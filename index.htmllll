function ld(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d;}catch{return d;}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch{}}
let done=ld('cp26d',{});
let cvals=ld('cp26c',{});

function showPage(id,btn){
  const page=document.getElementById(id);
  if(!page)return;
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nt').forEach(t=>t.classList.remove('active'));
  page.classList.add('active');
  const navBtn=btn || document.querySelector('.nt[onclick*="'+id+'"]');
  if(navBtn)navBtn.classList.add('active');
  if(location.hash !== '#'+id) history.replaceState(null,'','#'+id);
  window.scrollTo({top:0,behavior:'smooth'});
  if(id==='p2')buildCosts();
  if(id==='p3')buildMap();
}

function buildProgress(){
  const w=document.getElementById('dw');w.innerHTML='';
  DAYS.forEach((day,di)=>{
    const tot=day.s.length;
    const dn=day.s.filter((_,si)=>done[di+'-'+si]).length;
    const pct=tot?Math.round(dn/tot*100):0;
    const el=document.createElement('div');
    el.className='cb card'+(dn>0?' open':'');
    el.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+day.n+'</span>'+
        '<div class="ci"><div class="ctitle">'+day.t+'</div><div class="csub">'+day.d+'</div></div>'+
        '<div class="cr"><span class="ccnt">'+dn+'/'+tot+'</span>'+
        '<svg class="chev" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></div>'+
      '</div>'+
      '<div class="pb"><div class="pf" style="width:'+pct+'%"></div></div>'+
      '<div class="cbody">'+
        day.s.map(function(seg,si){
          var isDone=done[di+'-'+si];
          return '<div class="seg'+(isDone?' done':'')+'" onclick="toggleSeg('+di+','+si+')">'+
            '<div class="schk"><svg class="csv" width="9" height="7" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
            '<span class="stm">'+seg.ti+'</span>'+
            '<div class="sbdy"><div class="sttl">'+seg.h+'</div>'+(seg.de?'<div class="sdsc">'+seg.de+'</div>':'')+'</div>'+
            '<div class="sr2">'+
              (seg.free?'<span class="chip cf">bezmaksas</span>':'')+
              (seg.paid?'<span class="chip cp">apmaksāts</span>':'')+
              (seg.c&&!seg.free&&!seg.paid?'<span class="scst">'+seg.c+'</span>':'')+
            '</div></div>';
        }).join('')+
        '<div class="bft"><span>Dienas budžets</span><strong>'+day.tot+'</strong></div>'+
      '</div>';
    w.appendChild(el);
  });
  updateStats();
}

function toggleSeg(di,si){
  var k=di+'-'+si;done[k]=!done[k];sv('cp26d',done);buildProgress();
}
function updateStats(){
  var tot=DAYS.reduce(function(a,d){return a+d.s.length;},0);
  var n=Object.values(done).filter(Boolean).length;
  document.getElementById('spct').textContent=tot?Math.round(n/tot*100)+'%':'0%';
  document.getElementById('slft').textContent=tot-n;
}

function buildCosts(){
  var w=document.getElementById('cw');w.innerHTML='';
  COSTS.forEach(function(cat,ci){
    var catB=cat.items.reduce(function(a,i){return a+i.b;},0);
    var catA=0,catH=false;
    cat.items.forEach(function(item,ii){
      var k=ci+'-'+ii;
      if(item.paid){catA+=item.b;catH=true;}
      else if(cvals[k]!==undefined&&cvals[k]!==''){catA+=parseFloat(cvals[k])||0;catH=true;}
    });
    var catPct=catH?Math.min(Math.round(catA/catB*100),100):0;
    var el=document.createElement('div');
    el.className='cb card';
    var rows=cat.items.map(function(item,ii){
      var k=ci+'-'+ii;
      if(item.paid){
        return '<div class="crow">'+
          '<div class="clbl">'+item.l+'</div>'+
          '<span class="chip cp" style="flex-shrink:0;">apmaksāts</span>'+
          '<div class="cfxd">EUR '+item.b.toFixed(2)+'</div>'+
          '<div class="cdif under">✓</div>'+
        '</div>';
      }
      var av=cvals[k]!==undefined?cvals[k]:'';
      var diff=av!==''?parseFloat(av)-item.b:null;
      var dtxt=diff!==null?(diff>=0?'+':'')+diff.toFixed(0):'';
      var dcls=diff!==null?(diff>0.5?'over':'under'):'';
      return '<div class="crow">'+
        '<div class="clbl">'+item.l+'</div>'+
        '<div class="cfxd">EUR '+item.b.toFixed(2)+'</div>'+
        '<input class="cinp" type="number" inputmode="decimal" step="0.01" min="0" placeholder="ievadi" value="'+av+'" data-k="'+k+'" oninput="updateCost(this.dataset.k,this.value,this)" onchange="buildCosts()">'+
        '<div class="cdif '+dcls+'">'+(dtxt?'EUR '+dtxt:'')+'</div>'+
      '</div>';
    }).join('');
    el.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+cat.badge+'</span>'+
        '<div class="ci"><div class="ctitle">'+cat.t+'</div>'+
        '<div class="csub">Budžets: EUR '+catB.toFixed(0)+(catH?' · Iztērēts: EUR '+catA.toFixed(0):'')+'</div></div>'+
        '<svg class="chev" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>'+
      '</div>'+
      '<div class="pb"><div class="pf" style="width:'+catPct+'%"></div></div>'+
      '<div class="cbody">'+rows+
        '<div class="bft"><span>Kategorijas budžets</span><strong>EUR '+catB.toFixed(0)+'</strong></div>'+
      '</div>';
    w.appendChild(el);
  });
  recalc();
}

function updateCost(k,v,input){
  cvals[k]=v===''?'':parseFloat(v)||0;sv('cp26c',cvals);
  if(input){
    const parts=k.split('-').map(Number);
    const item=COSTS[parts[0]].items[parts[1]];
    const diff=v===''?null:(parseFloat(v)||0)-item.b;
    const row=input.closest('.crow');
    const diffEl=row?row.querySelector('.cdif'):null;
    if(diffEl){
      diffEl.classList.toggle('over', diff!==null && diff>0.5);
      diffEl.classList.toggle('under', diff!==null && diff<=0.5);
      diffEl.textContent=diff===null?'':'EUR '+(diff>=0?'+':'')+diff.toFixed(0);
    }
  }
  recalc();
}
function recalc(){
  var b=0,a=0,has=false;
  COSTS.forEach(function(cat,ci){cat.items.forEach(function(item,ii){
    b+=item.b;var k=ci+'-'+ii;
    if(item.paid){a+=item.b;has=true;}
    else if(cvals[k]!==undefined&&cvals[k]!==''){a+=parseFloat(cvals[k])||0;has=true;}
  });});
  document.getElementById('kb').textContent='EUR '+b.toFixed(0);
  var ae=document.getElementById('ka'),de=document.getElementById('kd');
  if(has){
    ae.textContent='EUR '+a.toFixed(0);ae.style.color='var(--blue)';
    var d=a-b;
    de.textContent=(d>=0?'+':'')+' EUR '+d.toFixed(0);
    de.style.color=d>0?'var(--orange)':'var(--green)';
  }else{
    ae.textContent='—';ae.style.color='var(--muted)';
    de.textContent='—';de.style.color='var(--muted)';
  }
}

var tC={red:'#c2185b',gold:'#a07ac4',green:'#4ea68a',blue:'#5b9bd6'};
var STOP_COORDS={
  "Valmiera":[57.5389,25.4264],"Rīgas apvedceļš":[56.8520,24.0500],"Panevēžis, Lietuva":[55.7333,24.3500],"Kaunas Vecpilsēta":[54.8985,23.9036],"Bjalostoka, Polija":[53.1325,23.1688],"Biedronka, Varšava":[52.2297,21.0122],"Hotel Arkadia Royal":[52.2227,21.1647],"Varšavas Vecpilsēta":[52.2497,21.0122],
  "MOP Wozniki, A1":[50.5890,19.0580],"CZ robeža — Cieszyn":[49.7461,18.6261],"Brno — Soul Bistro":[49.1951,16.6068],"AT robeža — A2":[48.7436,16.7565],"Steiner Residences":[48.0856,16.2977],
  "Mūzikas Universitāte Vīne":[48.1933,16.3060],"Naschmarkt":[48.1980,16.3618],"Šēnbrunnas dārzs":[48.1845,16.3122],"Musikverein — Steinerner Saal":[48.2006,16.3726],"Café Central":[48.2100,16.3654],"Musikverein — Glaserner Saal":[48.2006,16.3726],
  "Prāga — Kārļa tilts":[50.0865,14.4114],"Drēzdene — Frauenkirche":[51.0519,13.7416],"Berlīne — Mitte":[52.5170,13.3889],"Brandenburgas vārti":[52.5163,13.3777],"Holokasta memoriāls":[52.5138,13.3787],"Reihstaga kupols":[52.5186,13.3762],"East Side Gallery":[52.5050,13.4397],"Staatsoper Unter den Linden":[52.5164,13.3949],
  "Solo brauciens 05:00":[52.5200,13.4050],"Elbloga — brokastis":[54.1561,19.4045],"Kaunas — degviela":[54.8985,23.9036],"VALMIERA":[57.5389,25.4264]
};
var routeMap=null, routeLayer=null, markerLayer=null;

function htmlEscape(str){return String(str).replace(/[&<>"]/g,function(m){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m];});}
function stopLatLng(s){return STOP_COORDS[s.name] || null;}
function pinIcon(type){
  return L.divIcon({className:'',html:'<div class="map-pin" style="background:'+tC[type]+'"></div>',iconSize:[18,18],iconAnchor:[9,9],popupAnchor:[0,-8]});
}
function buildStopsGrid(){
  var g=document.getElementById('stops-g');
  if(!g || g.dataset.built==='1')return;
  g.innerHTML=STOPS.map(function(s,i){
    return '<button class="spc" type="button" onclick="focusStop('+i+')" style="text-align:left;cursor:pointer;width:100%;font-family:inherit;">'+
      '<div class="spd"><span style="width:8px;height:8px;border-radius:50%;background:'+tC[s.type]+';display:inline-block;flex-shrink:0;"></span>'+htmlEscape(s.day)+'</div>'+
      '<div class="spn">'+htmlEscape(s.name)+'</div>'+
      '<div class="spnt">'+htmlEscape(s.note)+'</div>'+
    '</button>';
  }).join('');
  g.dataset.built='1';
}
function buildMap(){
  buildStopsGrid();
  if(routeMap){setTimeout(function(){routeMap.invalidateSize();},120);return;}
  var el=document.getElementById('route-map');
  if(!el || typeof L==='undefined'){
    if(el)el.innerHTML='<div style="padding:1rem;font-size:0.8rem;color:#8494aa;">Karte nevar ielādēties. Pārbaudi internetu vai atver Google Maps pogu augšā.</div>';
    return;
  }
  routeMap=L.map('route-map',{zoomControl:true,scrollWheelZoom:true,tap:true}).setView([52.5,18.5],5);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:19,attribution:'&copy; OpenStreetMap contributors'}).addTo(routeMap);
  markerLayer=L.layerGroup().addTo(routeMap);
  var latlngs=[];
  STOPS.forEach(function(s,i){
    var ll=stopLatLng(s); if(!ll)return;
    latlngs.push(ll);
    var pop='<div class="map-pop"><h3>'+htmlEscape(s.day)+' · '+htmlEscape(s.name)+'</h3><p>'+htmlEscape(s.note)+'</p><small>Klikšķini kartē, zoomo ar +/− vai ar pirkstiem.</small></div>';
    var m=L.marker(ll,{icon:pinIcon(s.type),title:s.name}).bindPopup(pop).addTo(markerLayer);
    s._marker=m;
  });
  routeLayer=L.polyline(latlngs,{color:'#c2185b',weight:3,opacity:0.65,dashArray:'8,8'}).addTo(routeMap);
  centerMap();
  setTimeout(function(){routeMap.invalidateSize();centerMap();},250);
}
function centerMap(){
  if(routeMap && routeLayer){routeMap.fitBounds(routeLayer.getBounds(),{padding:[28,28]});}
}
function focusStop(i){
  var s=STOPS[i];
  if(!s)return;
  showPage('p3');
  buildMap();
  var ll=stopLatLng(s);
  if(routeMap && ll){routeMap.setView(ll,12,{animate:true}); if(s._marker)s._marker.openPopup();}
}

function resetProgress(){
  if(confirm('Notīrīt visu maršruta progresu?')){
    done={};sv('cp26d',done);buildProgress();
  }
}
function resetCosts(){
  if(confirm('Notīrīt ievadītās izmaksas?')){
    cvals={};sv('cp26c',cvals);buildCosts();
  }
}

var btt=document.getElementById('btt');
window.addEventListener('scroll',function(){btt.classList.toggle('show',window.scrollY>300);},{passive:true});
window.addEventListener('hashchange',function(){showPage((location.hash||'#p1').slice(1));});

buildProgress();
showPage((location.hash||'#p1').slice(1));
</script>
</body>
</html>
