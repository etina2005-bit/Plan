<!DOCTYPE html>
<html lang="lv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ceļu Plāns 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIINfQbPCkGYoB0ZpKQXIGIblt8t0Ck0JQ=" crossorigin="">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --glass:rgba(255,255,255,0.58);
  --glass2:rgba(255,255,255,0.76);
  --border:rgba(255,255,255,0.72);
  --bsoft:rgba(200,215,240,0.4);
  --ink:#1c2333;--ink2:#3a4558;--muted:#8494aa;
  --blue:#5b9bd6;--pink:#c2185b;--green:#4ea68a;--orange:#d4826b;
  --r:14px;--rsm:10px;
  --sh:0 4px 28px rgba(90,140,200,0.13);--shsm:0 2px 12px rgba(90,140,200,0.09);
}
html{scroll-behavior:smooth;}
body{font-family:'Inter',sans-serif;font-weight:400;color:var(--ink);min-height:100vh;overflow-x:hidden;
  background:linear-gradient(135deg,#daeaf8 0%,#ecd8f0 50%,#f9c8d8 100%) fixed;}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-thumb{background:rgba(194,24,91,0.2);border-radius:10px;}

nav{position:fixed;bottom:1.3rem;left:50%;transform:translateX(-50%);z-index:300;
  display:flex;align-items:center;gap:3px;max-width:calc(100vw - 1rem);overflow-x:auto;scrollbar-width:none;
  background:rgba(255,255,255,0.72);backdrop-filter:blur(28px) saturate(2);
  -webkit-backdrop-filter:blur(28px) saturate(2);
  border:1px solid var(--border);border-radius:100px;padding:5px;
  box-shadow:0 8px 32px rgba(90,140,200,0.18),0 2px 8px rgba(194,24,91,0.1);}
.nt{font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:500;letter-spacing:0.02em;
  color:var(--ink2);background:none;border:none;padding:0.42rem 1.15rem;border-radius:100px;
  cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.nt:hover{background:rgba(255,255,255,0.8);color:var(--ink);}
.nt.active{background:var(--pink);color:white;box-shadow:0 2px 12px rgba(194,24,91,0.35);}

.page{display:none;padding-top:0.35rem;padding-bottom:6rem;min-height:100vh;}
.page.active{display:block;animation:fi 0.22s ease;}
@keyframes fi{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

.ph{padding:1.25rem 1.5rem 1.15rem;text-align:center;}
.ph h1{font-family:'Playfair Display',serif;font-size:2.1rem;font-weight:400;color:var(--ink);margin-bottom:0.4rem;line-height:1.2;}
.ph h1 em{font-style:italic;background:linear-gradient(135deg,var(--blue),var(--pink));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.ph .sub{font-size:0.74rem;color:var(--muted);letter-spacing:0.04em;}

.wrap{max-width:800px;margin:0 auto;padding:0 1.5rem;}

.card{background:var(--glass);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
  border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shsm);}

.sr{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--bsoft);
  border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shsm);margin-bottom:1.2rem;}
.sc{background:var(--glass);backdrop-filter:blur(18px);padding:1.15rem 0.5rem;text-align:center;}
.sv{font-family:'Playfair Display',serif;font-size:1.45rem;display:block;color:var(--ink);margin-bottom:0.18rem;}
.sl{font-size:0.59rem;font-weight:500;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}

.cb{margin-bottom:0.75rem;}
.chd{display:flex;align-items:center;gap:0.8rem;padding:0.9rem 1.1rem;
  cursor:pointer;user-select:none;border-radius:var(--r);transition:background 0.16s;}
.chd:hover{background:rgba(255,255,255,0.1);}
.cbadge{font-size:0.6rem;font-weight:600;letter-spacing:0.07em;text-transform:uppercase;
  background:linear-gradient(135deg,var(--blue),var(--pink));
  color:white;padding:0.24rem 0.6rem;border-radius:100px;flex-shrink:0;}
.ci{flex:1;min-width:0;}
.ctitle{font-size:0.9rem;font-weight:500;color:var(--ink);margin-bottom:0.06rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.csub{font-size:0.66rem;color:var(--muted);}
.cr{display:flex;align-items:center;gap:0.5rem;flex-shrink:0;}
.ccnt{font-size:0.66rem;color:var(--muted);}
.chev{color:var(--muted);transition:transform 0.22s;flex-shrink:0;}
.cb.open .chev{transform:rotate(180deg);}
.pb{height:2px;background:rgba(200,220,240,0.3);border-radius:100px;overflow:hidden;margin-top:2px;}
.pf{height:100%;background:linear-gradient(90deg,var(--blue),var(--pink));transition:width 0.4s;}
.cbody{display:none;border-top:1px solid var(--bsoft);overflow:hidden;border-radius:0 0 var(--r) var(--r);}
.cb.open .cbody{display:block;animation:sd 0.2s ease;}
@keyframes sd{from{opacity:0;transform:translateY(-4px)}to{opacity:1;transform:translateY(0)}}

.seg{display:flex;align-items:flex-start;gap:0.8rem;padding:0.78rem 1.1rem;
  border-bottom:1px solid rgba(200,220,240,0.22);cursor:pointer;transition:background 0.14s;}
.seg:last-of-type{border-bottom:none;}
.seg:hover{background:rgba(255,255,255,0.32);}
.seg.done{opacity:0.52;}
.schk{width:20px;height:20px;border-radius:50%;flex-shrink:0;margin-top:2px;
  border:1.5px solid rgba(150,180,220,0.45);background:rgba(255,255,255,0.55);
  display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.seg.done .schk{background:linear-gradient(135deg,var(--blue),var(--pink));border-color:transparent;}
.csv{display:none;}
.seg.done .csv{display:block;}
.stm{font-size:0.65rem;font-weight:500;color:var(--muted);min-width:52px;white-space:nowrap;padding-top:3px;flex-shrink:0;}
.sbdy{flex:1;min-width:0;}
.sttl{font-size:0.84rem;font-weight:500;color:var(--ink);margin-bottom:0.14rem;line-height:1.35;}
.seg.done .sttl{text-decoration:line-through;color:var(--muted);}
.sdsc{font-size:0.72rem;color:var(--muted);line-height:1.5;font-weight:300;}
.sr2{display:flex;flex-direction:column;align-items:flex-end;gap:0.2rem;flex-shrink:0;padding-top:2px;min-width:68px;}
.scst{font-size:0.68rem;font-weight:500;color:var(--ink2);white-space:nowrap;}
.chip{font-size:0.56rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;
  padding:0.12rem 0.4rem;border-radius:100px;white-space:nowrap;}
.cf{background:rgba(78,166,138,0.12);color:var(--green);border:1px solid rgba(78,166,138,0.28);}
.cp{background:rgba(194,24,91,0.1);color:var(--pink);border:1px solid rgba(194,24,91,0.25);}
.bft{display:flex;justify-content:space-between;align-items:center;
  padding:0.65rem 1.1rem;border-top:1px solid var(--bsoft);
  font-size:0.72rem;color:var(--muted);}
.bft strong{color:var(--ink2);font-weight:600;}


.tools{display:flex;gap:0.6rem;justify-content:center;flex-wrap:wrap;margin:0 0 1.2rem;}
.toolbtn{font-family:'Inter',sans-serif;font-size:0.68rem;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;
  color:var(--ink2);background:rgba(255,255,255,0.62);border:1px solid var(--border);
  border-radius:100px;padding:0.55rem 0.85rem;cursor:pointer;box-shadow:var(--shsm);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);transition:all 0.18s;}
.toolbtn:hover{background:rgba(255,255,255,0.92);transform:translateY(-1px);}
.note{font-size:0.68rem;color:var(--muted);line-height:1.5;text-align:center;margin:-0.4rem 0 1rem;}

/* costs */
.cov{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--bsoft);
  border:1px solid var(--border);border-radius:var(--r);overflow:hidden;box-shadow:var(--shsm);margin-bottom:1.5rem;}
.cvc{background:var(--glass);backdrop-filter:blur(18px);padding:1.2rem;text-align:center;}
.cvv{font-family:'Playfair Display',serif;font-size:1.5rem;display:block;color:var(--ink);margin-bottom:0.18rem;}
.cvl{font-size:0.59rem;font-weight:500;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;}

.crow{display:flex;align-items:center;gap:0.8rem;padding:0.7rem 1.1rem;
  border-bottom:1px solid rgba(200,220,240,0.22);}
.crow:last-of-type{border-bottom:none;}
.clbl{flex:1;font-size:0.82rem;color:var(--ink);min-width:0;}
.cfxd{font-size:0.74rem;color:var(--muted);white-space:nowrap;flex-shrink:0;}
.cinp{font-family:'Inter',sans-serif;font-size:0.78rem;color:var(--ink);font-weight:500;
  background:rgba(255,255,255,0.65);border:1px solid rgba(200,220,240,0.45);
  border-radius:8px;padding:0.3rem 0.5rem;outline:none;
  transition:border-color 0.16s,box-shadow 0.16s;text-align:right;width:95px;flex-shrink:0;}
.cinp:focus{border-color:rgba(194,24,91,0.4);box-shadow:0 0 0 3px rgba(194,24,91,0.08);}
.cinp::placeholder{color:var(--muted);font-weight:300;}
.cdif{font-size:0.72rem;font-weight:600;white-space:nowrap;min-width:58px;text-align:right;flex-shrink:0;}
.cdif.over{color:var(--orange);}
.cdif.under{color:var(--green);}

/* map */
.ml{display:flex;flex-wrap:wrap;gap:1rem;align-items:center;padding:0.9rem 1.1rem;margin-bottom:1.2rem;font-size:0.72rem;color:var(--ink2);}
.ld{width:9px;height:9px;border-radius:50%;display:inline-block;flex-shrink:0;}
.li{display:flex;align-items:center;gap:0.4rem;}
.mab{display:flex;align-items:center;gap:0.5rem;justify-content:center;width:100%;padding:0.85rem;margin-bottom:1.2rem;
  background:linear-gradient(135deg,rgba(91,155,214,0.12),rgba(194,24,91,0.1));
  border:1px solid var(--border);border-radius:var(--rsm);
  font-size:0.78rem;font-weight:600;color:var(--ink);text-decoration:none;
  cursor:pointer;transition:background 0.18s;font-family:'Inter',sans-serif;}
.mab:hover{background:linear-gradient(135deg,rgba(91,155,214,0.22),rgba(194,24,91,0.18));}
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:0.65rem;margin-bottom:1.5rem;}
.spc{background:var(--glass);backdrop-filter:blur(16px);border:1px solid var(--border);
  border-radius:var(--rsm);padding:0.85rem;box-shadow:var(--shsm);transition:background 0.16s;}
.spc:hover{background:var(--glass2);}
.spd{font-size:0.62rem;font-weight:500;color:var(--muted);margin-bottom:0.28rem;display:flex;align-items:center;gap:0.35rem;}
.spn{font-size:0.84rem;font-weight:500;color:var(--ink);margin-bottom:0.16rem;}
.spnt{font-size:0.7rem;color:var(--muted);font-weight:300;line-height:1.4;}
.slbl{font-size:0.62rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:0.6rem;padding:0 0.1rem;}
 .mfw{border-radius:var(--rsm);overflow:hidden;border:1px solid var(--border);box-shadow:var(--shsm);background:rgba(255,255,255,0.45);}
#route-map{width:100%;height:540px;display:block;}
.leaflet-container{font-family:'Inter',sans-serif;background:#d9e8f5;}
.map-pin{width:18px;height:18px;border-radius:50%;border:2px solid white;box-shadow:0 2px 10px rgba(28,35,51,0.32);}
.map-pop h3{font-size:0.86rem;margin:0 0 0.2rem;color:var(--ink);}
.map-pop p{font-size:0.72rem;line-height:1.45;margin:0;color:var(--ink2);}
.map-pop small{display:inline-block;margin-top:0.35rem;color:var(--muted);font-size:0.65rem;}
.map-actions{display:flex;gap:0.6rem;flex-wrap:wrap;margin:0 0 1rem;}
.map-actions .mab{margin-bottom:0;flex:1;min-width:220px;}

/* contacts */
.cg{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
.ctc{padding:1.25rem;}
.ctt{font-size:0.66rem;font-weight:600;letter-spacing:0.09em;text-transform:uppercase;color:var(--muted);
  margin-bottom:0.9rem;padding-bottom:0.6rem;border-bottom:1px solid var(--bsoft);}
.ctr{padding:0.5rem 0;border-bottom:1px solid rgba(200,220,240,0.18);}
.ctr:last-child{border-bottom:none;}
.ctk{font-size:0.61rem;font-weight:500;color:var(--muted);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:0.18rem;}
.ctv{font-size:0.81rem;color:var(--ink);line-height:1.55;}
.ctv a{color:var(--blue);text-decoration:none;}
.ctv a:hover{text-decoration:underline;}
.mn{font-weight:600;letter-spacing:0.02em;}
.ac{color:var(--orange);font-weight:500;}
.okc{color:var(--green);font-weight:500;}
.ir{display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:start;
  padding:0.52rem 0;border-bottom:1px solid rgba(200,220,240,0.18);}
.ir:last-child{border-bottom:none;}
.im{font-size:0.81rem;color:var(--ink);}
.is{font-size:0.67rem;color:var(--muted);margin-top:0.14rem;}
.idl{font-size:0.65rem;font-weight:600;color:var(--orange);white-space:nowrap;padding-top:3px;}
.idl.ok{color:var(--green);}
.eg{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:0.5rem;}
.ei{padding:0.7rem 0.9rem;}
.en{font-size:1.15rem;font-weight:600;color:var(--pink);}
.en a{color:inherit;text-decoration:none;}
.el{font-size:0.65rem;color:var(--muted);margin-top:0.1rem;}

#btt{position:fixed;bottom:5.8rem;right:1.5rem;z-index:200;
  width:40px;height:40px;border-radius:50%;
  background:rgba(255,255,255,0.75);backdrop-filter:blur(16px);
  border:1px solid var(--border);box-shadow:var(--sh);
  color:var(--ink2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  opacity:0;transform:translateY(10px);pointer-events:none;
  transition:opacity 0.22s,transform 0.22s;}
#btt.show{opacity:1;transform:translateY(0);pointer-events:all;}
#btt:hover{background:rgba(255,255,255,0.95);}

@media(max-width:640px){
  nav{bottom:0.9rem;padding:4px;max-width:calc(100vw - 0.7rem);}
  .nt{padding:0.38rem 0.7rem;font-size:0.64rem;}
  .wrap{padding:0 1rem;}
  .sr{grid-template-columns:repeat(2,1fr);}
  .cg{grid-template-columns:1fr;}
  .cov{grid-template-columns:repeat(3,1fr);}
  .eg{grid-template-columns:repeat(2,1fr);}
  .ph{padding:1rem 1rem 1rem;}
  .ph h1{font-size:1.75rem;}
  .sg{grid-template-columns:repeat(2,1fr);}
  .sr2{min-width:55px;}
  #btt{bottom:5rem;right:1rem;}
}
@media(max-width:400px){
  .nt{padding:0.33rem 0.5rem;font-size:0.6rem;}
  .sg{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<nav>
  <button class="nt active" onclick="showPage('p1',this)">Maršruts</button>
  <button class="nt" onclick="showPage('p2',this)">Izmaksas</button>
  <button class="nt" onclick="showPage('p3',this)">Karte</button>
  <button class="nt" onclick="showPage('p4',this)">Kontakti</button>
</nav>

<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Uz augšu">
  <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<!-- PAGE 1 -->
<div id="p1" class="page active">
  <div class="ph"><h1><em>Maršruta Progress</em></h1>
    <p class="sub">Valmiera → Varšava → Vīne → Berlīne → Valmiera &nbsp;·&nbsp; 27. maijs – 4. jūnijs 2026</p></div>
  <div class="wrap">
    <div class="sr">
      <div class="sc"><span class="sv">~4 200</span><span class="sl">km kopā</span></div>
      <div class="sc"><span class="sv">9</span><span class="sl">Dienas</span></div>
      <div class="sc"><span class="sv" id="spct">0%</span><span class="sl">Pabeigts</span></div>
      <div class="sc"><span class="sv" id="slft">–</span><span class="sl">Pieturas atlicis</span></div>
    </div>
    <div class="tools"><button class="toolbtn" onclick="resetProgress()">Notīrīt progresu</button></div>
    <div id="dw"></div>
  </div>
</div>

<!-- PAGE 2 -->
<div id="p2" class="page">
  <div class="ph"><h1><em>Izmaksu Plāns</em></h1>
    <p class="sub">Noklikšķini uz kategorijas, lai izvērstu · Apmaksātās izmaksas ir fiksētas</p></div>
  <div class="wrap">
    <div class="cov">
      <div class="cvc card"><span class="cvv" id="kb">—</span><span class="cvl">Plānotais</span></div>
      <div class="cvc card"><span class="cvv" id="ka">—</span><span class="cvl">Iztērēts</span></div>
      <div class="cvc card"><span class="cvv" id="kd">—</span><span class="cvl">Starpība</span></div>
    </div>
    <div class="tools"><button class="toolbtn" onclick="resetCosts()">Notīrīt izmaksas</button></div>
    <div id="cw"></div>
  </div>
</div>

<!-- PAGE 3 -->
<div id="p3" class="page">
  <div class="ph"><h1><em>Maršruta Karte</em></h1>
    <p class="sub">Visas pieturas, naktsmītnes un sacensību vietas</p></div>
  <div class="wrap">
    <div class="card ml">
      <div class="li"><div class="ld" style="background:#c2185b;"></div> Naktsmītne</div>
      <div class="li"><div class="ld" style="background:#a07ac4;"></div> Sacensības</div>
      <div class="li"><div class="ld" style="background:#4ea68a;"></div> Apskate</div>
      <div class="li"><div class="ld" style="background:#5b9bd6;"></div> Degviela/Tehniskie</div>
    </div>
    <div class="slbl">Interaktīvā karte</div>
    <p class="note">Zoomo, velc karti, klikšķini uz punktiem. Ceļu līnija ir plāna maršruta skice, bet pašā kartē redzami reālie ceļi un ielas.</p>
    <div class="map-actions">
      <button class="mab card" type="button" onclick="centerMap()">Centrēt visu maršrutu</button>
      <a class="mab card" href="https://www.google.com/maps/dir/Valmiera%2C%20Latvia/Warsaw%2C%20Poland/M%C3%B6dling%2C%20Austria/Musikverein%2C%20Vienna%2C%20Austria/Berlin%2C%20Germany/Valmiera%2C%20Latvia" target="_blank" rel="noopener">Atvērt pilno maršrutu Google Maps</a>
    </div>
    <div class="mfw"><div id="route-map" aria-label="Interaktīva maršruta karte"></div></div>
    <div class="slbl" style="margin-top:1.2rem;">Visas pieturas</div>
    <div class="sg" id="stops-g"></div>
  </div>
</div>

<!-- PAGE 4 -->
<div id="p4" class="page">
  <div class="ph"><h1><em>Kontakti & Info</em></h1>
    <p class="sub">Naktsmītnes · Sacensības · Ārkārtas numuri</p></div>
  <div class="wrap">
    <div class="cg">

      <div class="card ctc">
        <div class="ctt">Naktsmītnes</div>
        <div class="ctr"><div class="ctk">Hotel Arkadia Royal — Varšava</div>
          <div class="ctv">ul. Czecha 10, Wawer<br><a href="tel:+48225173660">+48 22 517 36 60</a><br>
            <small style="color:var(--muted);font-size:0.68rem;">Bezmaksas stāvvieta · SPA līdz 23:00</small></div></div>
        <div class="ctr"><div class="ctk">Steiner Residences — Mēdlings</div>
          <div class="ctv">Duursmagasse 1, 2340 Mēdlings<br><a href="tel:+436644480400">+43 664 4480400</a></div></div>
        <div class="ctr"><div class="ctk">Ieregistrēšanās kods</div>
          <div class="ctv">Numurs: <span class="mn">659513351</span><br>PIN: <span class="mn">077300</span><br>
            Apstiprinājums: <span class="mn" style="font-size:0.7rem;">3291112877065982311</span></div></div>
        <div class="ctr"><div class="ctk">Mēdlings atcelšanas termiņš</div>
          <div class="ctv"><span class="ac">23:59 CEST, 24. maijs 2026</span></div></div>
        <div class="ctr"><div class="ctk">Berlīne — dzīvoklis</div>
          <div class="ctv">Mitte · blakus Staatsoper<br><span class="okc">Jau nodrošināts</span></div></div>
      </div>

      <div class="card ctc">
        <div class="ctt">Hedda Urbani Wettbewerb</div>
        <div class="ctr"><div class="ctk">Kontakts</div>
          <div class="ctv"><a href="mailto:competition@opernfreunde.at">competition@opernfreunde.at</a></div></div>
        <div class="ctr"><div class="ctk">Mēģinājums — 29. maijs</div>
