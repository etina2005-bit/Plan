// ── State ──
let done=ld('cp26d',{});
let cvals=ld('cp26c',{});
let summaryOverride=ld('cp26so',null);
if(summaryOverride!==null)summaryOverride=parseFloat(summaryOverride)||null;

// ── Page navigation ──
let currentPage='p0';
function showPage(id,btn){
  const prev=document.getElementById(currentPage);
  const next=document.getElementById(id);
  if(id===currentPage)return;
  prev.classList.remove('active');
  next.classList.add('active','page-enter');
  setTimeout(()=>next.classList.remove('page-enter'),350);
  document.querySelectorAll('.bn').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  currentPage=id;
  document.getElementById('pageArea').scrollTop=0;
  if(id==='p1')buildTimeline();
  if(id==='p2')buildCosts();
  if(id==='p3'){buildStopGroups();setTimeout(()=>{buildRealMap();},100);}
}

// ── Stats ──
function calcStats(){
  let tot=0,n=0;
  DAYS.forEach((day,di)=>{
    day.s.forEach((seg,si)=>{
      if(seg.info)return;
      tot++;if(done[di+'-'+si])n++;
    });
  });
  return{tot,n,pct:tot?Math.round(n/tot*100):0};
}
function updateStats(){
  const{tot,n,pct}=calcStats();
  document.getElementById('t-pct').textContent=pct+'%';
  document.getElementById('t-left').textContent=tot-n;
  document.getElementById('route-sub').textContent=n+' / '+tot+' pieturas pabeigtas';
  document.getElementById('prog-text').textContent=n+' / '+tot;
  // Animate fill
  requestAnimationFrame(()=>{
    document.getElementById('prog-fill').style.width=pct+'%';
  });
}

// ── Timeline (Route page) ──
const DAY_COLORS=['#4ade99','#34d399','#60a5fa','#a78bfa','#f472b6','#fb923c','#34d399','#4ade99'];

function buildTimeline(){
  const el=document.getElementById('tl');
  if(el.children.length)return;
  DAYS.forEach((day,di)=>{
    const checkable=day.s.filter(s=>!s.info);
    const dn=checkable.filter((_,ci)=>done[di+'-'+day.s.indexOf(checkable[ci])]).length;
    const tot=checkable.length;
    const pct=tot?Math.round(dn/tot*100):0;
    const dc=DAY_COLORS[di]||'#4ade99';
    const div=document.createElement('div');
    div.className='tl-day glass';
    div.style.cssText='margin-bottom:0.5rem;border-radius:18px;overflow:hidden;';
    div.id='tld-'+di;

    const stopsHtml=day.s.map((seg,si)=>{
      if(seg.info){
        return `<div class="tl-stop info-only">
          <div class="tl-stop-marker"><div class="tl-info-dot"></div></div>
          <div class="tl-stop-body">
            <div class="tl-stop-time">${seg.ti}</div>
            <div class="tl-stop-title" style="font-style:italic;opacity:0.6">${seg.h}</div>
            ${seg.de?`<div class="tl-stop-desc">${seg.de}</div>`:''}
          </div>
          <div class="tl-stop-right">${seg.free?'<span class="tl-chip chip-free">bezmaksas</span>':seg.c?`<span class="tl-cost">${seg.c}</span>`:''}</div>
        </div>`;
      }
      const isDone=done[di+'-'+si];
      return `<div class="tl-stop clickable${isDone?' done':''}" data-stop="${di}-${si}" onclick="toggleStop(${di},${si})">
        <div class="tl-stop-marker">
          <svg class="tl-check-svg" width="10" height="8" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          ${!isDone?`<div class="tl-info-dot"></div>`:''}
        </div>
        <div class="tl-stop-body">
          <div class="tl-stop-time">${seg.ti}</div>
          <div class="tl-stop-title">${seg.h}</div>
          ${seg.de?`<div class="tl-stop-desc">${seg.de}</div>`:''}
        </div>
        <div class="tl-stop-right">${seg.free?'<span class="tl-chip chip-free">bezmaksas</span>':seg.paid?'<span class="tl-chip chip-paid">apmaksāts</span>':seg.c?`<span class="tl-cost">${seg.c}</span>`:''}</div>
      </div>`;
    }).join('');

    div.innerHTML=`
      <div class="tl-day-head" onclick="this.closest('.tl-day').classList.toggle('open')"
           style="padding-left:1.1rem;border-left:4px solid ${dc};">
        <span class="tl-day-badge" style="background:${dc};color:#0f1a0e;">${day.n}</span>
        <div class="tl-day-info">
          <div class="tl-day-name">${day.t}</div>
          <div class="tl-day-date">${day.d} · ${dn}/${tot}</div>
        </div>
        <div class="tl-day-right">
          <span class="tl-count">${day.tot}</span>
          <svg class="tl-chev" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </div>
      </div>
      <div class="cat-pb"><div class="cat-pb-fill" style="width:${pct}%"></div></div>
      <div class="tl-stops">${stopsHtml}
        <div class="tl-day-budget"><span>Dienas budžets</span><strong>${day.tot}</strong></div>
      </div>`;
    el.appendChild(div);
  });
}

function toggleStop(di,si){
  const k=di+'-'+si;
  done[k]=!done[k];
  sv('cp26d',done);
  // Update in-place WITHOUT rebuilding — keeps sections open
  const stopEl=document.querySelector(`[data-stop="${di}-${si}"]`);
  if(stopEl){
    if(done[k]){
      stopEl.classList.add('done');
      stopEl.querySelector('.tl-check-svg').style.display='block';
      const dot=stopEl.querySelector('.tl-info-dot');if(dot)dot.style.display='none';
    } else {
      stopEl.classList.remove('done');
      stopEl.querySelector('.tl-check-svg').style.display='none';
      const dot=stopEl.querySelector('.tl-info-dot');if(dot)dot.style.display='block';
    }
    // Update day progress bar & counter
    const dayEl=document.getElementById('tld-'+di);
    if(dayEl){
      const checkable=DAYS[di].s.filter(s=>!s.info);
      const dn=checkable.filter((_,ci)=>done[di+'-'+DAYS[di].s.indexOf(checkable[ci])]).length;
      const tot=checkable.length;
      const pct=tot?Math.round(dn/tot*100):0;
      const pb=dayEl.querySelector('.cat-pb-fill');if(pb)pb.style.width=pct+'%';
      const dc=dayEl.querySelector('.tl-day-date');
      if(dc){const parts=dc.textContent.split(' · ');dc.textContent=parts[0]+' · '+dn+'/'+tot;}
    }
  }
  updateStats();
}

// ── Costs ──
function rowTotal(k){
  if(!cvals[k]||!cvals[k].length)return null;
  return cvals[k].reduce((s,e)=>s+(parseFloat(e.v)||0),0);
}
function migrateCvals(){
  Object.keys(cvals).forEach(k=>{
    if(!Array.isArray(cvals[k])){
      if(cvals[k]!==''&&cvals[k]!=null){cvals[k]=[{v:parseFloat(cvals[k])||0}];}
      else{delete cvals[k];}
    }
  });
  sv('cp26c',cvals);
}

function buildCosts(){
  const w=document.getElementById('cw');
  if(w.children.length){recalc();return;}
  COSTS.forEach((cat,ci)=>{
    const catB=cat.items.reduce((a,i)=>a+i.b,0);
    const el=document.createElement('div');
    el.className='cost-cat';el.id='cat-'+ci;
    const rowsHtml=cat.items.map((item,ii)=>{
      const k=ci+'-'+ii;
      if(item.paid){
        return `<div class="cost-row"><div class="cost-row-top"><div class="cost-row-lbl">${item.l}</div><span class="tl-chip chip-paid" style="flex-shrink:0;">apmaksāts</span><div class="cost-row-plan">EUR ${item.b.toFixed(2)}</div></div></div>`;
      }
      return `<div class="cost-row" id="row-${k}">
        <div class="cost-row-top">
          <div class="cost-row-lbl">${item.l}</div>
          <div class="cost-row-plan">EUR ${item.b.toFixed(2)}</div>
        </div>
        <div class="cost-entries" id="entries-${k}"></div>
        <div class="cost-row-bottom" id="bot-${k}" style="display:none;">
          <span class="cost-row-total" id="val-${k}">–</span>
          <span class="cost-row-diff" id="dif-${k}"></span>
        </div>
      </div>`;
    }).join('');
    el.innerHTML=`
      <div class="cost-cat-head" onclick="this.closest('.cost-cat').classList.toggle('open')">
        <span class="cat-badge">${cat.badge}</span>
        <div class="cat-info">
          <div class="cat-title">${cat.t}</div>
          <div class="cat-sub" id="csub-${ci}">Budžets: EUR ${catB.toFixed(0)}</div>
        </div>
        <svg class="cat-chev" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </div>
      <div class="cat-pb"><div class="cat-pb-fill" id="cpf-${ci}" style="width:0%"></div></div>
      <div class="cost-cat-body">${rowsHtml}</div>`;
    w.appendChild(el);
  });
  // Render entry pills
  COSTS.forEach((cat,ci)=>{
    cat.items.forEach((item,ii)=>{
      if(item.paid)return;
      const k=ci+'-'+ii;
      renderEntries(k,item.b);
    });
  });
  recalc();
}

function renderEntries(k,budget){
  const el=document.getElementById('entries-'+k);
  if(!el)return;
  const entries=cvals[k]||[];
  const existingWrap=el.querySelector('.cinp-wrap');
  const pills=entries.map((e,ei)=>{
    const p=document.createElement('span');
    p.className='entry-pill';p.id='pill-'+k+'-'+ei;
    p.innerHTML=`EUR ${(parseFloat(e.v)||0).toFixed(2)}<button class="pill-del" onclick="delEntry('${k}',${ei},${budget})">×</button>`;
    return p.outerHTML;
  }).join('');
  el.innerHTML=pills+`<button class="add-btn" onclick="startAdd('${k}',${budget})" title="Pievienot">+</button>`;
  if(existingWrap)el.insertBefore(existingWrap,el.lastChild);
  // update bottom
  const total=rowTotal(k);
  const bot=document.getElementById('bot-'+k);
  const valEl=document.getElementById('val-'+k);
  const difEl=document.getElementById('dif-'+k);
  if(entries.length>0&&bot){
    bot.style.display='flex';
    valEl.textContent='Kopā: EUR '+total.toFixed(2);
    const diff=total-budget;
    difEl.textContent=diff>0.05?'+ EUR '+diff.toFixed(2):diff<-0.05?'− EUR '+Math.abs(diff).toFixed(2):'✓';
    difEl.className='cost-row-diff '+(diff>0.05?'diff-over':'diff-under');
  } else if(bot){
    bot.style.display='none';
  }
}

function startAdd(k,budget){
  const el=document.getElementById('entries-'+k);
  if(!el)return;
  if(el.querySelector('.cinp-wrap')){el.querySelector('.cinp').focus();return;}
  const addBtn=el.querySelector('.add-btn');
  if(addBtn)addBtn.style.display='none';
  const wrap=document.createElement('div');
  wrap.className='cinp-wrap';
  wrap.innerHTML=`<input class="cinp" type="number" step="0.01" min="0" placeholder="0.00"><button class="cinp-ok" onclick="confirmAdd('${k}',${budget})">OK</button><button class="cinp-cancel" onclick="cancelAdd('${k}')">✕</button>`;
  el.insertBefore(wrap,el.lastChild);
  const inp=wrap.querySelector('.cinp');
  inp.focus();
  inp.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();confirmAdd(k,budget);}if(e.key==='Escape')cancelAdd(k);});
}
function cancelAdd(k){
  const el=document.getElementById('entries-'+k);
  if(!el)return;
  const w=el.querySelector('.cinp-wrap');if(w)w.remove();
  const ab=el.querySelector('.add-btn');if(ab)ab.style.display='';
}
function confirmAdd(k,budget){
  const el=document.getElementById('entries-'+k);
  if(!el)return;
  const inp=el.querySelector('.cinp');
  const v=parseFloat(inp?inp.value:'');
  if(!isNaN(v)&&v>0){if(!cvals[k])cvals[k]=[];cvals[k].push({v});sv('cp26c',cvals);}
  cancelAdd(k);
  renderEntries(k,budget);
  recalc();
}
function delEntry(k,ei,budget){
  if(!cvals[k])return;
  cvals[k].splice(ei,1);
  if(!cvals[k].length)delete cvals[k];
  sv('cp26c',cvals);
  renderEntries(k,budget);
  recalc();
}

function recalc(){
  let b=0,a=0,has=false;
  COSTS.forEach((cat,ci)=>{
    const catB=cat.items.reduce((x,i)=>x+i.b,0);
    let catA=0,catH=false;
    cat.items.forEach((item,ii)=>{
      b+=item.b;const k=ci+'-'+ii;
      const t=rowTotal(k);
      if(t!==null){a+=t;catA+=t;has=true;catH=true;}
    });
    const pct=catH?Math.min(Math.round(catA/catB*100),100):0;
    const pf=document.getElementById('cpf-'+ci);if(pf)pf.style.width=pct+'%';
    const cs=document.getElementById('csub-'+ci);
    if(cs)cs.textContent='Budžets: EUR '+catB.toFixed(0)+(catH?' · Iztērēts: EUR '+catA.toFixed(2):'');
  });
  document.getElementById('kb').textContent='EUR '+b.toFixed(0);
  const ae=document.getElementById('ka'),de=document.getElementById('kd'),sb=document.getElementById('spent-bar-fill');
  const displayA=summaryOverride!==null?summaryOverride:a;
  const displayHas=summaryOverride!==null?true:has;
  if(displayHas){
    ae.textContent='EUR '+displayA.toFixed(0);
    ae.style.color=summaryOverride!==null?'var(--amber)':'var(--green)';
    const d=displayA-b;
    de.textContent=(d>=0?'+':'')+'EUR '+d.toFixed(0);
    de.style.color=d>0?'#ef4444':'var(--green)';
    if(sb)sb.style.width=Math.min(Math.round(displayA/b*100),100)+'%';
  } else {
    ae.textContent='—';ae.style.color='var(--muted)';
    de.textContent='—';de.style.color='var(--muted)';
    if(sb)sb.style.width='0%';
  }
  const autoNote=document.getElementById('ka-auto');
  if(autoNote)autoNote.style.display=summaryOverride!==null&&has?'block':'none';
  if(autoNote&&summaryOverride!==null&&has)autoNote.textContent='auto: EUR '+a.toFixed(0);
}

function startSummaryEdit(){
  const ae=document.getElementById('ka'),btn=document.getElementById('ka-edit-btn');
  let wrap=document.getElementById('ka-edit-wrap');
  if(wrap){wrap.style.display='flex';ae.style.display='none';btn.style.display='none';wrap.querySelector('.cinp').focus();return;}
  wrap=document.createElement('div');wrap.id='ka-edit-wrap';
  wrap.className='summary-edit-wrap';
  wrap.innerHTML=`<input class="cinp" style="width:90px;" type="number" step="1" min="0" placeholder="EUR" id="ka-inp"><button class="cinp-ok" onclick="confirmSummaryEdit()">OK</button><button class="cinp-cancel" onclick="clearSummaryEdit()">Auto</button>`;
  ae.after(wrap);ae.style.display='none';btn.style.display='none';
  document.getElementById('ka-inp').focus();
  document.getElementById('ka-inp').addEventListener('keydown',e=>{if(e.key==='Enter')confirmSummaryEdit();if(e.key==='Escape')clearSummaryEdit();});
}
function confirmSummaryEdit(){
  const v=parseFloat(document.getElementById('ka-inp')?.value);
  if(!isNaN(v)&&v>=0){summaryOverride=v;sv('cp26so',summaryOverride);}
  hideSummaryWrap();recalc();
}
function clearSummaryEdit(){summaryOverride=null;sv('cp26so',null);hideSummaryWrap();recalc();}
function hideSummaryWrap(){
  const ae=document.getElementById('ka'),btn=document.getElementById('ka-edit-btn'),wrap=document.getElementById('ka-edit-wrap');
  if(ae)ae.style.display='';if(btn)btn.style.display='';if(wrap)wrap.remove();
}

// ── Map tab switching ──
function switchMapTab(tab,btn){
  document.querySelectorAll('.map-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.map-panel').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('panel-'+tab).classList.add('active');
  if(tab==='online'){buildStopGroups();setTimeout(buildRealMap,120);}
  if(tab==='offline')setTimeout(buildOfflineMap,60);
  if(tab==='timeline')buildTlStrip();
}

// ── Stop groups ──
const tC={red:'#f472b6',gold:'#a78bfa',green:'#4ade99',blue:'#60a5fa'};
const dayKeys=['D1','D2','D3','D4','D5','D6','D7–8','D9'];
const dayColors=['#4ade99','#34d399','#60a5fa','#a78bfa','#f472b6','#fb923c','#34d399','#4ade99'];

function buildStopGroups(){
  const g=document.getElementById('stops-g');
  if(g.children.length)return;
  const groups={};
  STOPS.forEach(s=>{
    const key=s.day.split(' ')[0].replace('–8','–8');
    if(!groups[key])groups[key]=[];
    groups[key].push(s);
  });
  g.innerHTML=Object.keys(groups).map((day,idx)=>{
    const dc=dayColors[dayKeys.indexOf(day)]||'#4ade99';
    const items=groups[day].map(s=>{
      const safe=s.name.replace(/'/g,"&#39;");
      return `<button type="button" class="spc" onclick="focusStop('${safe}')">
        <div class="spd"><span style="width:6px;height:6px;border-radius:50%;background:${tC[s.type]};display:inline-block;flex-shrink:0;"></span>${s.day}</div>
        <div class="spn">${s.name}</div>
        <div class="spnt">${s.note}</div>
      </button>`;
    }).join('');
    return `<div class="stop-group${idx===0?' open':''}">
      <div class="stop-group-head" onclick="this.parentElement.classList.toggle('open')" style="border-left:3px solid ${dc};">
        <strong>${day}</strong><span>${groups[day].length} pieturas</span>
        <svg style="color:var(--muted);transition:transform 0.2s;margin-left:auto;" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </div>
      <div class="stop-group-body">${items}</div>
    </div>`;
  }).join('');
}

// ── Leaflet online map ──
let realMap=null,realMarkers=[],realBounds=null;
const realStops=[
  {name:"Valmiera",lat:57.5418,lng:25.4266,type:"green",day:"D1",address:"Valmiera, Latvija",info:"Starta punkts. 05:30.",cost:"EUR 0"},
