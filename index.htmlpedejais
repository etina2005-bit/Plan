  {name:"Brno",lat:49.197,lng:16.608,type:"green",day:"D2",address:"Jakubská 9",info:"Pusdienas.",cost:"~EUR 15"},
  {name:"AT robeža",lat:48.74,lng:16.64,type:"blue",day:"D2",address:"A2",info:"Vinjete EUR 10.",cost:"EUR 10"},
  {name:"Steiner Residences",lat:48.0856,lng:16.2977,type:"red",day:"D2",address:"Duursmagasse 1, Mödling",info:"Kods 659513351 PIN 077300.",cost:"EUR 297.99"},
  {name:"Mūzikas Universitāte",lat:48.1905,lng:16.3117,type:"gold",day:"D3",address:"Penzingerstrasse 7",info:"MĒĢINĀJUMS.",cost:"~EUR 8"},
  {name:"Musikverein D4",lat:48.2006,lng:16.3726,type:"gold",day:"D4",address:"Musikvereinsplatz 1",info:"2. Kārta.",cost:"~EUR 8"},
  {name:"Musikverein D5",lat:48.2008,lng:16.373,type:"gold",day:"D5",address:"Musikvereinsplatz 1",info:"FINĀLS.",cost:"~EUR 8"},
  {name:"Prāga",lat:50.0865,lng:14.4114,type:"green",day:"D6",address:"Karlův most",info:"1.5h pietura.",cost:"~EUR 21"},
  {name:"Drēzdene",lat:51.0519,lng:13.7414,type:"green",day:"D6",address:"Frauenkirche",info:"45 min.",cost:"~EUR 10"},
  {name:"Berlīne",lat:52.5186,lng:13.397,type:"red",day:"D6",address:"Mitte, blakus Staatsoper",info:"Dzīvoklis.",cost:"~EUR 90"},
  {name:"Staatsoper",lat:52.5171,lng:13.3949,type:"gold",day:"D7–8",address:"Unter den Linden 7",info:"Tava nākotne.",cost:"EUR 0"},
  {name:"Elbloga",lat:54.156,lng:19.404,type:"blue",day:"D9",address:"S7/E77",info:"Brokastis.",cost:"~EUR 8"},
  {name:"VALMIERA",lat:57.5418,lng:25.4266,type:"red",day:"D9",address:"Valmiera",info:"MĀJAS!",cost:"0"},
];
const realColors={red:"#f472b6",gold:"#a78bfa",green:"#4ade99",blue:"#60a5fa"};

function pinIcon(color){
  return L.divIcon({
    className:"",
    html:`<div style="width:22px;height:22px;border-radius:8px;background:${color};border:2px solid rgba(255,255,255,0.8);box-shadow:0 3px 10px rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;"></div>`,
    iconSize:[22,22],iconAnchor:[11,11],popupAnchor:[0,-14]
  });
}
function popupHtml(s){
  const di=dayKeys.indexOf(s.day);const dc=dayColors[Math.max(0,di)];
  return `<div class="popup-day" style="color:${dc}">${s.day}</div><div class="popup-title">${s.name}</div><div class="popup-key">Adrese</div><div class="popup-val">${s.address}</div><div class="popup-key">Info</div><div class="popup-val">${s.info}</div><div class="popup-key">Izmaksas</div><div class="popup-val">${s.cost}</div>`;
}
function buildRealMap(){
  if(realMap||!document.getElementById("route-real-map")||typeof L==="undefined")return;
  realMap=L.map("route-real-map",{zoomControl:true,scrollWheelZoom:true,doubleClickZoom:true,touchZoom:true,dragging:true});
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',{attribution:'© CARTO',maxZoom:19,subdomains:'abcd'}).addTo(realMap);
  let prev=null;
  realStops.forEach(s=>{
    const di=dayKeys.indexOf(s.day);const dc=dayColors[Math.max(0,di)];
    if(prev)L.polyline([[prev.lat,prev.lng],[s.lat,s.lng]],{color:dc,weight:4.5,opacity:0.92,lineCap:'round',lineJoin:'round'}).addTo(realMap);
    const m=L.marker([s.lat,s.lng],{icon:pinIcon(realColors[s.type])}).addTo(realMap).bindPopup(popupHtml(s));
    m.stopName=s.name;realMarkers.push(m);prev=s;
  });
  const ll=realStops.map(s=>[s.lat,s.lng]);
  realBounds=L.latLngBounds(ll).pad(0.1);
  realMap.fitBounds(realBounds);
  setTimeout(()=>{realMap.invalidateSize();realMap.fitBounds(realBounds);},250);
}
function realMapFit(){buildRealMap();if(realMap&&realBounds)realMap.fitBounds(realBounds);}
function realMapZoomIn(){buildRealMap();if(realMap)realMap.zoomIn();}
function realMapZoomOut(){buildRealMap();if(realMap)realMap.zoomOut();}
let isFs=false;
function toggleFullscreen(){
  const w=document.getElementById('real-map-wrap');
  const ic=document.getElementById('fs-icon');
  isFs=!isFs;w.classList.toggle('fullscreen',isFs);
  if(isFs){ic.innerHTML='<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>';document.body.style.overflow='hidden';}
  else{ic.innerHTML='<path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"/>';document.body.style.overflow='';}
  setTimeout(()=>{if(realMap)realMap.invalidateSize();},300);
}
function focusStop(name){
  const t=realStops.find(s=>s.name===name||s.name.toLowerCase().includes(name.toLowerCase()));
  if(!t)return;
  showPage('p3',document.querySelector('.bn:nth-child(4)'));
  switchMapTab('online',document.querySelector('.map-tab:nth-child(2)'));
  setTimeout(()=>{
    if(realMap){realMap.invalidateSize();realMap.setView([t.lat,t.lng],12,{animate:true});
    const m=realMarkers.find(mk=>mk.stopName===t.name);if(m)m.openPopup();}
  },200);
}

// ── Offline Canvas Map ──
const MAP_BOUNDS={minLat:47.5,maxLat:58.5,minLng:12.2,maxLng:27.0};
let offlineScale=1,offlinePanX=0,offlinePanY=0,offlineDrag=false,offlineDragStart={x:0,y:0,px:0,py:0},offlineBuilt=false,DPR=1,offlinePopupEl=null;

function mercY(lat){const r=lat*Math.PI/180;return Math.log(Math.tan(Math.PI/4+r/2));}
const _minY=mercY(MAP_BOUNDS.minLat),_maxY=mercY(MAP_BOUNDS.maxLat);
function geo2c(lat,lng,bw,bh,ox,oy){
  const xf=(lng-MAP_BOUNDS.minLng)/(MAP_BOUNDS.maxLng-MAP_BOUNDS.minLng);
  const yf=1-(mercY(lat)-_minY)/(_maxY-_minY);
  return{x:ox+xf*bw,y:oy+yf*bh};
}

const COUNTRY_OUTLINES=[
  [[21.06,57.19],[21.75,56.33],[23.35,56.33],[24.36,57.0],[25.2,57.91],[26.59,57.84],[27.99,57.53],[27.70,56.80],[26.90,56.40],[25.90,56.20],[24.30,56.90],[22.80,56.97],[21.75,56.80],[21.06,57.19]],
  [[21.06,56.0],[21.75,55.77],[22.73,54.33],[24.36,53.90],[25.70,54.15],[26.59,55.67],[25.53,56.13],[24.36,57.0],[23.35,56.33],[21.75,56.33],[21.06,57.19],[21.06,56.0]],
  [[23.39,59.61],[24.60,59.47],[27.98,59.47],[28.0,57.52],[26.59,57.84],[25.2,57.91],[24.36,57.0],[23.39,59.61]],
  [[14.12,53.87],[15.02,51.11],[17.60,50.29],[18.85,49.49],[22.56,49.07],[23.93,50.41],[24.10,52.01],[23.18,52.30],[23.48,53.93],[22.73,54.33],[21.75,55.77],[21.06,56.0],[19.86,54.43],[18.33,54.84],[14.12,53.87]],
  [[12.33,50.32],[13.03,47.45],[15.02,48.98],[18.85,49.49],[17.60,50.29],[15.02,51.11],[12.33,50.32]],
  [[17.17,48.02],[18.85,49.49],[22.56,49.07],[22.09,48.38],[20.47,48.26],[18.78,47.88],[17.17,48.02]],
  [[13.03,47.45],[12.54,47.67],[10.45,47.56],[9.55,47.53],[9.53,48.02],[10.89,48.46],[12.04,47.67],[12.87,48.29],[13.84,48.77],[15.02,48.98],[15.02,47.45],[13.03,47.45]],
  [[6.08,51.24],[6.17,50.12],[6.69,49.44],[8.01,48.00],[7.59,47.59],[9.55,47.53],[10.45,47.56],[12.54,47.67],[13.03,47.45],[15.02,47.45],[15.02,48.98],[15.02,51.11],[14.12,53.87],[13.82,54.50],[12.09,54.15],[9.92,54.85],[8.57,54.94],[7.22,55.06],[6.08,51.24]],
];
const CITY_LABELS=[[24.10,56.95,'Rīga'],[23.90,54.89,'Kaunas'],[21.01,52.23,'Varšava'],[16.37,48.21,'Vīne'],[16.61,49.20,'Brno'],[14.42,50.09,'Prāga'],[13.74,51.05,'Drēzdene'],[13.40,52.52,'Berlīne'],[25.29,57.41,'Valmiera']];

function getCDims(){const c=document.getElementById('offline-map-canvas');if(!c)return{w:0,h:0};const w=c.parentElement.clientWidth||320;return{w,h:Math.min(Math.round(w*0.88),520)};}

function buildOfflineMap(){
  const c=document.getElementById('offline-map-canvas');if(!c)return;
  DPR=window.devicePixelRatio||1;
  const{w,h}=getCDims();
  c.style.width=w+'px';c.style.height=h+'px';
  c.width=w*DPR;c.height=h*DPR;
  const ctx=c.getContext('2d');ctx.scale(DPR,DPR);
  buildDayLegend();drawOfflineMap();
  if(offlineBuilt)return;offlineBuilt=true;
  c.onmousedown=e=>{offlineDrag=true;offlineDragStart={x:e.clientX,y:e.clientY,px:offlinePanX,py:offlinePanY};e.preventDefault();};
  window.addEventListener('mousemove',e=>{if(!offlineDrag)return;offlinePanX=offlineDragStart.px+(e.clientX-offlineDragStart.x);offlinePanY=offlineDragStart.py+(e.clientY-offlineDragStart.y);drawOfflineMap();});
  window.addEventListener('mouseup',()=>offlineDrag=false);
  c.ontouchstart=e=>{const t=e.touches[0];offlineDrag=true;offlineDragStart={x:t.clientX,y:t.clientY,px:offlinePanX,py:offlinePanY};};
  c.ontouchmove=e=>{e.preventDefault();if(!offlineDrag)return;const t=e.touches[0];offlinePanX=offlineDragStart.px+(t.clientX-offlineDragStart.x);offlinePanY=offlineDragStart.py+(t.clientY-offlineDragStart.y);drawOfflineMap();};
  c.ontouchend=()=>offlineDrag=false;
  let lastD=null;
  c.addEventListener('touchstart',e=>{if(e.touches.length===2)lastD=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);});
  c.addEventListener('touchmove',e=>{if(e.touches.length===2){const d=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);if(lastD){offlineScale=Math.max(0.4,Math.min(5,offlineScale*(d/lastD)));}lastD=d;drawOfflineMap();}},{passive:false});
  c.addEventListener('touchend',()=>lastD=null);
  c.addEventListener('click',e=>{
    if(offlineDrag)return;
    const rect=c.getBoundingClientRect();const mx=e.clientX-rect.left,my=e.clientY-rect.top;
    const{w,h}=getCDims();const bw=w*offlineScale,bh=h*offlineScale;
    const ox=(w-bw)/2+offlinePanX,oy=(h-bh)/2+offlinePanY;
    let hit=null,bestD=24;
    realStops.forEach(s=>{const p=geo2c(s.lat,s.lng,bw,bh,ox,oy);const d=Math.hypot(mx-p.x,my-p.y);if(d<bestD){bestD=d;hit=s;}});
    if(hit)showOfflinePopup(hit,c);
    else if(offlinePopupEl){offlinePopupEl.remove();offlinePopupEl=null;}
  });
}

function showOfflinePopup(s,c){
  if(offlinePopupEl)offlinePopupEl.remove();
  const di=dayKeys.indexOf(s.day);const dc=dayColors[Math.max(0,di)];
  const div=document.createElement('div');
  div.style.cssText=`position:absolute;z-index:50;left:50%;transform:translateX(-50%);bottom:12px;background:#fffaf1;border:2px solid ${dc};border-radius:14px;padding:0.75rem 1rem;box-shadow:0 8px 28px rgba(80,55,20,0.18);max-width:calc(100% - 2rem);width:260px;font-family:"DM Sans",sans-serif;`;
  div.innerHTML=`<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.28rem;"><span style="font-size:0.56rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:${dc};">${s.day}</span><button onclick="this.closest('div[style]').remove()" style="background:none;border:none;color:#7d927f;cursor:pointer;font-size:1rem;line-height:1;">✕</button></div><div style="font-size:0.88rem;font-weight:700;color:#123629;margin-bottom:0.25rem;">${s.name}</div><div style="font-size:0.7rem;color:#547461;line-height:1.4;">${s.info}</div><div style="font-size:0.66rem;font-weight:600;color:${dc};margin-top:0.2rem;">${s.cost}</div>`;
  c.parentElement.style.position='relative';c.parentElement.appendChild(div);offlinePopupEl=div;
}

function pinR(s){return Math.max(5,7*Math.min(s,2));}
function rRect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);ctx.closePath();}

function drawPin(ctx,x,y,type,scale){
  const color=realColors[type]||'#60a5fa';const r=pinR(scale);
  ctx.save();ctx.shadowColor='rgba(0,0,0,0.5)';ctx.shadowBlur=5*scale;ctx.shadowOffsetY=2*scale;
  if(type==='red'){
    rRect(ctx,x-r,y-r,r*2,r*2,r*0.4);ctx.fillStyle=color;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.7)';ctx.lineWidth=1.5;ctx.stroke();
    ctx.shadowColor='transparent';ctx.fillStyle='rgba(255,255,255,0.9)';ctx.font=`bold ${r}px "DM Sans",sans-serif`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('H',x,y+0.5);
  } else if(type==='gold'){
    ctx.beginPath();for(let i=0;i<5;i++){const oa=i*Math.PI*2/5-Math.PI/2,ia=oa+Math.PI/5;const ox=x+Math.cos(oa)*r,oy=y+Math.sin(oa)*r,ix=x+Math.cos(ia)*r*0.42,iy=y+Math.sin(ia)*r*0.42;if(i===0)ctx.moveTo(ox,oy);else ctx.lineTo(ox,oy);ctx.lineTo(ix,iy);}ctx.closePath();ctx.fillStyle=color;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;ctx.stroke();
  } else if(type==='blue'){
    ctx.beginPath();ctx.moveTo(x,y-r);ctx.lineTo(x+r*0.75,y);ctx.lineTo(x,y+r);ctx.lineTo(x-r*0.75,y);ctx.closePath();ctx.fillStyle=color;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.6)';ctx.lineWidth=1.5;ctx.stroke();
  } else {
    ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);ctx.fillStyle=color;ctx.fill();ctx.strokeStyle='rgba(255,255,255,0.7)';ctx.lineWidth=1.8;ctx.stroke();
    ctx.shadowColor='transparent';ctx.beginPath();ctx.arc(x,y,r*0.35,0,Math.PI*2);ctx.fillStyle='rgba(255,255,255,0.7)';ctx.fill();
  }
  ctx.restore();ctx.textBaseline='alphabetic';
}

function drawOfflineMap(){
  const c=document.getElementById('offline-map-canvas');if(!c)return;
  const ctx=c.getContext('2d');const{w,h}=getCDims();
  ctx.save();ctx.setTransform(DPR,0,0,DPR,0,0);
  const bw=w*offlineScale,bh=h*offlineScale;
  const ox=(w-bw)/2+offlinePanX,oy=(h-bh)/2+offlinePanY;
  // BG
  const bg=ctx.createLinearGradient(0,0,0,h);bg.addColorStop(0,'#0a1a0e');bg.addColorStop(1,'#061008');
  ctx.fillStyle=bg;ctx.fillRect(0,0,w,h);
  // Sea shimmer
  ctx.fillStyle='rgba(31,74,55,0.04)';for(let i=0;i<w;i+=30)for(let j=0;j<h;j+=30){ctx.beginPath();ctx.arc(i,j,1,0,Math.PI*2);ctx.fill();}
  // Countries
  COUNTRY_OUTLINES.forEach(poly=>{
    ctx.beginPath();poly.forEach((pt,i)=>{const p=geo2c(pt[1],pt[0],bw,bh,ox,oy);if(i===0)ctx.moveTo(p.x,p.y);else ctx.lineTo(p.x,p.y);});ctx.closePath();
    ctx.fillStyle='rgba(245,255,248,0.92)';ctx.fill();ctx.strokeStyle='rgba(31,74,55,0.18)';ctx.lineWidth=0.8;ctx.stroke();
  });
  // Route shadow
  let prev2=null;
  realStops.forEach(s=>{const p=geo2c(s.lat,s.lng,bw,bh,ox,oy);if(prev2){ctx.beginPath();ctx.moveTo(prev2.x,prev2.y);ctx.lineTo(p.x,p.y);ctx.strokeStyle='rgba(31,74,55,0.08)';ctx.lineWidth=7*offlineScale;ctx.lineCap='round';ctx.stroke();}prev2={x:p.x,y:p.y};});
  // Route colored
  let prevP=null,prevDay=null;
  realStops.forEach(s=>{
    const p=geo2c(s.lat,s.lng,bw,bh,ox,oy);const di=dayKeys.indexOf(s.day);const dc=dayColors[Math.max(0,di)];
    if(prevP){const pdi=dayKeys.indexOf(prevDay);const pdc=dayColors[Math.max(0,pdi)];
      const g=ctx.createLinearGradient(prevP.x,prevP.y,p.x,p.y);g.addColorStop(0,pdc);g.addColorStop(1,dc);
      ctx.beginPath();ctx.moveTo(prevP.x,prevP.y);ctx.lineTo(p.x,p.y);ctx.strokeStyle=g;ctx.lineWidth=Math.max(2,3.5*offlineScale);ctx.lineCap='round';ctx.stroke();}
    prevP={x:p.x,y:p.y};prevDay=s.day;
  });
  // City labels
  if(offlineScale>=0.65){
    ctx.font=`500 ${9*Math.min(offlineScale,1.5)}px "DM Sans",sans-serif`;ctx.textAlign='center';
    CITY_LABELS.forEach(cl=>{const p=geo2c(cl[1],cl[0],bw,bh,ox,oy);if(p.x<-20||p.x>w+20||p.y<-10||p.y>h+10)return;ctx.fillStyle='rgba(31,74,55,0.5)';ctx.fillText(cl[2],p.x,p.y+3);});
  }
  // Pins
  realStops.forEach(s=>{const p=geo2c(s.lat,s.lng,bw,bh,ox,oy);drawPin(ctx,p.x,p.y,s.type,offlineScale);});
  // Pin labels at zoom
  if(offlineScale>=1.2){
    realStops.forEach(s=>{const p=geo2c(s.lat,s.lng,bw,bh,ox,oy);const r=pinR(offlineScale);const lbl=s.name.split(',')[0].trim().substring(0,14);ctx.font=`600 ${9*offlineScale}px "DM Sans",sans-serif`;ctx.textAlign='center';ctx.strokeStyle='rgba(6,16,8,0.9)';ctx.lineWidth=3;ctx.strokeText(lbl,p.x,p.y+r+12);ctx.fillStyle='#c8d4c4';ctx.fillText(lbl,p.x,p.y+r+12);});
  }
  ctx.restore();
}
function offlineZoom(f){offlineScale=Math.max(0.4,Math.min(5,offlineScale*f));drawOfflineMap();}
function offlineReset(){offlineScale=1;offlinePanX=0;offlinePanY=0;drawOfflineMap();}
function buildDayLegend(){
  const el=document.getElementById('day-legend');if(el.children.length)return;
  dayKeys.forEach((d,i)=>{const ch=document.createElement('div');ch.className='day-chip';ch.style.background=dayColors[i];ch.textContent=d;el.appendChild(ch);});
}
window.addEventListener('resize',()=>{if(document.getElementById('panel-offline').classList.contains('active')){offlineBuilt=false;buildOfflineMap();}});

// ── Timeline strip (map page) ──
function buildTlStrip(){
  const el=document.getElementById('tl-strip');if(el.children.length)return;
  const dayTitles={'D1':'Valmiera→Varšava','D2':'Varšava→Vīne','D3':'Vīne Mēģ.','D4':'2.Kārta','D5':'Fināls','D6':'→Berlīne','D7–8':'Berlīne','D9':'→Valmiera'};
  const groups={};const order=[];
  STOPS.forEach(s=>{const k=s.day.split(' ')[0];if(!groups[k]){groups[k]=[];order.push(k);}groups[k].push(s);});
  el.innerHTML=order.map((day,i)=>{
    const dc=dayColors[i]||'#4ade99';
    const stops=groups[day].map(s=>`<div class="tls-stop" style="--stop-c:${tC[s.type]||'#7a8f74'}"><div><div class="tls-sn">${s.name}</div><div class="tls-si">${s.note}</div></div></div>`).join('');
    return `<div class="tls-day"><div class="tls-head" style="background:${dc}20;border-left:3px solid ${dc};"><span class="tls-dl" style="color:${dc}">${day}</span><span class="tls-dt">${dayTitles[day]||''}</span></div><div class="tls-stops">${stops}</div></div>`;
  }).join('');
}

// ── Init ──
migrateCvals();
updateStats();
// ── Today Dashboard — smart date logic ──
const TRIP_DATES=[
  {date:'2026-05-27',di:0},{date:'2026-05-28',di:1},
  {date:'2026-05-29',di:2},{date:'2026-05-30',di:3},
  {date:'2026-05-31',di:4},{date:'2026-06-01',di:5},
  {date:'2026-06-02',di:6},{date:'2026-06-03',di:6},
  {date:'2026-06-04',di:7},
];
const TRIP_START=new Date('2026-05-27T00:00:00');
const TRIP_END=new Date('2026-06-04T23:59:59');

// Key dates and items for homepage
const IMPORTANT_ITEMS=[
  {date:'2026-05-24',type:'deadline',title:'Mēdlings atcelšana — bezmaksas',detail:'Steiner Residences · termiņš beidzas',color:'var(--amber)'},
  {date:'2026-05-27',type:'drive',title:'Valmiera → Varšava',detail:'Hotel Arkadia Royal · degviela ~EUR 76',color:'var(--text-accent)'},
  {date:'2026-05-28',type:'drive',title:'Varšava → Vīne',detail:'Steiner Residences · CZ+AT vinjetes',color:'var(--text-accent)'},
  {date:'2026-05-29',type:'competition',title:'Mēģinājums — Vīne',detail:'Penzingerstrasse 7 · laiks pēc epasta',color:'var(--pink)'},
  {date:'2026-05-30',type:'competition',title:'2. Kārta — Musikverein',detail:'Steinerner Saal · 10:00–17:00',color:'var(--pink)'},
  {date:'2026-05-31',type:'competition',title:'Fināls — Musikverein',detail:'Glaserner Saal · laiks pēc ziņas',color:'var(--pink)'},
  {date:'2026-06-01',type:'drive',title:'Vīne → Berlīne',detail:'Prāga & Drēzdene pa ceļam · dzīvoklis Mitte',color:'var(--text-accent)'},
  {date:'2026-06-04',type:'drive',title:'Berlīne → Valmiera (solo)',detail:'~1150 km · ~12.5h braukšana',color:'var(--text-accent)'},
];

// All reminders with dates for filtering
const ALL_REMINDERS=[
  {date:'2026-05-24',text:'Mēdlings atcelšana — bezmaksas',label:'24. maijs',urgent:false,color:'var(--amber)'},
  {date:'2026-05-27',text:'CZ vinjete EUR 15 — edalnice.cz',label:'pirms D2',urgent:false,color:'var(--amber)'},
  {date:'2026-05-28',text:'AT vinjete EUR 10 — pirmā OMV/BP',label:'D2',urgent:false,color:'var(--amber)'},
  {date:'2026-05-29',text:'Mēģinājuma laiks — gaidīt epastu',label:'gaida',urgent:false,color:'var(--green)'},
  {date:'2026-06-01',text:'Reihstaga kupols — rezervēt bundestag.de',label:'ātrāk!',urgent:true,color:'var(--pink)'},
];

function localDateString(d){
  d=d||new Date();
  const y=d.getFullYear();
  const m=String(d.getMonth()+1).padStart(2,'0');
  const day=String(d.getDate()).padStart(2,'0');
  return `${y}-${m}-${day}`;
}

function buildTodayDashboard(){
  const now=new Date();
  const todayStr=localDateString(now);
  const eyebrow=document.getElementById('hero-eyebrow');
  const title=document.getElementById('hero-title');
  const sub=document.getElementById('hero-sub');
  const sLabel=document.getElementById('today-section-lbl');
  const nextLabel=document.getElementById('next-label');
  const nextDest=document.getElementById('next-dest');
  const nextSub=document.getElementById('next-sub');
  const nextBadge=document.getElementById('next-badge');

  // Helper: find next upcoming item from IMPORTANT_ITEMS
  function nextItem(afterDate){
    return IMPORTANT_ITEMS.find(i=>i.date>afterDate);
  }

  // Helper: set contextual cards
  function setCards(cards){
    // cards = [{icon,label,val,sub}, ...]  max 3
    ['ctx-c1','ctx-c2','ctx-c3'].forEach((id,i)=>{
      const el=document.getElementById(id);
      if(!el)return;
      if(i<cards.length){
        el.style.display='';
        document.getElementById('ctx-i'+(i+1)).textContent=cards[i].icon;
        document.getElementById('ctx-l'+(i+1)).textContent=cards[i].label;
        if(id==='ctx-c3'){
          document.getElementById('today-budget').textContent=cards[i].val;
        } else {
          document.getElementById('ctx-v'+(i+1)).textContent=cards[i].val;
        }
        document.getElementById('ctx-s'+(i+1)).textContent=cards[i].sub;
      } else {
        el.style.display='none';
      }
    });
  }

  // Helper: show urgent reminders (max 2 upcoming/urgent)
  function showUrgentReminders(todayStr){
    const wrap=document.getElementById('urgent-rem-wrap');
    if(!wrap)return;
    // Show reminders that are on or after today, max 2
    const upcoming=ALL_REMINDERS
      .filter(r=>r.date>=todayStr)
      .sort((a,b)=>a.date.localeCompare(b.date))
      .slice(0,2);
    if(!upcoming.length){wrap.innerHTML='';return;}
    const lbl=`<div class="sec-label" style="margin-top:.1rem;">Atgādinājumi <a onclick="showPage('p4',document.querySelector('.bn:nth-child(5)'))" style="font-size:.55rem;font-weight:600;color:var(--text-accent);text-transform:none;letter-spacing:0;cursor:pointer;margin-left:.3rem;">Visi →</a></div>`;
    const items=upcoming.map(r=>`<div class="rem-item"><div class="rem-dot" style="background:${r.color}"></div><div class="rem-text">${r.text}</div><div class="rem-date${r.urgent?' urgent':''}">${r.label}</div></div>`).join('');
    wrap.innerHTML=lbl+`<div class="rem-list" style="margin-bottom:.75rem;">${items}</div>`;
  }

  if(now<TRIP_START){
    const days=Math.ceil((TRIP_START-now)/86400000);
    if(eyebrow)eyebrow.textContent='Ceļojums 2026';
    if(title)title.textContent='Sākas pēc '+days+(days===1?' dienas':' dienām');
    if(sub)sub.textContent='27. maijs — Valmiera → Varšava';
    if(sLabel)sLabel.textContent='Pirmā diena';
    if(nextLabel)nextLabel.textContent='Sākas';
    if(nextDest)nextDest.textContent='D1 · Valmiera → Varšava';
    if(nextSub)nextSub.textContent='27. maijs · ~EUR 167 · ~650 km';
    if(nextBadge)nextBadge.textContent='27. maijs';
    setCards([
      {icon:'🏨',label:'Viesnīca D1',val:'Hotel Arkadia Royal',sub:'Varšava · apmaksāts'},
      {icon:'⛽',label:'Degviela D1',val:'EUR 76',sub:'~650 km'},
      {icon:'💶',label:'Budžets D1',val:'~EUR 167',sub:'Pirmā diena'},
    ]);
    showUrgentReminders(todayStr);

  } else if(now>TRIP_END){
    if(eyebrow)eyebrow.textContent='Ceļojums 2026';
    if(title)title.textContent='Ceļojums pabeigts';
    if(sub)sub.textContent='Valmiera → Varšava → Vīne → Berlīne → Valmiera';
    if(sLabel)sLabel.textContent='Kopsavilkums';
    if(nextLabel)nextLabel.textContent='Pabeigts';
    if(nextDest)nextDest.textContent='4 200 km · 9 dienas';
    if(nextSub)nextSub.textContent='Maijs–Jūnijs 2026';
    if(nextBadge)nextBadge.textContent='✓';
    setCards([
      {icon:'🗺️',label:'Maršruts',val:'4 200 km',sub:'Valmiera → Berlīne → Valmiera'},
      {icon:'📅',label:'Ilgums',val:'9 dienas',sub:'27. maijs – 4. jūnijs'},
      {icon:'💶',label:'Kopbudžets',val:'~EUR 1 100',sub:'Viss ceļojums'},
    ]);
    document.getElementById('urgent-rem-wrap').innerHTML='';

  } else {
    const todayEntry=TRIP_DATES.find(t=>t.date===todayStr);
    if(todayEntry){
      const day=DAYS[todayEntry.di];
      const todayItem=IMPORTANT_ITEMS.find(i=>i.date===todayStr);
      const dStr=now.toLocaleDateString('lv-LV',{weekday:'short',day:'numeric',month:'long'});
      if(eyebrow)eyebrow.textContent=dStr;
      if(title)title.textContent=day.t;
      if(sub)sub.textContent=day.km+(day.km&&day.tot?' · ':'')+day.tot;
      if(sLabel)sLabel.textContent='Šodien';
      if(nextLabel)nextLabel.textContent=todayItem?todayItem.title:'Šodienas maršruts';
      if(nextDest)nextDest.textContent=day.t;
      if(nextSub)nextSub.textContent=todayItem?todayItem.detail:(day.d+' · '+day.tot);
      if(nextBadge)nextBadge.textContent=day.km||day.n;

      // Contextual cards based on day type
      const type=todayItem?todayItem.type:'drive';
      if(type==='competition'){
        setCards([
          {icon:'🎭',label:'Sacensību vieta',val:'Musikverein',sub:'Vīne · Musikvereinsplatz 1'},
          {icon:'⏰',label:'Laiks',val:'10:00',sub:'Skatīt info lapu'},
          {icon:'💶',label:'Budžets',val:day.tot,sub:day.d},
        ]);
      } else if(type==='drive'){
        setCards([
          {icon:'🏨',label:'Šīs nakts viesnīca',val:todayEntry.di===0?'Hotel Arkadia Royal':todayEntry.di===1?'Steiner Residences':'Berlīne — dzīvoklis',sub:todayEntry.di===0?'Varšava · apmaksāts':todayEntry.di===1?'Mēdlings · apmaksāts':'Mitte'},
          {icon:'⛽',label:'Degviela',val:todayEntry.di===0?'EUR 76':todayEntry.di===1?'EUR 75':todayEntry.di===5?'EUR 86':'EUR 143',sub:day.km},
          {icon:'💶',label:'Budžets',val:day.tot,sub:day.d},
        ]);
      } else {
        setCards([
          {icon:'📍',label:'Šodienas vieta',val:day.km,sub:day.d},
          {icon:'💶',label:'Budžets',val:day.tot,sub:'Dienas budžets'},
          {icon:'🗺️',label:'Maršruts',val:day.n,sub:day.t},
        ]);
      }
      showUrgentReminders(todayStr);

    } else {
      // In trip range, no specific plan for today
      const nxt=nextItem(todayStr);
      const dStr=now.toLocaleDateString('lv-LV',{weekday:'short',day:'numeric',month:'long'});
      if(eyebrow)eyebrow.textContent=dStr;
      if(title)title.textContent='Brīva diena';
      if(sub)sub.textContent='Berlīne · apskate';
      if(sLabel)sLabel.textContent='Nākamais';
      if(nxt){
        if(nextLabel)nextLabel.textContent=nxt.title;
        if(nextDest)nextDest.textContent=nxt.title;
        if(nextSub)nextSub.textContent=nxt.detail;
        if(nextBadge)nextBadge.textContent=nxt.date.slice(5).replace('-','.');
      }
      setCards([
        {icon:'🗺️',label:'Berlīne',val:'Apskate',sub:'Brandenburgas vārti · East Side Gallery'},
        {icon:'📅',label:'Nākamais',val:nxt?nxt.title:'—',sub:nxt?nxt.detail:''},
        {icon:'💶',label:'Dienas budžets',val:'~EUR 45',sub:'Ēdiens un transports'},
      ]);
      showUrgentReminders(todayStr);
    }
  }
}
buildTodayDashboard();

// Trigger offline map when map tab first opened
document.querySelector('.bn:nth-child(4)').addEventListener('click',()=>{setTimeout(buildOfflineMap,100);},true);
</script>
</body>
</html>
