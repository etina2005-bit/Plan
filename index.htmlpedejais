<!DOCTYPE html>
<html lang="lv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#f7ecd9">
<title>Ceļojums 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#f7ecd9;--bg2:#fff6e8;--card:#fffaf1;--card2:#fdf3e3;
  --text-strong:#123629;--text-main:#1f4a37;--text-soft:#547461;--text-muted:#7d927f;
  --text-accent:#1f7a4d;
  /* Legacy aliases */
  --ink:#123629;--ink2:#1f4a37;--ink3:#547461;--muted:#7d927f;
  --surface:rgba(31,74,55,0.06);--surface2:rgba(31,74,55,0.1);--surface3:rgba(31,74,55,0.14);
  --border:rgba(31,74,55,0.10);--border2:rgba(31,74,55,0.16);--border-b:rgba(31,74,55,0.22);
  --green:#1f7a4d;--green2:#2f9b64;--green3:#1a6b47;
  --accent:#eba94f;--accent2:#ffbd69;
  --pink:#c0434f;--amber:#d17c24;--blue:#3a7db5;
  --r:16px;--rsm:11px;--rxs:7px;
  --font:'DM Sans',sans-serif;--serif:'DM Serif Display',serif;
  --nav-h:68px;--safe-b:env(safe-area-inset-bottom,0px);
  --sh:0 8px 28px rgba(80,55,20,0.10);
  --sh2:0 12px 36px rgba(80,55,20,0.13);
  --sh3:0 20px 50px rgba(80,55,20,0.16);
  --shadow:0 8px 28px rgba(80,55,20,0.10);
}
html,body{height:100%;overflow:hidden;}
body{font-family:var(--font);color:var(--text-main);background:linear-gradient(180deg,#f8ead3 0%,#fff8ee 45%,#f7ecd9 100%) fixed;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;overscroll-behavior:none;}
.app-shell{position:fixed;inset:0;display:flex;flex-direction:column;overflow:hidden;}
.page-area{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;scroll-behavior:smooth;padding-bottom:calc(var(--nav-h) + var(--safe-b) + 20px);}
.page{display:none;min-height:100%;padding:0;}
.page.active{display:block;}
.page-enter{animation:pgIn 0.36s cubic-bezier(0.16,1,0.3,1) both;}
@keyframes pgIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

/* ── BOTTOM NAV ── */
.bnav{
  flex-shrink:0;display:flex;align-items:flex-start;justify-content:space-around;
  padding:8px 4px calc(var(--safe-b) + 8px);
  background:rgba(255,250,241,0.95);
  backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
  border-top:1px solid var(--border);
  box-shadow:0 -4px 20px rgba(80,55,20,0.08);z-index:200;
}
.bn{display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;padding:6px 8px;border-radius:12px;transition:transform 0.18s cubic-bezier(0.34,1.56,0.64,1);min-width:52px;-webkit-tap-highlight-color:transparent;position:relative;}
.bn:active{transform:scale(0.88);}
.bn-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:9px;transition:all 0.24s cubic-bezier(0.34,1.56,0.64,1);position:relative;}
.bn.active .bn-icon{
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  box-shadow:0 4px 14px rgba(235,169,79,0.35);
  transform:scale(1.08) translateY(-1px);
}
.bn-label{font-size:0.6rem;font-weight:600;color:var(--text-soft);letter-spacing:0.02em;transition:color 0.18s;white-space:nowrap;}
.bn.active .bn-label{color:var(--green);}
.bn svg{transition:stroke 0.18s,opacity 0.18s;}
.bn:not(.active) svg{stroke:var(--text-soft);opacity:0.85;}
.bn.active svg{stroke:#173322;}
.bn.active::after{content:'';position:absolute;bottom:2px;left:50%;transform:translateX(-50%);width:4px;height:4px;border-radius:50%;background:var(--accent);box-shadow:0 0 6px var(--accent);}

/* ── CARDS ── */
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);}
.card2{background:var(--card2);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);}
.glass{background:var(--card);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);}

/* ── TODAY ── */
.today-hero{position:relative;overflow:hidden;min-height:0;max-height:180px;display:flex;flex-direction:column;justify-content:flex-end;padding:1.1rem 1.1rem 1rem;}
.today-hero-bg{position:absolute;inset:0;background:linear-gradient(155deg,#1a4a2e 0%,#1f5c38 40%,#173322 70%,#2a1f14 100%);z-index:0;}
.today-hero-orb{position:absolute;width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(235,169,79,0.18) 0%,transparent 70%);top:-60px;right:-60px;z-index:0;animation:orbFloat 7s ease-in-out infinite;}
@keyframes orbFloat{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-14px) scale(1.04)}}
.today-hero-content{position:relative;z-index:1;}
.today-hero-eyebrow{font-size:0.58rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent2);margin-bottom:0.3rem;}
.today-hero-title{font-family:var(--serif);font-size:1.55rem;font-weight:400;color:#ffffff;line-height:1.1;margin-bottom:0.2rem;}
.today-hero-sub{font-size:0.76rem;color:rgba(255,255,255,0.82);font-weight:400;}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin:.5rem 1rem .85rem;border-radius:var(--r);overflow:hidden;background:var(--card);border:1px solid var(--border);box-shadow:var(--shadow);}
.stat-cell{padding:.65rem .4rem;text-align:center;border-right:1px solid var(--border);}
.stat-cell:last-child{border-right:none;}
.stat-val{font-family:var(--serif);font-size:1.35rem;font-weight:400;color:var(--text-strong);display:block;line-height:1;margin-bottom:.18rem;}
.stat-val.green{color:var(--green);-webkit-text-fill-color:var(--green);}
.stat-lbl{font-size:.47rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text-muted);}
.sec-label{font-size:.56rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--text-muted);padding:0 1.1rem;margin-bottom:.45rem;display:flex;align-items:center;gap:.45rem;}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border);}
.wrap{padding:0 1rem;}
.next-card{margin:0 1rem .9rem;padding:1.1rem;background:linear-gradient(135deg,#1f5c38 0%,#1a4a2e 100%);border:1px solid rgba(31,74,55,.2);border-radius:var(--r);position:relative;overflow:hidden;box-shadow:var(--sh2);}
.next-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at top right,rgba(235,169,79,.15),transparent 60%);pointer-events:none;}
.next-label{font-size:.58rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent2);margin-bottom:.28rem;}
.next-dest{font-size:1.05rem;font-weight:700;color:#ffffff;margin-bottom:.15rem;}
.next-sub{font-size:.73rem;color:rgba(255,255,255,0.78);}
.next-badge{position:absolute;top:1rem;right:1rem;background:rgba(235,169,79,.25);border:1px solid rgba(235,169,79,.4);border-radius:7px;padding:.22rem .55rem;font-size:.62rem;font-weight:700;color:var(--accent2);}
.info-cards{display:grid;grid-template-columns:1fr 1fr;gap:.55rem;margin:0 1rem 1rem;}
.ic{padding:.95rem;position:relative;}
.ic-label{font-size:.54rem;font-weight:700;letter-spacing:.11em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.24rem;}
.ic-val{font-size:.92rem;font-weight:700;color:var(--text-strong);line-height:1.2;}
.ic-sub{font-size:.66rem;color:var(--text-soft);margin-top:.08rem;}
.ic-icon{position:absolute;top:.82rem;right:.82rem;font-size:1rem;opacity:.55;}
.prog-bar{height:4px;background:rgba(31,74,55,.1);border-radius:100px;overflow:hidden;margin-top:.45rem;}
.prog-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--green),var(--accent));transition:width .9s cubic-bezier(.16,1,.3,1);}
.rem-list{margin:0 1rem 1.5rem;display:flex;flex-direction:column;gap:.45rem;}
.rem-item{display:flex;align-items:center;gap:.72rem;padding:.65rem .9rem;background:var(--card);border:1px solid var(--border);border-radius:var(--rsm);box-shadow:var(--shadow);}
.rem-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.rem-text{flex:1;font-size:.79rem;color:var(--text-main);}
.rem-date{font-size:.6rem;font-weight:700;color:var(--amber);white-space:nowrap;}
.rem-date.ok{color:var(--green);}
.rem-date.urgent{color:var(--pink);}

/* ── ROUTE ── */
.route-header{padding:1rem 1.1rem .75rem;}
.route-title{font-family:var(--serif);font-size:1.4rem;color:var(--text-strong);margin-bottom:.1rem;}
.route-sub{font-size:.72rem;color:var(--text-muted);}
.timeline{padding:0 1rem 1rem;position:relative;}
.tl-day{margin-bottom:.45rem;}
.tl-day-head{display:flex;align-items:center;gap:.7rem;padding:.82rem 1rem;border-radius:var(--r);cursor:pointer;background:var(--card);border:1px solid var(--border);box-shadow:var(--shadow);transition:background .14s;-webkit-tap-highlight-color:transparent;}
.tl-day-head:active{background:var(--card2);}
.tl-day.open .tl-day-head{border-radius:var(--r) var(--r) 0 0;border-bottom-color:transparent;}
.tl-day-badge{font-size:.58rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase;padding:.2rem .5rem;border-radius:6px;color:#fff;flex-shrink:0;}
.tl-day-info{flex:1;min-width:0;}
.tl-day-name{font-size:.88rem;font-weight:600;color:var(--text-strong);margin-bottom:.03rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tl-day-date{font-size:.62rem;color:var(--text-soft);}
.tl-day-right{display:flex;align-items:center;gap:.45rem;flex-shrink:0;}
.tl-count{font-size:.62rem;font-weight:500;color:var(--text-soft);}
.tl-chev{color:var(--text-muted);transition:transform .28s cubic-bezier(.34,1.56,.64,1);}
.tl-day.open .tl-chev{transform:rotate(180deg);}
.tl-stops{display:none;padding-left:1rem;padding-bottom:.5rem;border-left:2px solid var(--border);margin-left:1.7rem;background:rgba(255,255,248,.02);border-radius:0 0 var(--r) var(--r);border:1px solid var(--border);border-top:none;}
.tl-day.open .tl-stops{display:block;animation:pgIn .22s ease;}
.tl-stop{display:flex;align-items:flex-start;gap:.65rem;padding:.58rem .7rem;position:relative;border-radius:var(--rsm);transition:background .12s;-webkit-tap-highlight-color:transparent;}
.tl-stop.clickable{cursor:pointer;}
.tl-stop.clickable:active{background:rgba(255,255,255,.04);}
.tl-stop.done .tl-stop-title{opacity:.28;text-decoration:line-through;}
.tl-stop.info-only{opacity:.48;cursor:default;}
.tl-stop-marker{width:20px;height:20px;border-radius:50%;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;background:#fff;border:1.5px solid var(--border2);box-shadow:var(--shadow);transition:all .22s cubic-bezier(.34,1.56,.64,1);}
.tl-stop.done .tl-stop-marker{background:var(--green);border-color:var(--green);box-shadow:0 0 0 3px rgba(31,122,77,.15);}
.tl-stop.info-only .tl-stop-marker{background:transparent;border-style:dashed;border-color:var(--muted);}
.tl-check-svg{display:none;}
.tl-stop.done .tl-check-svg{display:block;}
.tl-info-dot{width:5px;height:5px;border-radius:50%;background:var(--border2);}
.tl-stop.done .tl-info-dot{display:none;}
.tl-stop-body{flex:1;min-width:0;}
.tl-stop-time{font-size:.57rem;font-weight:600;color:var(--text-muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:.06rem;}
.tl-stop-title{font-size:.84rem;font-weight:600;color:var(--text-strong);line-height:1.3;}
.tl-stop-desc{font-size:.7rem;color:var(--text-soft);margin-top:.08rem;line-height:1.4;}
.tl-stop-right{flex-shrink:0;padding-top:2px;}
.tl-chip{font-size:.53rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:.14rem .4rem;border-radius:5px;white-space:nowrap;}
.chip-free{background:rgba(31,74,55,.08);color:var(--green);border:1px solid var(--border2);}
.chip-paid{background:rgba(192,67,79,.08);color:var(--pink);border:1px solid rgba(192,67,79,.18);}
.tl-cost{font-size:.64rem;color:var(--text-soft);font-weight:500;}
.tl-day-budget{display:flex;justify-content:space-between;align-items:center;padding:.45rem .7rem;margin-top:.15rem;border-top:1px solid var(--border);font-size:.68rem;color:var(--text-soft);}
.tl-day-budget strong{color:var(--green);font-weight:700;}

/* ── COSTS ── */
.costs-hero{padding:1rem 1.1rem .75rem;}
.costs-title{font-family:var(--serif);font-size:1.4rem;color:var(--text-strong);margin-bottom:.1rem;}
.costs-sub{font-size:.72rem;color:var(--text-muted);}
.budget-overview{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin:0 1rem 1rem;border-radius:var(--r);overflow:hidden;border:1px solid var(--border2);box-shadow:var(--sh),inset 0 1px 0 rgba(255,255,255,.05);}
.bov-cell{padding:1rem .7rem;text-align:center;background:var(--card);}
.bov-cell:nth-child(2){background:linear-gradient(135deg,#1f5c38,#1a4a2e);border-left:1px solid var(--border2);border-right:1px solid var(--border2);position:relative;}
.bov-val{font-family:var(--serif);font-size:1.4rem;color:var(--text-strong);display:block;margin-bottom:.1rem;}
.bov-lbl{font-size:.48rem;font-weight:700;letter-spacing:.11em;text-transform:uppercase;color:var(--text-soft);}
.bov-edit{position:absolute;top:.5rem;right:.5rem;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.25);border-radius:6px;color:rgba(255,255,255,.8);font-size:.75rem;padding:.1rem .3rem;cursor:pointer;font-family:var(--font);transition:all .14s;}
.bov-edit:hover{background:rgba(255,255,255,.25);}
.bov-bar{height:3px;border-radius:100px;background:rgba(255,255,255,.2);margin-top:.45rem;overflow:hidden;}
.bov-bar-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,var(--green2),var(--green));transition:width .9s cubic-bezier(.16,1,.3,1);}
.costs-list{padding:0 1rem;display:flex;flex-direction:column;gap:.45rem;margin-bottom:1.5rem;}
.cost-cat{border-radius:var(--r);overflow:hidden;}
.cost-cat-head{display:flex;align-items:center;gap:.6rem;padding:.8rem 1rem;cursor:pointer;background:var(--card);border:1px solid var(--border);border-radius:var(--r);font-family:var(--font);box-shadow:var(--shadow);transition:background .13s;-webkit-tap-highlight-color:transparent;}
.cost-cat.open .cost-cat-head{border-radius:var(--r) var(--r) 0 0;border-bottom-color:transparent;}
.cost-cat-head:active{background:var(--card2);}
.cat-badge{font-size:.56rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:.18rem .48rem;border-radius:5px;background:rgba(31,74,55,.09);color:var(--green);border:1px solid var(--border2);flex-shrink:0;}
.cat-info{flex:1;min-width:0;}
.cat-title{font-size:.85rem;font-weight:600;color:var(--text-strong);}
.cat-sub{font-size:.62rem;color:var(--text-soft);margin-top:.04rem;}
.cat-chev{color:var(--text-muted);transition:transform .26s cubic-bezier(.34,1.56,.64,1);}
.cost-cat.open .cat-chev{transform:rotate(180deg);}
.cost-cat-body{display:none;background:var(--card2);border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r) var(--r);}
.cost-cat.open .cost-cat-body{display:block;}
.cost-row{display:flex;flex-direction:column;gap:.38rem;padding:.72rem 1rem;border-bottom:1px solid var(--border);}
.cost-row:last-child{border-bottom:none;}
.cost-row-top{display:flex;align-items:center;gap:.5rem;}
.cost-row-lbl{flex:1;font-size:.8rem;color:var(--text-strong);min-width:0;}
.cost-row-plan{font-size:.68rem;color:var(--text-muted);white-space:nowrap;flex-shrink:0;}
.cost-entries{display:flex;flex-wrap:wrap;gap:.28rem;align-items:center;}
.entry-pill{display:inline-flex;align-items:center;gap:.18rem;font-size:.64rem;font-weight:600;color:var(--green);background:rgba(31,74,55,.08);border:1px solid var(--border2);border-radius:100px;padding:.14rem .38rem .14rem .48rem;}
.pill-del{background:none;border:none;color:var(--muted);cursor:pointer;padding:0;font-size:.7rem;font-family:var(--font);line-height:1;transition:color .12s;}
.pill-del:hover{color:var(--pink);}
.add-btn{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:6px;background:rgba(31,74,55,.07);border:1.5px dashed var(--border2);color:var(--green);font-size:1rem;font-weight:700;cursor:pointer;font-family:var(--font);line-height:1;transition:all .15s;}
.add-btn:hover{background:rgba(31,74,55,.15);border-style:solid;}
.add-btn:active{transform:scale(.9);}
.cost-row-bottom{display:flex;align-items:center;justify-content:space-between;padding-top:.28rem;border-top:1px solid var(--border);font-size:.72rem;}
.cost-row-total{font-weight:700;color:var(--text-strong);}
.cost-row-diff{font-weight:700;}
.diff-over{color:#c0303b;}
.diff-under{color:var(--green);}
.cinp-wrap{display:flex;align-items:center;gap:.32rem;}
.cinp{font-family:var(--font);font-size:.76rem;color:var(--text-strong);font-weight:500;background:#fff;border:1px solid var(--border2);border-radius:8px;padding:.28rem .5rem;outline:none;transition:border-color .15s,box-shadow .15s;text-align:right;width:80px;-webkit-appearance:none;}
.cinp:focus{border-color:var(--green);box-shadow:0 0 0 3px rgba(31,122,77,.12);}
/* PRIMARY BUTTON */
.cinp-ok{font-family:var(--font);font-size:.62rem;font-weight:700;letter-spacing:.04em;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#173322;border:none;border-radius:7px;padding:.3rem .58rem;cursor:pointer;box-shadow:0 4px 14px rgba(235,169,79,.3);transition:all .15s;}
.cinp-ok:hover{box-shadow:0 6px 18px rgba(235,169,79,.35);transform:translateY(-1px);}
.cinp-ok:active{transform:scale(.95);}
/* SECONDARY BUTTON */
.cinp-cancel{background:#fff;border:1px solid var(--border);border-radius:7px;color:var(--text-soft);font-size:.62rem;padding:.3rem .42rem;cursor:pointer;font-family:var(--font);box-shadow:var(--shadow);transition:all .13s;}
.cinp-cancel:hover{background:var(--card2);}
.cinp-cancel:active{transform:scale(.95);}
.cat-pb{height:2px;background:rgba(31,74,55,.08);overflow:hidden;}
.cat-pb-fill{height:100%;background:linear-gradient(90deg,var(--green),var(--accent));transition:width .7s cubic-bezier(.16,1,.3,1);}
.summary-edit-wrap{display:flex;align-items:center;gap:.32rem;justify-content:center;margin-top:.3rem;}

/* ── MAP ── */
.map-page{padding:0;}
.map-tabs{display:flex;gap:5px;padding:.9rem 1rem .7rem;background:linear-gradient(180deg,rgba(255,255,248,.04) 0%,transparent 100%);}
.map-tab{flex:1;font-family:var(--font);font-size:.74rem;font-weight:600;color:var(--text-soft);background:var(--card);border:1px solid var(--border);border-radius:10px;padding:.48rem .35rem;cursor:pointer;box-shadow:var(--shadow);transition:all .2s cubic-bezier(.34,1.56,.64,1);-webkit-tap-highlight-color:transparent;letter-spacing:.01em;}
.map-tab:active{transform:scale(.95);}
.map-tab.active{background:linear-gradient(135deg,#1f5c38,#1a4a2e);color:#fff;border-color:transparent;box-shadow:var(--sh2);transform:translateY(-1px);}
.map-panel{display:none;}
.map-panel.active{display:block;}
.realMapWrap{border-radius:var(--r);overflow:hidden;margin:0 1rem 1rem;border:1px solid var(--border);box-shadow:var(--sh2);background:#e8ede8;position:relative;}
.realMapTop{display:flex;gap:.5rem;align-items:center;justify-content:space-between;padding:.6rem .85rem;border-bottom:1px solid var(--border);background:var(--card);}
.realMapHelp{font-size:.65rem;color:var(--text-muted);flex:1;}
.rmc{display:flex;gap:.28rem;}
.rmc button{font-family:var(--font);font-size:.7rem;font-weight:700;color:var(--text-main);background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:.33rem .62rem;cursor:pointer;box-shadow:var(--shadow);transition:all .13s;}
.rmc button:hover{background:#fff;color:var(--green);}
.rmc button:active{transform:scale(.93);}
#route-real-map{height:55vh;min-height:340px;width:100%;background:#e8ede8;z-index:1;}
.leaflet-container{font-family:var(--font);background:#e8ede8;}
.leaflet-tile{filter:saturate(0.85) contrast(0.95);}
.leaflet-control-zoom a{width:34px!important;height:34px!important;line-height:34px!important;font-size:18px!important;border-radius:8px!important;margin-bottom:3px;background:rgba(255,250,241,.96)!important;color:var(--text-strong)!important;border:1px solid var(--border)!important;box-shadow:var(--shadow)!important;}
.leaflet-control-zoom{border:none!important;background:transparent!important;}
.leaflet-popup-content-wrapper{background:var(--card)!important;border-radius:14px!important;border:1px solid var(--border)!important;box-shadow:var(--sh2)!important;}
.leaflet-popup-tip{background:var(--card)!important;}
.leaflet-popup-content{margin:.9rem 1rem!important;}
.popup-day{font-size:.55rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;margin-bottom:.18rem;font-family:var(--font);}
.popup-title{font-size:.92rem;font-weight:700;color:var(--text-strong);margin-bottom:.25rem;font-family:var(--font);}
.popup-key{font-size:.53rem;text-transform:uppercase;letter-spacing:.08em;color:var(--text-muted);font-weight:700;margin-top:.35rem;font-family:var(--font);}
.popup-val{font-size:.75rem;color:var(--text-main);line-height:1.4;font-family:var(--font);}
.map-fs{position:absolute;top:.6rem;right:.6rem;z-index:500;width:32px;height:32px;border-radius:8px;background:rgba(255,250,241,.9);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:var(--shadow);color:var(--text-main);-webkit-tap-highlight-color:transparent;transition:all .13s;}
.map-fs:hover{background:rgba(12,21,16,.96);color:var(--text-accent);}
.realMapWrap.fullscreen{position:fixed;inset:0;z-index:1000;border-radius:0;margin:0;border:none;}
.realMapWrap.fullscreen #route-real-map{height:100vh;min-height:unset;}
.stop-groups{padding:0 1rem 1rem;}
.stop-group{margin-bottom:.45rem;}
.stop-group-head{display:flex;align-items:center;gap:.55rem;padding:.7rem 1rem;background:var(--card);border:1px solid var(--border);border-radius:var(--r);cursor:pointer;font-family:var(--font);color:var(--text-main);box-shadow:var(--shadow);transition:background .13s;-webkit-tap-highlight-color:transparent;}
.stop-group-head:active{background:var(--card2);}
.stop-group.open .stop-group-head{border-radius:var(--r) var(--r) 0 0;border-bottom-color:transparent;}
.stop-group-head strong{font-size:.84rem;font-weight:600;flex:1;color:var(--text-strong);}
.stop-group-head span{font-size:.62rem;color:var(--text-muted);}
.stop-group-body{display:none;padding-top:.35rem;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:.35rem;background:var(--card2);border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r) var(--r);padding:.4rem;}
.stop-group.open .stop-group-body{display:grid;}
.spc{background:var(--card);border:1px solid var(--border);border-radius:var(--rsm);padding:.7rem .82rem;cursor:pointer;font-family:var(--font);text-align:left;box-shadow:var(--shadow);transition:all .13s;-webkit-tap-highlight-color:transparent;}
.spc:active{background:var(--card2);transform:scale(.98);}
.spd{font-size:.57rem;font-weight:600;color:var(--ink3);margin-bottom:.18rem;display:flex;align-items:center;gap:.3rem;text-transform:uppercase;letter-spacing:.06em;}
.spn{font-size:.8rem;font-weight:600;color:var(--text-strong);margin-bottom:.08rem;}
.spnt{font-size:.65rem;color:var(--text-muted);line-height:1.35;}
.offline-map-wrap{margin:0 1rem 1rem;position:relative;}
.offline-controls{display:flex;gap:.35rem;justify-content:center;margin-bottom:.55rem;flex-wrap:wrap;}
.offline-controls button{font-family:var(--font);font-size:.7rem;font-weight:700;color:var(--text-main);background:var(--card);border:1px solid var(--border);border-radius:8px;padding:.36rem .78rem;cursor:pointer;box-shadow:var(--shadow);transition:all .13s;}
.offline-controls button:hover{color:var(--green);background:var(--card2);}
.offline-controls button:active{transform:scale(.94);}
#offline-map-canvas{width:100%;border-radius:var(--r);display:block;cursor:grab;touch-action:none;box-shadow:var(--sh2);}
#offline-map-canvas:active{cursor:grabbing;}
.day-legend{display:flex;flex-wrap:wrap;gap:.32rem;margin-bottom:.6rem;padding:0 1rem;}
.day-chip{font-size:.58rem;font-weight:700;letter-spacing:.06em;padding:.18rem .5rem;border-radius:6px;color:#fff;}
.map-legend{display:flex;flex-wrap:wrap;gap:.6rem;align-items:center;padding:.62rem 1rem;margin:0 1rem .75rem;font-size:.67rem;font-weight:500;color:var(--text-main);background:var(--card);border:1px solid var(--border);border-radius:var(--rsm);box-shadow:var(--shadow);}
.ml-dot{width:7px;height:7px;border-radius:50%;display:inline-block;flex-shrink:0;}
.ml-item{display:flex;align-items:center;gap:.3rem;}
.gmap-btn{display:flex;align-items:center;gap:.5rem;justify-content:center;padding:.72rem;margin:0 1rem .85rem;background:rgba(31,74,55,.07);border:1px solid var(--border);border-radius:var(--rsm);font-size:.75rem;font-weight:600;color:var(--green);text-decoration:none;cursor:pointer;box-shadow:var(--shadow);transition:all .13s;font-family:var(--font);}
.gmap-btn:hover{background:rgba(31,74,55,.12);}
.gmap-btn:active{transform:scale(.98);}
.tl-strip{padding:0 1rem 1rem;}
.tls-day{margin-bottom:.4rem;}
.tls-head{display:flex;align-items:center;gap:.55rem;padding:.62rem .85rem;border-radius:9px;margin-bottom:.28rem;}
.tls-dl{font-size:.75rem;font-weight:700;color:#fff;flex-shrink:0;}
.tls-dt{font-size:.67rem;font-weight:500;color:rgba(255,255,255,.75);}
.tls-stops{padding-left:1rem;border-left:2px solid var(--border);margin-left:.85rem;}
.tls-stop{display:flex;gap:.5rem;padding:.36rem .5rem;position:relative;}
.tls-stop::before{content:'';position:absolute;left:-1.18rem;top:.82rem;width:6px;height:6px;border-radius:50%;background:var(--stop-c,var(--muted));border:1.5px solid var(--bg);}
.tls-sn{font-size:.76rem;font-weight:600;color:var(--text-strong);}
.tls-si{font-size:.62rem;color:var(--text-muted);margin-top:.03rem;}

/* ── INFO ── */
.info-page-head{padding:1rem 1.1rem .75rem;}
.info-page-title{font-family:var(--serif);font-size:1.4rem;color:var(--text-strong);margin-bottom:.1rem;}
.info-page-sub{font-size:.72rem;color:var(--text-muted);}
.info-sections{padding:0 1rem 1rem;display:flex;flex-direction:column;gap:.45rem;}
.is{border-radius:var(--r);overflow:hidden;}
.is-head{display:flex;align-items:center;gap:.7rem;padding:.9rem 1rem;cursor:pointer;font-family:var(--font);background:var(--card);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow);transition:background .13s;-webkit-tap-highlight-color:transparent;text-align:left;width:100%;}
.is.open .is-head{border-radius:var(--r) var(--r) 0 0;border-bottom-color:transparent;}
.is-head:active{background:var(--card2);}
.is-icon{width:36px;height:36px;border-radius:10px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1rem;background:rgba(31,74,55,.08);border:1px solid var(--border);}
.is-title-wrap{flex:1;}
.is-title{font-size:.87rem;font-weight:700;color:var(--text-strong);display:block;}
.is-sub{font-size:.62rem;color:var(--text-muted);display:block;margin-top:.04rem;}
.is-chev{color:var(--text-muted);transition:transform .26s cubic-bezier(.34,1.56,.64,1);}
.is.open .is-chev{transform:rotate(180deg);}
.is-body{display:none;background:var(--card2);border:1px solid var(--border);border-top:none;border-radius:0 0 var(--r) var(--r);}
.is.open .is-body{display:block;animation:pgIn .18s ease;}
.is-row{display:flex;align-items:flex-start;gap:.72rem;padding:.78rem 1.05rem;border-bottom:1px solid var(--border);font-family:var(--font);}
.is-row:last-child{border-bottom:none;}
.is-row-icon{width:28px;height:28px;border-radius:7px;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:.8rem;background:rgba(31,74,55,.06);border:1px solid var(--border);}
.is-row-body{flex:1;min-width:0;}
.is-row-label{font-size:.57rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text-muted);margin-bottom:.14rem;}
.is-row-val{font-size:.83rem;font-weight:500;color:var(--text-strong);line-height:1.45;}
.is-row-val a{color:var(--green);text-decoration:none;font-weight:600;}
.is-row-sub{font-size:.67rem;color:var(--text-muted);margin-top:.06rem;line-height:1.4;}
.is-row-sub a{color:var(--green);text-decoration:none;}
.is-row-right{flex-shrink:0;padding-top:2px;}
.is-badge{display:inline-block;font-size:.56rem;font-weight:700;letter-spacing:.05em;padding:.17rem .46rem;border-radius:6px;white-space:nowrap;font-family:var(--font);}
.badge-warn{background:rgba(209,124,36,.1);color:var(--amber);border:1px solid rgba(209,124,36,.2);}
.badge-ok{background:rgba(31,74,55,.09);color:var(--green);border:1px solid var(--border2);}
.badge-urgent{background:rgba(192,67,79,.09);color:var(--pink);border:1px solid rgba(192,67,79,.18);}
.aria-row{display:flex;align-items:center;gap:.8rem;padding:.7rem 1.05rem;border-bottom:1px solid var(--border);}
.aria-row:last-child{border-bottom:none;}
.aria-num{width:24px;height:24px;border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.66rem;font-weight:800;color:#fff;background:var(--green);box-shadow:0 2px 6px rgba(31,122,77,.25);}
.aria-comp{font-size:.62rem;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;}
.aria-name{font-size:.8rem;font-weight:500;color:var(--text-strong);margin-top:.04rem;font-style:italic;}
.aria-warn{margin:.5rem 1.05rem .72rem;padding:.58rem .78rem;background:rgba(192,67,79,.06);border:1px solid rgba(192,67,79,.15);border-radius:8px;font-size:.7rem;color:var(--text-muted);line-height:1.45;}
.emg-row{display:flex;align-items:center;gap:.78rem;padding:.78rem 1.05rem;border-bottom:1px solid var(--border);text-decoration:none;transition:background .12s;font-family:var(--font);}
.emg-row:last-child{border-bottom:none;}
.emg-row:active{background:rgba(255,255,255,.03);}
.emg-dot{width:38px;height:38px;border-radius:10px;flex-shrink:0;background:rgba(192,67,79,.07);border:1px solid rgba(192,67,79,.15);display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:800;color:var(--pink);font-family:var(--font);}
.emg-desc{flex:1;min-width:0;}
.emg-num-text{font-size:.9rem;font-weight:700;color:var(--pink);}
.emg-lbl-text{font-size:.64rem;color:var(--text-muted);margin-top:.04rem;}
.emg-arr{color:rgba(224,96,144,.3);flex-shrink:0;}

/* ── Scrollbar ── */
.page-area::-webkit-scrollbar{width:2px;}
.page-area::-webkit-scrollbar-thumb{background:rgba(31,74,55,.18);border-radius:10px;}

/* ── Responsive ── */
@media(max-width:400px){.stat-val{font-size:1.3rem;}.info-cards{grid-template-columns:1fr;}.budget-overview{grid-template-columns:repeat(3,1fr);}}
@media(min-width:600px){.info-cards{grid-template-columns:repeat(3,1fr);}.stat-row{max-width:500px;margin-left:auto;margin-right:auto;}}
/* ── Route summary card (online map) ── */
.route-summary-card{
  margin:0 1rem .65rem;padding:.75rem 1rem;
  background:linear-gradient(145deg,rgba(62,207,130,.08),rgba(37,166,100,.03));
  border:1px solid rgba(62,207,130,.2);border-radius:var(--r);
  display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;
  box-shadow:var(--sh),inset 0 1px 0 rgba(255,255,255,.06);
  position:relative;overflow:hidden;
}
.route-summary-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at left,rgba(235,169,79,.12),transparent 60%);pointer-events:none;}
.rsc-route{display:flex;align-items:center;gap:.5rem;flex:1;}
.rsc-from,.rsc-to{font-size:.84rem;font-weight:700;color:#fff;}
.rsc-to{color:var(--accent2);}
.rsc-stats{display:flex;align-items:center;gap:.35rem;flex-shrink:0;}
.rsc-stat{font-size:.65rem;font-weight:600;color:rgba(255,255,255,.72);}
.rsc-dot{font-size:.65rem;color:rgba(255,255,255,.4);}
.rsc-gmaps{
  display:flex;align-items:center;gap:.3rem;
  font-size:.62rem;font-weight:600;color:var(--text-accent);
  text-decoration:none;
  background:rgba(62,207,130,.1);border:1px solid rgba(62,207,130,.2);
  border-radius:6px;padding:.22rem .5rem;flex-shrink:0;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.06);
  transition:background .13s;
}
.rsc-gmaps:hover{background:rgba(235,169,79,.3);}

/* ── Section label ── */
.sec-label{font-size:.54rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(--text-soft);padding:0 1.1rem;margin-bottom:.45rem;display:flex;align-items:center;gap:.45rem;}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border);}

/* ── Info card compact — 3 cards max ── */
.ic{padding:.82rem;position:relative;}
.info-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:.4rem;margin:0 1rem .8rem;}
@media(max-width:380px){.info-cards{grid-template-columns:1fr 1fr;}}

/* ── Rem item compact ── */
.rem-list{margin:0 1rem 1rem;display:flex;flex-direction:column;gap:.38rem;}
.rem-item{display:flex;align-items:center;gap:.65rem;padding:.6rem .85rem;background:linear-gradient(145deg,rgba(20,80,45,0.2),rgba(10,40,25,0.25));border:1px solid var(--border);border-radius:var(--rsm);box-shadow:var(--sh);}

/* ── Timeline compact ── */
.timeline{padding:0 .9rem .9rem;}
.tl-day{margin-bottom:.38rem;}
.tl-day-head{padding:.78rem .9rem;}
.tl-stops{padding-left:.85rem;}
.tl-stop{padding:.5rem .55rem;}

/* ── Costs compact ── */
.costs-list{padding:0 .9rem;gap:.38rem;margin-bottom:1.2rem;}
.budget-overview{margin:0 .9rem .85rem;}
.bov-cell{padding:.95rem .65rem;}

/* ── Map tabs compact ── */
.map-tabs{padding:.75rem .9rem .6rem;}

/* ── Info sections ── */
.info-sections{padding:0 .9rem .9rem;gap:.38rem;}
.is-head{padding:.82rem .95rem;}
.is-row{padding:.68rem .95rem;}

/* ── Body font on dark - force antialiasing ── */
body{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;}

</style>
</head>
<body>

<div class="app-shell">

  <!-- Scrollable page area -->
  <div class="page-area" id="pageArea">

    <!-- PAGE 0: TODAY -->
    <div class="page active" id="p0">
      <div class="today-hero">
        <div class="today-hero-bg"></div>
        <div class="today-hero-orb"></div>
        <div class="today-hero-content">
          <div class="today-hero-eyebrow" id="hero-eyebrow">Ceļojums 2026</div>
          <div class="today-hero-title" id="hero-title">9 Dienas · 4 200 km</div>
          <div class="today-hero-sub" id="hero-sub">Valmiera → Varšava → Vīne → Berlīne</div>
        </div>
      </div>

      <!-- MAIN CARD: current/next event -->
      <div class="sec-label" id="today-section-lbl" style="margin-top:.65rem;">Šodien</div>
      <div class="next-card" id="today-next">
        <div class="next-label" id="next-label">Nākamais</div>
        <div class="next-dest" id="next-dest">D1 · Valmiera → Varšava</div>
        <div class="next-sub" id="next-sub">27. maijs · ~EUR 167 · ~650 km</div>
        <div class="next-badge" id="next-badge">27. maijs</div>
      </div>

      <!-- CONTEXTUAL INFO CARDS (updated by JS) -->
      <div class="info-cards" id="ctx-cards">
        <div class="glass ic" id="ctx-c1">
          <div class="ic-icon" id="ctx-i1">🏨</div>
          <div class="ic-label" id="ctx-l1">Šīs nakts viesnīca</div>
          <div class="ic-val" id="ctx-v1">Hotel Arkadia</div>
          <div class="ic-sub" id="ctx-s1">Varšava · apmaksāts</div>
        </div>
        <div class="glass ic" id="ctx-c2">
          <div class="ic-icon" id="ctx-i2">⛽</div>
          <div class="ic-label" id="ctx-l2">Degviela</div>
          <div class="ic-val" id="ctx-v2">EUR 76</div>
          <div class="ic-sub" id="ctx-s2">~650 km</div>
        </div>
        <div class="glass ic" id="ctx-c3">
          <div class="ic-icon" id="ctx-i3">💶</div>
          <div class="ic-label" id="ctx-l3">Budžets šodien</div>
          <div class="ic-val" id="today-budget">~EUR 167</div>
          <div class="ic-sub" id="ctx-s3">D1 dienas budžets</div>
        </div>
      </div>

      <!-- URGENT REMINDER (max 1-2) -->
      <div id="urgent-rem-wrap"></div>

      <!-- TRIP PROGRESS — compact, lower -->
      <div class="sec-label">Progress</div>
      <div class="wrap" style="margin-bottom:1rem;">
        <div class="glass" style="padding:.8rem 1rem;">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem;">
            <span style="font-size:.75rem;color:var(--text-main);">Pieturas pabeigtas</span>
            <span style="font-size:.75rem;font-weight:700;color:var(--text-accent);" id="prog-text">0 / 0</span>
          </div>
          <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
        </div>
      </div>

      <!-- SMALL TRIP STATS — moved to bottom -->
      <div class="stat-row" style="margin-bottom:1.2rem;">
        <div class="stat-cell">
          <span class="stat-val">~4 200</span>
          <span class="stat-lbl">km kopā</span>
        </div>
        <div class="stat-cell">
          <span class="stat-val">9</span>
          <span class="stat-lbl">Dienas</span>
        </div>
        <div class="stat-cell">
          <span class="stat-val green" id="t-pct">0%</span>
          <span class="stat-lbl">Gatavs</span>
        </div>
        <div class="stat-cell">
          <span class="stat-val" id="t-left">–</span>
          <span class="stat-lbl">Atlicis</span>
        </div>
      </div>
    </div>

    <!-- PAGE 1: ROUTE -->
    <div class="page" id="p1">
      <div class="route-header">
        <div class="route-title">Maršruts</div>
        <div class="route-sub" id="route-sub">0 / 0 pieturas pabeigtas</div>
      </div>
      <div class="timeline" id="tl"></div>
    </div>

    <!-- PAGE 2: COSTS -->
    <div class="page" id="p2">
      <div class="costs-hero">
        <div class="costs-title">Izmaksas</div>
        <div class="costs-sub">Budžets un iztēriņš</div>
      </div>
      <div class="budget-overview">
        <div class="bov-cell">
          <span class="bov-val" id="kb">—</span>
          <span class="bov-lbl">Plānotais</span>
        </div>
        <div class="bov-cell" style="position:relative;">
          <span class="bov-val" id="ka" style="color:#fff;">—</span>
          <span class="bov-lbl" style="color:rgba(255,255,255,0.7);">Iztērēts</span>
          <span id="ka-auto" style="display:none;font-size:0.52rem;color:var(--muted);margin-top:0.12rem;display:block;"></span>
          <button class="bov-edit" id="ka-edit-btn" onclick="startSummaryEdit()" title="Rediģēt">✎</button>
          <div class="bov-bar"><div class="bov-bar-fill" id="spent-bar-fill" style="width:0%"></div></div>
        </div>
        <div class="bov-cell">
          <span class="bov-val" id="kd">—</span>
          <span class="bov-lbl">Starpība</span>
        </div>
      </div>
      <div class="costs-list" id="cw"></div>
    </div>

    <!-- PAGE 3: MAP -->
    <div class="page map-page" id="p3">
      <div class="map-tabs">
        <button class="map-tab active" onclick="switchMapTab('online',this)">Tiešsaiste</button>
        <button class="map-tab" onclick="switchMapTab('offline',this)">Bezsaiste</button>
        <button class="map-tab" onclick="switchMapTab('timeline',this)">Grafiks</button>
      </div>

      <div class="map-panel" id="panel-offline">
        <div class="day-legend" id="day-legend"></div>
        <div class="offline-controls">
          <button onclick="offlineZoom(1.3)">＋</button>
          <button onclick="offlineZoom(0.77)">－</button>
          <button onclick="offlineReset()">Viss maršruts</button>
        </div>
        <div class="offline-map-wrap">
          <canvas id="offline-map-canvas"></canvas>
        </div>
        <div class="map-legend">
          <div class="ml-item"><div class="ml-dot" style="background:#f472b6"></div>Naktsmītne</div>
          <div class="ml-item"><div class="ml-dot" style="background:#a78bfa"></div>Sacensības</div>
          <div class="ml-item"><div class="ml-dot" style="background:#4ade99"></div>Apskate</div>
          <div class="ml-item"><div class="ml-dot" style="background:#60a5fa"></div>Degviela</div>
        </div>
      </div>

      <div class="map-panel active" id="panel-online">
        <div class="route-summary-card">
          <div class="rsc-route">
            <span class="rsc-from">Valmiera</span>
            <svg width="16" height="10" fill="none" viewBox="0 0 24 12" style="flex-shrink:0;opacity:0.6"><path d="M1 6h20M15 1l6 5-6 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span class="rsc-to">Berlīne · Vīne</span>
          </div>
          <div class="rsc-stats">
