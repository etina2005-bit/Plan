  {t:"Ēdiens — Atceļš",badge:"D9",items:[
    {l:"3 pieturas (Elbloga, Kaunas, Rīga)",b:20},
  ]},
  {t:"Apskates vietas (izvēle)",badge:"D7–D8",items:[
    {l:"Alte Nationalgalerie",b:12},
    {l:"Berlīnes Dāms",b:9},
  ]},
];

const STOPS=[
  {day:"D1",name:"Valmiera",note:"Starta punkts, 05:30",type:"green"},
  {day:"D1",name:"Rīgas apvedceļš",note:"Degviela, Circle K",type:"blue"},
  {day:"D1",name:"Panevēžis, Lietuva",note:"Pietura, E67",type:"blue"},
  {day:"D1",name:"Kaunas Vecpilsēta",note:"Pusdienas, Laisvės aleja",type:"green"},
  {day:"D1",name:"Bjalostoka, Polija",note:"Degviela, S8/E67",type:"blue"},
  {day:"D1",name:"Biedronka, Varšava",note:"Iepirkšanās Vīnei",type:"blue"},
  {day:"D1",name:"Hotel Arkadia Royal",note:"ul. Czecha 10, Wawer",type:"red"},
  {day:"D1",name:"Varšavas Vecpilsēta",note:"Zamkowy laukums, Barbikāns",type:"green"},
  {day:"D2",name:"MOP Wozniki, A1",note:"KFC + Circle K",type:"blue"},
  {day:"D2",name:"CZ robeža — Cieszyn",note:"Vinjete EUR 15",type:"blue"},
  {day:"D2",name:"Brno — Soul Bistro",note:"Jakubska 9, pusdienas",type:"green"},
  {day:"D2",name:"AT robeža — A2",note:"Vinjete EUR 10",type:"blue"},
  {day:"D2",name:"Steiner Residences",note:"Duursmagasse 1, Mēdlings",type:"red"},
  {day:"D3",name:"Mūzikas Universitāte Vīne",note:"Penzingerstrasse 7 — MĒĢINĀJUMS",type:"gold"},
  {day:"D3",name:"Naschmarkt",note:"400 stendi, Wienzeile",type:"green"},
  {day:"D3",name:"Šēnbrunnas dārzs",note:"UNESCO, bezmaksas",type:"green"},
  {day:"D4",name:"Musikverein — Steinerner Saal",note:"2. KĀRTA 10:00–17:00",type:"gold"},
  {day:"D4",name:"Café Central",note:"Herrengasse 14",type:"green"},
  {day:"D5",name:"Musikverein — Glaserner Saal",note:"FINĀLS",type:"gold"},
  {day:"D6",name:"Prāga — Kārļa tilts",note:"1.5h pietura, bezmaksas",type:"green"},
  {day:"D6",name:"Drēzdene — Frauenkirche",note:"45 min, Elba",type:"green"},
  {day:"D6",name:"Berlīne — Mitte",note:"Tavs dzīvoklis, blakus Staatsoper",type:"red"},
  {day:"D7–8",name:"Brandenburgas vārti",note:"Pariser Platz",type:"green"},
  {day:"D7–8",name:"Holokasta memoriāls",note:"Cora-Berliner-Str.",type:"green"},
  {day:"D7–8",name:"Reihstaga kupols",note:"Rezervēt bundestag.de!",type:"green"},
  {day:"D7–8",name:"East Side Gallery",note:"1.3 km Berlīnes mūra",type:"green"},
  {day:"D7–8",name:"Staatsoper Unter den Linden",note:"Tava nākotne — sezona augustā",type:"gold"},
  {day:"D9",name:"Solo brauciens 05:00",note:"A10/A11/E28",type:"blue"},
  {day:"D9",name:"Elbloga — brokastis",note:"S7/E77, ~EUR 8",type:"blue"},
  {day:"D9",name:"Kaunas — degviela",note:"Via Baltica",type:"blue"},
  {day:"D9 ~16:00",name:"VALMIERA",note:"Mājas. 9 dienas. 4200 km.",type:"red"},
];

function ld(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d;}catch{return d;}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch{}}
let done=ld('cp26d',{});
let cvals=ld('cp26c',{});

function showPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nt').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(btn)btn.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
  if(id==='p2')buildCosts();
  if(id==='p3'){buildMap();setTimeout(buildRealMap,120);}
}

function buildProgress(){
  const w=document.getElementById('dw');w.innerHTML='';
  DAYS.forEach((day,di)=>{
    const tot=day.s.length;
    const dn=day.s.filter((_,si)=>done[di+'-'+si]).length;
    const pct=tot?Math.round(dn/tot*100):0;
    const el=document.createElement('div');
    el.className='cb card'+(dn>0?' open':'');
    el.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+day.n+'</span>'+
        '<div class="ci"><div class="ctitle">'+day.t+'</div><div class="csub">'+day.d+'</div></div>'+
        '<div class="cr"><span class="ccnt">'+dn+'/'+tot+'</span>'+
        '<svg class="chev" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></div>'+
      '</div>'+
      '<div class="pb"><div class="pf" style="width:'+pct+'%"></div></div>'+
      '<div class="cbody">'+
        day.s.map(function(seg,si){
          var isDone=done[di+'-'+si];
          return '<div class="seg'+(isDone?' done':'')+'" onclick="toggleSeg('+di+','+si+')">'+
            '<div class="schk"><svg class="csv" width="9" height="7" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
            '<span class="stm">'+seg.ti+'</span>'+
            '<div class="sbdy"><div class="sttl">'+seg.h+'</div>'+(seg.de?'<div class="sdsc">'+seg.de+'</div>':'')+'</div>'+
            '<div class="sr2">'+
              (seg.free?'<span class="chip cf">bezmaksas</span>':'')+
              (seg.paid?'<span class="chip cp">apmaksāts</span>':'')+
              (seg.c&&!seg.free&&!seg.paid?'<span class="scst">'+seg.c+'</span>':'')+
            '</div></div>';
        }).join('')+
        '<div class="bft"><span>Dienas budžets</span><strong>'+day.tot+'</strong></div>'+
      '</div>';
    w.appendChild(el);
  });
  updateStats();
}

function toggleSeg(di,si){
  var k=di+'-'+si;done[k]=!done[k];sv('cp26d',done);buildProgress();
if(location.hash==='#p3'){showPage('p3',document.querySelector("button[onclick*=\"p3\"]"));}
}
function updateStats(){
  var tot=DAYS.reduce(function(a,d){return a+d.s.length;},0);
  var n=Object.values(done).filter(Boolean).length;
  document.getElementById('spct').textContent=tot?Math.round(n/tot*100)+'%':'0%';
  document.getElementById('slft').textContent=tot-n;
}

function buildCosts(){
  var w=document.getElementById('cw');w.innerHTML='';
  COSTS.forEach(function(cat,ci){
    var catB=cat.items.reduce(function(a,i){return a+i.b;},0);
    var catA=0,catH=false;
    cat.items.forEach(function(item,ii){
      var k=ci+'-'+ii;
      if(item.paid){catA+=item.b;catH=true;}
      else if(cvals[k]!==undefined&&cvals[k]!==''){catA+=parseFloat(cvals[k])||0;catH=true;}
    });
    var catPct=catH?Math.min(Math.round(catA/catB*100),100):0;
    var el=document.createElement('div');
    el.className='cb card';
    var rows=cat.items.map(function(item,ii){
      var k=ci+'-'+ii;
      if(item.paid){
        return '<div class="crow">'+
          '<div class="clbl">'+item.l+'</div>'+
          '<span class="chip cp" style="flex-shrink:0;">apmaksāts</span>'+
          '<div class="cfxd">EUR '+item.b.toFixed(2)+'</div>'+
          '<div class="cdif under">✓</div>'+
        '</div>';
      }
      var av=cvals[k]!==undefined?cvals[k]:'';
      var diff=av!==''?parseFloat(av)-item.b:null;
      var dtxt=diff!==null?(diff>=0?'+':'')+diff.toFixed(0):'';
      var dcls=diff!==null?(diff>0.5?'over':'under'):'';
      return '<div class="crow">'+
        '<div class="clbl">'+item.l+'</div>'+
        '<div class="cfxd">EUR '+item.b.toFixed(2)+'</div>'+
        '<input class="cinp" type="number" step="0.01" min="0" placeholder="ievadi" value="'+av+'" oninput="updateCost(\''+k+'\',this.value)">'+
        '<div class="cdif '+dcls+'">'+(dtxt?'EUR '+dtxt:'')+'</div>'+
      '</div>';
    }).join('');
    el.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+cat.badge+'</span>'+
        '<div class="ci"><div class="ctitle">'+cat.t+'</div>'+
        '<div class="csub">Budžets: EUR '+catB.toFixed(0)+(catH?' · Iztērēts: EUR '+catA.toFixed(0):'')+'</div></div>'+
        '<svg class="chev" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>'+
      '</div>'+
      '<div class="pb"><div class="pf" style="width:'+catPct+'%"></div></div>'+
      '<div class="cbody">'+rows+
        '<div class="bft"><span>Kategorijas budžets</span><strong>EUR '+catB.toFixed(0)+'</strong></div>'+
      '</div>';
    w.appendChild(el);
  });
  recalc();
}

function updateCost(k,v){
  cvals[k]=v===''?'':parseFloat(v)||0;sv('cp26c',cvals);
  buildCosts();
}
function recalc(){
  var b=0,a=0,has=false;
  COSTS.forEach(function(cat,ci){cat.items.forEach(function(item,ii){
    b+=item.b;var k=ci+'-'+ii;
    if(item.paid){a+=item.b;has=true;}
    else if(cvals[k]!==undefined&&cvals[k]!==''){a+=parseFloat(cvals[k])||0;has=true;}
  });});
  document.getElementById('kb').textContent='EUR '+b.toFixed(0);
  var ae=document.getElementById('ka'),de=document.getElementById('kd');
  if(has){
    ae.textContent='EUR '+a.toFixed(0);ae.style.color='var(--blue)';
    var d=a-b;
    de.textContent=(d>=0?'+':'')+' EUR '+d.toFixed(0);
    de.style.color=d>0?'var(--orange)':'var(--green)';
  }else{
    ae.textContent='—';ae.style.color='var(--muted)';
    de.textContent='—';de.style.color='var(--muted)';
  }
}

var tC={red:'#c2185b',gold:'#a07ac4',green:'#4ea68a',blue:'#5b9bd6'};


function buildMap(){
  var g=document.getElementById('stops-g');
  if(!g || g.children.length>0)return;
  var groups={};
  STOPS.forEach(function(s){
    var key=s.day.split(' ')[0];
    if(s.day.indexOf('D7')===0)key='D7–8';
    if(s.day.indexOf('D9')===0)key='D9';
    if(!groups[key])groups[key]=[];
    groups[key].push(s);
  });
  g.innerHTML=Object.keys(groups).map(function(day,idx){
    var items=groups[day].map(function(s){
      var safe=s.name.replace(/'/g,"&#39;");
      return '<button type="button" class="spc" onclick="focusStopFromCard(\''+safe+'\')">'+
        '<div class="spd"><span style="width:8px;height:8px;border-radius:50%;background:'+tC[s.type]+';display:inline-block;flex-shrink:0;"></span>'+s.day+'</div>'+
        '<div class="spn">'+s.name+'</div>'+
        '<div class="spnt">'+s.note+'</div>'+
      '</button>';
    }).join('');
    return '<div class="stopGroup '+(idx===0?'open':'')+'">'+
      '<button type="button" class="stopGroupHead" onclick="this.parentElement.classList.toggle(\'open\')">'+
      '<strong>'+day+'</strong><span>'+groups[day].length+' pieturas</span></button>'+
      '<div class="stopGroupBody">'+items+'</div></div>';
  }).join('');
}






var realMap=null;
var realMarkers=[];
var realBounds=null;

var realStops=[
  {name:"Valmiera",lat:57.5418,lng:25.4266,type:"green",day:"D1",address:"Valmiera, Latvija",info:"Starta punkts. Izbraukšana 05:30.",cost:"EUR 0"},
  {name:"Rīgas apvedceļš",lat:56.85,lng:24.06,type:"blue",day:"D1",address:"A5/E67, Rīgas apvedceļš",info:"Degviela. Circle K vai Virši.",cost:"Pēc degvielas daudzuma"},
  {name:"Panevēžis, Lietuva",lat:55.733,lng:24.35,type:"blue",day:"D1",address:"Panevėžys, Lietuva",info:"Īsa pietura uz Via Baltica.",cost:"EUR 0–5"},
  {name:"Kaunas Vecpilsēta",lat:54.8985,lng:23.9036,type:"green",day:"D1",address:"Kaunas Old Town / Laisvės alėja",info:"Pusdienas un īsa pastaiga.",cost:"~EUR 15"},
  {name:"Hotel Arkadia Royal",lat:52.225,lng:21.157,type:"red",day:"D1",address:"ul. Czecha 10, Wawer, Warsaw",info:"Naktsmītne. Bezmaksas stāvvieta, SPA līdz 23:00.",cost:"EUR 89.83, apmaksāts"},
  {name:"MOP Wozniki, A1",lat:50.58,lng:19.05,type:"blue",day:"D2",address:"A1, MOP Woźniki Wschód, Polija",info:"Degviela/KFC pietura.",cost:"~EUR 8"},
  {name:"CZ robeža — Cieszyn",lat:49.75,lng:18.63,type:"blue",day:"D2",address:"Cieszyn/Ostrava robežas zona",info:"Čehijas vinjete.",cost:"EUR 15"},
  {name:"Brno — Soul Bistro",lat:49.197,lng:16.608,type:"green",day:"D2",address:"Jakubská 9, Brno",info:"Pusdienas pa ceļam uz Vīni.",cost:"~EUR 15"},
  {name:"AT robeža — A2",lat:48.74,lng:16.64,type:"blue",day:"D2",address:"Austrijas robeža / A2",info:"Austrijas vinjete.",cost:"EUR 10"},
  {name:"Steiner Residences",lat:48.0856,lng:16.2977,type:"red",day:"D2",address:"Duursmagasse 1, 2340 Mödling",info:"Naktsmītne pie Vīnes. Kods/PIN kontaktu lapā.",cost:"EUR 297.99, apmaksāts"},
  {name:"Mūzikas Universitāte Vīne",lat:48.1905,lng:16.3117,type:"gold",day:"D3",address:"Penzingerstrasse 7, 1140 Wien",info:"Mēģinājums 29. maijā.",cost:"Transports ~EUR 8"},
  {name:"Musikverein — Steinerner Saal",lat:48.2006,lng:16.3726,type:"gold",day:"D4",address:"Musikvereinsplatz 1, 1010 Wien",info:"Hedda Urbani Wettbewerb 2. kārta.",cost:"Transports ~EUR 8"},
  {name:"Musikverein — Glaserner Saal",lat:48.2008,lng:16.373,type:"gold",day:"D5",address:"Musikvereinsplatz 1, 1010 Wien",info:"Fināls.",cost:"Transports ~EUR 8"},
  {name:"Prāga — Kārļa tilts",lat:50.0865,lng:14.4114,type:"green",day:"D6",address:"Karlův most, Praha",info:"1.5h pietura, vecpilsēta.",cost:"~EUR 21"},
  {name:"Drēzdene — Frauenkirche",lat:51.0519,lng:13.7414,type:"green",day:"D6",address:"Frauenkirche, Dresden",info:"45 min pietura pie Elbas.",cost:"~EUR 10"},
  {name:"Berlīne — Mitte",lat:52.5186,lng:13.397,type:"red",day:"D6",address:"Mitte, Berlin, blakus Staatsoper Unter den Linden",info:"Dzīvoklis, Berlīnes apskate, Staatsoper zona.",cost:"Ēdiens ~EUR 90 divām dienām"},
  {name:"Staatsoper Unter den Linden",lat:52.5171,lng:13.3949,type:"gold",day:"D7–8",address:"Unter den Linden 7, 10117 Berlin",info:"Tava nākotnes darba zona.",cost:"EUR 0"},
  {name:"Elbloga — brokastis",lat:54.156,lng:19.404,type:"blue",day:"D9",address:"Elbląg apkārtne, S7/E77",info:"Solo atceļš. Degviela + brokastis.",cost:"~EUR 8"},
  {name:"Kaunas — degviela",lat:54.8985,lng:23.9036,type:"blue",day:"D9",address:"Kaunas, Lietuva",info:"Degviela Via Baltica.",cost:"Pēc degvielas daudzuma"},
  {name:"VALMIERA",lat:57.5418,lng:25.4266,type:"red",day:"D9",address:"Valmiera, Latvija",info:"Ierašanās mājās. 9 dienas, ~4200 km.",cost:"Ceļš pabeigts"}
];

var realColors={red:"#c2185b",gold:"#a07ac4",green:"#4ea68a",blue:"#5b9bd6"};

function pinIcon(color){
  return L.divIcon({
    className:"",
    html:'<div class="mapPin" style="background:'+color+'"></div>',
    iconSize:[30,30],
    iconAnchor:[15,30],
    popupAnchor:[0,-28]
  });
}

function popupHtml(s){
  return '<div class="popupTitle">'+s.name+'</div>'+
    '<div class="popupKey">Adrese</div><div class="popupVal">'+s.address+'</div>'+
    '<div class="popupKey">Info</div><div class="popupVal">'+s.info+'</div>'+
    '<div class="popupKey">Izmaksas</div><div class="popupVal">'+s.cost+'</div>';
}

function buildRealMap(){
  if(realMap || !document.getElementById("route-real-map") || typeof L==="undefined")return;

  realMap=L.map("route-real-map",{
    zoomControl:true,
    scrollWheelZoom:true,
    doubleClickZoom:true,
    touchZoom:true,
    dragging:true,
    tap:true
  });

  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{
    maxZoom:19,
    attribution:"© OpenStreetMap"
  }).addTo(realMap);

  var routeLatLngs=realStops.map(function(s){return [s.lat,s.lng];});

  var routeLine=L.polyline(routeLatLngs,{
    color:"#c2185b",
    weight:5,
    opacity:0.86,
    lineCap:"round",
    lineJoin:"round"
  }).addTo(realMap);

  realStops.forEach(function(s){
    var marker=L.marker([s.lat,s.lng],{icon:pinIcon(realColors[s.type]||realColors.blue)})
      .addTo(realMap)
      .bindPopup(popupHtml(s));
    marker.stopName=s.name;
    realMarkers.push(marker);
  });

  realBounds=L.latLngBounds(routeLatLngs).pad(0.13);
  realMap.fitBounds(realBounds);
  setTimeout(function(){realMap.invalidateSize();realMap.fitBounds(realBounds);},250);
}

function realMapFit(){
  buildRealMap();
  if(realMap && realBounds)realMap.fitBounds(realBounds);
}

function realMapZoomIn(){
  buildRealMap();
  if(realMap)realMap.zoomIn();
}

function realMapZoomOut(){
  buildRealMap();
  if(realMap)realMap.zoomOut();
}

function focusStopFromCard(name){
  buildRealMap();
  var target=realStops.find(function(s){
    return s.name===name || s.name.toLowerCase().indexOf(name.toLowerCase())!==-1 || name.toLowerCase().indexOf(s.name.toLowerCase())!==-1;
  });
  if(!target || !realMap)return;
  showPage('p3',document.querySelector("button[onclick*='p3']"));
  setTimeout(function(){
    realMap.invalidateSize();
    realMap.setView([target.lat,target.lng],13,{animate:true});
    var marker=realMarkers.find(function(m){return m.stopName===target.name;});
    if(marker)marker.openPopup();
    document.getElementById("route-real-map").scrollIntoView({behavior:"smooth",block:"center"});
  },160);
}


var btt=document.getElementById('btt');
window.addEventListener('scroll',function(){btt.classList.toggle('show',window.scrollY>300);},{passive:true});

buildProgress();
if(location.hash==='#p3'){showPage('p3',document.querySelector("button[onclick*=\"p3\"]"));}
</script>
</body>
</html>

