            <div class="aria-name">"Pieśń Roksany"</div>
          </div>
        </div>
        <div class="aria-warn">⚠️ Ņem visas 5 partitūras + kopijas klavieristam</div>
      </div>
    </div>

    <!-- Reminders -->
    <div class="info-section">
      <button class="info-header" onclick="this.parentElement.classList.toggle('open')">
        <div class="info-icon">📋</div>
        <div class="info-title">
          <strong>Atgādinājumi</strong>
          <span>Termiņi un svarīgas darbības</span>
        </div>
        <svg class="info-chev" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="info-body">
        <div class="info-row">
          <div class="info-row-icon">🏨</div>
          <div class="info-row-body">
            <div class="info-row-label">Mēdlings atcelšana — bezmaksas</div>
            <div class="info-row-val">Steiner Residences</div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-warn">24. maijs</span></div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🏛️</div>
          <div class="info-row-body">
            <div class="info-row-label">Reihstaga kupols — BEZMAKSAS</div>
            <div class="info-row-val"><a href="https://bundestag.de" target="_blank">bundestag.de</a></div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-urgent">ātrāk!</span></div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🛣️</div>
          <div class="info-row-body">
            <div class="info-row-label">CZ vinjete · EUR 15</div>
            <div class="info-row-val"><a href="https://edalnice.cz" target="_blank">edalnice.cz</a></div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-warn">pirms D2</span></div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🛣️</div>
          <div class="info-row-body">
            <div class="info-row-label">AT vinjete · EUR 10</div>
            <div class="info-row-val">Pirmā OMV/BP Austrijā</div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-warn">D2</span></div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">📧</div>
          <div class="info-row-body">
            <div class="info-row-label">Mēģinājuma laiks</div>
            <div class="info-row-val">Epasts nāks par 29. maija laiku</div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-ok">gaida</span></div>
        </div>
      </div>
    </div>

    <!-- Emergency -->
    <div class="info-section">
      <button class="info-header" onclick="this.parentElement.classList.toggle('open')">
        <div class="info-icon">🚨</div>
        <div class="info-title">
          <strong>Ārkārtas numuri</strong>
