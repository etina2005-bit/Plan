            <div class="info-row-sub">Duursmagasse 1, 2340 Mēdlings<br>Kods: <strong>659513351</strong> · PIN: <strong>077300</strong></div>
          </div>
          <div class="info-row-right">
            <span class="info-badge badge-warn">Atcelt līdz<br>24. maijs</span>
          </div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🇩🇪</div>
