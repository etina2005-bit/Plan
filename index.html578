function ld(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d;}catch{return d;}}
function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch{}}
let done=ld('cp26d',{});
let cvals=ld('cp26c',{});

function showPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nt').forEach(t=>t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if(btn)btn.classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
  if(id==='p2')buildCosts();
  if(id==='p3'){buildMap();setTimeout(buildRealMap,120);}
}

function buildProgress(){
  const w=document.getElementById('dw');w.innerHTML='';
  DAYS.forEach((day,di)=>{
    // only count non-info segments
    const checkable=day.s.filter(seg=>!seg.info);
    const tot=checkable.length;
    const dn=checkable.filter((_,ci)=>{
      // find the actual index in day.s
      var realIdx=day.s.indexOf(checkable[ci]);
      return done[di+'-'+realIdx];
    }).length;
    const pct=tot?Math.round(dn/tot*100):0;
    const el=document.createElement('div');
    el.className='cb card'+(dn>0?' open':'');
    el.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+day.n+'</span>'+
        '<div class="ci"><div class="ctitle">'+day.t+'</div><div class="csub">'+day.d+'</div></div>'+
        '<div class="cr"><span class="ccnt">'+dn+'/'+tot+'</span>'+
        '<svg class="chev" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg></div>'+
      '</div>'+
      '<div class="pb"><div class="pf" style="width:'+pct+'%"></div></div>'+
      '<div class="cbody">'+
        day.s.map(function(seg,si){
          if(seg.info){
            // info-only: no checkbox, no click, visually distinct
            return '<div class="seg seg-info">'+
              '<div class="seg-info-dot"></div>'+
              '<span class="stm">'+seg.ti+'</span>'+
              '<div class="sbdy"><div class="sttl">'+seg.h+'</div>'+(seg.de?'<div class="sdsc">'+seg.de+'</div>':'')+'</div>'+
              '<div class="sr2">'+
                (seg.free?'<span class="chip cf">bezmaksas</span>':'')+
                (seg.c&&!seg.free?'<span class="scst">'+seg.c+'</span>':'')+
              '</div></div>';
          }
          var isDone=done[di+'-'+si];
          return '<div class="seg'+(isDone?' done':'')+'" onclick="toggleSeg('+di+','+si+')">'+
            '<div class="schk"><svg class="csv" width="8" height="7" viewBox="0 0 10 8" fill="none"><path d="M1 4l3 3 5-6" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg></div>'+
            '<span class="stm">'+seg.ti+'</span>'+
            '<div class="sbdy"><div class="sttl">'+seg.h+'</div>'+(seg.de?'<div class="sdsc">'+seg.de+'</div>':'')+'</div>'+
            '<div class="sr2">'+
              (seg.free?'<span class="chip cf">bezmaksas</span>':'')+
              (seg.paid?'<span class="chip cp"></span>':'')+
              (seg.c&&!seg.free&&!seg.paid?'<span class="scst">'+seg.c+'</span>':'')+
            '</div></div>';
        }).join('')+
        '<div class="bft"><span>Dienas budžets</span><strong>'+day.tot+'</strong></div>'+
      '</div>';
    w.appendChild(el);
  });
  updateStats();
}

function toggleSeg(di,si){
  var k=di+'-'+si;done[k]=!done[k];sv('cp26d',done);buildProgress();
}
function updateStats(){
  var tot=0,n=0;
  DAYS.forEach(function(day,di){
    day.s.forEach(function(seg,si){
      if(seg.info)return; // skip info-only items
      tot++;
      if(done[di+'-'+si])n++;
    });
  });
  document.getElementById('spct').textContent=tot?Math.round(n/tot*100)+'%':'0%';
  document.getElementById('slft').textContent=tot-n;
}

/* ─────────────────────────────────────────────────────
   COSTS ENGINE
   cvals[k] = array of {v: number, note: string}
   summaryOverride = number | null  (manual edit of total spent)
───────────────────────────────────────────────────── */

// migrate old flat values to array format
(function migrateCvals(){
  Object.keys(cvals).forEach(function(k){
    var val=cvals[k];
    if(!Array.isArray(val)){
      if(val!==''&&val!==null&&val!==undefined){
        cvals[k]=[{v:parseFloat(val)||0,note:''}];
      } else {
        delete cvals[k];
      }
    }
  });
  sv('cp26c',cvals);
})();

var summaryOverride=ld('cp26so',null); // manual override for total spent
if(summaryOverride!==null)summaryOverride=parseFloat(summaryOverride)||null;

function rowTotal(k){
  if(!cvals[k]||!cvals[k].length)return null;
  return cvals[k].reduce(function(s,e){return s+(parseFloat(e.v)||0);},0);
}

function buildCosts(){
  var w=document.getElementById('cw');w.innerHTML='';
  COSTS.forEach(function(cat,ci){
    var catB=cat.items.reduce(function(a,i){return a+i.b;},0);
    var catEl=document.createElement('div');
    catEl.className='cb card';catEl.id='cat-'+ci;

    var rowsHtml=cat.items.map(function(item,ii){
      var k=ci+'-'+ii;
      if(item.paid){
        return '<div class="crow">'+
          '<div class="clbl">'+item.l+'</div>'+
          '<span class="chip cp" style="flex-shrink:0;"></span>'+
          '<div class="cfxd">EUR '+item.b.toFixed(2)+'</div>'+
          '<div class="cdif under" style="min-width:28px;">✓</div>'+
        '</div>';
      }
      return buildRowHTML(k,item.b,item.l);
    }).join('');

    catEl.innerHTML=
      '<div class="chd" onclick="this.closest(\'.cb\').classList.toggle(\'open\')">'+
        '<span class="cbadge">'+cat.badge+'</span>'+
        '<div class="ci">'+
          '<div class="ctitle">'+cat.t+'</div>'+
          '<div class="csub" id="csub-'+ci+'">Budžets: EUR '+catB.toFixed(0)+'</div>'+
        '</div>'+
        '<svg class="chev" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>'+
      '</div>'+
      '<div class="pb"><div class="pf" id="pf-'+ci+'" style="width:0%"></div></div>'+
      '<div class="cbody" id="cbody-'+ci+'">'+rowsHtml+
        '<div class="bft"><span>Kategorijas budžets</span><strong>EUR '+catB.toFixed(0)+'</strong></div>'+
      '</div>';
    w.appendChild(catEl);
  });
  recalc();
}

function buildRowHTML(k,budget,label){
  var entries=cvals[k]||[];
  var total=rowTotal(k);
  var diff=total!==null?total-budget:null;
  var dtxt=diff!==null?(diff>0.05?'+ EUR '+diff.toFixed(2):diff<-0.05?'− EUR '+Math.abs(diff).toFixed(2):'✓'):'';
  var dcls=diff!==null?(diff>0.05?'over':diff<-0.05?'under':'under'):'';

  var pills=entries.map(function(e,ei){
    return '<span class="entry-pill" id="pill-'+k+'-'+ei+'">'+
      'EUR '+(parseFloat(e.v)||0).toFixed(2)+
      '<button class="pill-del" onclick="deleteEntry(\''+k+'\','+ei+','+budget+')">×</button>'+
    '</span>';
  }).join('');

  var hasEntries=entries.length>0;
  return '<div class="crow" id="row-'+k+'">'+
    '<div class="crow-top">'+
      '<div class="clbl">'+label+'</div>'+
      '<div class="cfxd">Plāns: EUR '+budget.toFixed(2)+'</div>'+
    '</div>'+
    '<div class="crow-entries" id="entries-'+k+'">'+pills+
      '<button class="crow-add" id="add-'+k+'" onclick="startAdd(\''+k+'\','+budget+')" title="Pievienot">+</button>'+
    '</div>'+
    (hasEntries?
      '<div class="crow-bottom" id="bot-'+k+'">'+
        '<div class="crow-val" id="val-'+k+'">Kopā: EUR '+total.toFixed(2)+'</div>'+
        '<div class="cdif '+dcls+'" id="dif-'+k+'">'+dtxt+'</div>'+
      '</div>'
    :
      '<div class="crow-bottom" id="bot-'+k+'" style="display:none;">'+
        '<div class="crow-val" id="val-'+k+'">–</div>'+
        '<div class="cdif" id="dif-'+k+'"></div>'+
      '</div>'
    )+
  '</div>';
}

function refreshRow(k,budget){
  var row=document.getElementById('row-'+k);
  if(!row)return;
  var entries=cvals[k]||[];
  var total=rowTotal(k);
  var diff=total!==null?total-budget:null;
  var dtxt=diff!==null?(diff>0.05?'+ EUR '+diff.toFixed(2):diff<-0.05?'− EUR '+Math.abs(diff).toFixed(2):'✓'):'';
  var dcls=diff!==null?(diff>0.05?'over':diff<-0.05?'under':'under'):'';

  var pills=entries.map(function(e,ei){
    return '<span class="entry-pill" id="pill-'+k+'-'+ei+'">'+
      'EUR '+(parseFloat(e.v)||0).toFixed(2)+
      '<button class="pill-del" onclick="deleteEntry(\''+k+'\','+ei+','+budget+')">×</button>'+
    '</span>';
  }).join('');

  var entriesEl=document.getElementById('entries-'+k);
  if(entriesEl){
    var existingWrap=entriesEl.querySelector('.cinp-wrap');
    entriesEl.innerHTML=pills+'<button class="crow-add" id="add-'+k+'" onclick="startAdd(\''+k+'\','+budget+')" title="Pievienot">+</button>';
    if(existingWrap)entriesEl.insertBefore(existingWrap,entriesEl.lastChild);
  }

  var valEl=document.getElementById('val-'+k);
  var difEl=document.getElementById('dif-'+k);
  var botEl=document.getElementById('bot-'+k);
  if(entries.length>0){
    if(botEl)botEl.style.display='';
    if(valEl)valEl.textContent='Kopā: EUR '+total.toFixed(2);
    if(difEl){difEl.textContent=dtxt;difEl.className='cdif '+dcls;}
  } else {
    if(botEl)botEl.style.display='none';
    if(valEl)valEl.textContent='–';
    if(difEl){difEl.textContent='';difEl.className='cdif';}
  }
}

function startAdd(k,budget){
  var entriesEl=document.getElementById('entries-'+k);
  if(!entriesEl)return;
  // if input already open, just focus it
  var existing=entriesEl.querySelector('.cinp-wrap');
  if(existing){existing.querySelector('.cinp').focus();return;}
  var addBtn=document.getElementById('add-'+k);
  if(addBtn)addBtn.style.display='none';
  var wrap=document.createElement('div');
  wrap.className='cinp-wrap';
  wrap.innerHTML='<input class="cinp" type="number" step="0.01" min="0" placeholder="0.00">'+
    '<button class="cinp-confirm" onclick="confirmAdd(\''+k+'\','+budget+')">OK</button>'+
    '<button class="cinp-cancel" onclick="cancelAdd(\''+k+'\')">✕</button>';
  entriesEl.insertBefore(wrap,entriesEl.lastChild);
  wrap.querySelector('.cinp').focus();
  wrap.querySelector('.cinp').addEventListener('keydown',function(e){
    if(e.key==='Enter'){e.preventDefault();confirmAdd(k,budget);}
    if(e.key==='Escape'){cancelAdd(k);}
  });
}

function cancelAdd(k){
  var entriesEl=document.getElementById('entries-'+k);
  if(!entriesEl)return;
  var wrap=entriesEl.querySelector('.cinp-wrap');
  if(wrap)wrap.remove();
  var addBtn=document.getElementById('add-'+k);
  if(addBtn)addBtn.style.display='';
}

function confirmAdd(k,budget){
  var entriesEl=document.getElementById('entries-'+k);
  if(!entriesEl)return;
  var inp=entriesEl.querySelector('.cinp');
  var v=inp?parseFloat(inp.value):NaN;
  if(!isNaN(v)&&v>0){
    if(!cvals[k])cvals[k]=[];
    cvals[k].push({v:v,note:''});
    sv('cp26c',cvals);
  }
  var wrap=entriesEl.querySelector('.cinp-wrap');
  if(wrap)wrap.remove();
  var addBtn=document.getElementById('add-'+k);
  if(addBtn)addBtn.style.display='';
  refreshRow(k,budget);
  recalc();
}

function deleteEntry(k,ei,budget){
  if(!cvals[k])return;
  cvals[k].splice(ei,1);
  if(!cvals[k].length)delete cvals[k];
  sv('cp26c',cvals);
  refreshRow(k,budget);
  recalc();
}

function recalc(){
  var b=0,a=0,has=false;
  COSTS.forEach(function(cat,ci){
    var catB=cat.items.reduce(function(x,i){return x+i.b;},0);
    var catA=0,catH=false;
    cat.items.forEach(function(item,ii){
      b+=item.b;
      var k=ci+'-'+ii;
      var t=rowTotal(k);
      if(t!==null){a+=t;catA+=t;has=true;catH=true;}
    });
    var catPct=catH?Math.min(Math.round(catA/catB*100),100):0;
    var pf=document.getElementById('pf-'+ci);
    if(pf)pf.style.width=catPct+'%';
    var csub=document.getElementById('csub-'+ci);
    if(csub)csub.textContent='Budžets: EUR '+catB.toFixed(0)+(catH?' · Iztērēts: EUR '+catA.toFixed(2):'');
  });

  document.getElementById('kb').textContent='EUR '+b.toFixed(0);
  var ae=document.getElementById('ka'),de=document.getElementById('kd'),sb=document.getElementById('spent-bar-fill');
  var kaEdit=document.getElementById('ka-edit-btn');

  // use override if set, else auto total
  var displayA=summaryOverride!==null?summaryOverride:a;
  var displayHas=summaryOverride!==null?true:has;

  if(displayHas){
    ae.textContent='EUR '+displayA.toFixed(0);
    ae.style.color=summaryOverride!==null?'var(--amber)':'var(--green)';
    var d=displayA-b;
    de.textContent=(d>=0?'+':'')+' EUR '+d.toFixed(0);
    de.style.color=d>0?'var(--amber)':'var(--green)';
    if(sb)sb.style.width=Math.min(Math.round(displayA/b*100),100)+'%';
  } else {
    ae.textContent='—';ae.style.color='var(--muted)';
    de.textContent='—';de.style.color='var(--muted)';
    if(sb)sb.style.width='0%';
  }
  // show auto-sum note if override active
  var autoNote=document.getElementById('ka-auto');
  if(autoNote){
    if(summaryOverride!==null&&has){
      autoNote.textContent='(auto: EUR '+a.toFixed(0)+')';
      autoNote.style.display='block';
    } else {
      autoNote.style.display='none';
    }
  }
}

// ── Summary table edit ─────────────────────────────
function startSummaryEdit(){
  var ae=document.getElementById('ka');
  var btn=document.getElementById('ka-edit-btn');
  var wrap=document.getElementById('ka-edit-wrap');
  if(wrap){wrap.style.display='flex';ae.style.display='none';if(btn)btn.style.display='none';
    wrap.querySelector('.cinp').focus();return;}
  // build wrap
  var newWrap=document.createElement('div');
  newWrap.id='ka-edit-wrap';
  newWrap.style.cssText='display:flex;align-items:center;gap:0.35rem;justify-content:center;flex-wrap:wrap;margin-top:0.25rem;';
  newWrap.innerHTML=
    '<input class="cinp" style="width:90px;font-size:0.9rem;" type="number" step="1" min="0" placeholder="EUR" id="ka-inp">'+
    '<button class="cinp-confirm" onclick="confirmSummaryEdit()">OK</button>'+
    '<button class="cinp-cancel" onclick="clearSummaryEdit()">Auto</button>';
  ae.after(newWrap);
  ae.style.display='none';
  if(btn)btn.style.display='none';
  document.getElementById('ka-inp').focus();
  document.getElementById('ka-inp').addEventListener('keydown',function(e){
    if(e.key==='Enter')confirmSummaryEdit();
    if(e.key==='Escape')clearSummaryEdit();
  });
}
function confirmSummaryEdit(){
  var inp=document.getElementById('ka-inp');
  var v=parseFloat(inp?inp.value:'');
  if(!isNaN(v)&&v>=0){summaryOverride=v;sv('cp26so',summaryOverride);}
  hideSummaryWrap();recalc();
}
function clearSummaryEdit(){
  summaryOverride=null;sv('cp26so',null);
  hideSummaryWrap();recalc();
}
function hideSummaryWrap(){
  var ae=document.getElementById('ka');
  var btn=document.getElementById('ka-edit-btn');
  var wrap=document.getElementById('ka-edit-wrap');
  if(ae)ae.style.display='';
  if(btn)btn.style.display='';
  if(wrap)wrap.remove();
}

var tC={red:'#b5294e',gold:'#a07ac4',green:'#3d8b6e',blue:'#4a80b5'};

function buildMap(){
  var g=document.getElementById('stops-g');
  if(!g||g.children.length>0)return;
  var groups={};
  STOPS.forEach(function(s){
    var key=s.day.split(' ')[0];
    if(s.day.indexOf('D7')===0)key='D7–8';
    if(s.day.indexOf('D9')===0)key='D9';
    if(!groups[key])groups[key]=[];
    groups[key].push(s);
  });
  g.innerHTML=Object.keys(groups).map(function(day,idx){
    var items=groups[day].map(function(s){
      var safe=s.name.replace(/'/g,"&#39;");
      return '<button type="button" class="spc" onclick="focusStopFromCard(\''+safe+'\')">'+
        '<div class="spd"><span style="width:7px;height:7px;border-radius:50%;background:'+tC[s.type]+';display:inline-block;flex-shrink:0;"></span>'+s.day+'</div>'+
        '<div class="spn">'+s.name+'</div>'+
        '<div class="spnt">'+s.note+'</div>'+
      '</button>';
    }).join('');
    return '<div class="stopGroup '+(idx===0?'open':'')+'">'+
      '<button type="button" class="stopGroupHead" onclick="this.parentElement.classList.toggle(\'open\')">'+
      '<strong>'+day+'</strong><span>'+groups[day].length+' pieturas</span></button>'+
      '<div class="stopGroupBody">'+items+'</div></div>';
  }).join('');
}

var realMap=null;
var realMarkers=[];
var realBounds=null;

