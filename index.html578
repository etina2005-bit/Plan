  {name:"Staatsoper Unter den Linden",lat:52.5171,lng:13.3949,type:"gold",day:"D7–8",address:"Unter den Linden 7, 10117 Berlin",info:"Tava nākotnes darba zona.",cost:"EUR 0"},
