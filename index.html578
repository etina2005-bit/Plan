var realColors={red:"#b5294e",gold:"#a07ac4",green:"#3d8b6e",blue:"#4a80b5"};

function pinIcon(color){
  return L.divIcon({
    className:"",
    html:'<div class="mapPin" style="background:'+color+'"></div>',
    iconSize:[28,28],iconAnchor:[14,28],popupAnchor:[0,-26]
  });
}
function popupHtml(s){
  return '<div class="popupTitle">'+s.name+'</div>'+
    '<div class="popupKey">Adrese</div><div class="popupVal">'+s.address+'</div>'+
    '<div class="popupKey">Info</div><div class="popupVal">'+s.info+'</div>'+
    '<div class="popupKey">Izmaksas</div><div class="popupVal">'+s.cost+'</div>';
}
function buildRealMap(){
  if(realMap||!document.getElementById("route-real-map")||typeof L==="undefined")return;
  realMap=L.map("route-real-map",{zoomControl:true,scrollWheelZoom:true,doubleClickZoom:true,touchZoom:true,dragging:true,tap:true});
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{maxZoom:19,attribution:"© OpenStreetMap"}).addTo(realMap);
  var routeLatLngs=realStops.map(function(s){return [s.lat,s.lng];});
  L.polyline(routeLatLngs,{color:"#3d8b6e",weight:2.5,opacity:0.7,lineCap:"round",lineJoin:"round"}).addTo(realMap);
  realStops.forEach(function(s){
    var marker=L.marker([s.lat,s.lng],{icon:pinIcon(realColors[s.type]||realColors.blue)}).addTo(realMap).bindPopup(popupHtml(s));
    marker.stopName=s.name;realMarkers.push(marker);
  });
  realBounds=L.latLngBounds(routeLatLngs).pad(0.13);
  realMap.fitBounds(realBounds);
  setTimeout(function(){realMap.invalidateSize();realMap.fitBounds(realBounds);},250);
}
function realMapFit(){buildRealMap();if(realMap&&realBounds)realMap.fitBounds(realBounds);}
function realMapZoomIn(){buildRealMap();if(realMap)realMap.zoomIn();}
function realMapZoomOut(){buildRealMap();if(realMap)realMap.zoomOut();}
function focusStopFromCard(name){
  buildRealMap();
  var target=realStops.find(function(s){return s.name===name||s.name.toLowerCase().indexOf(name.toLowerCase())!==-1||name.toLowerCase().indexOf(s.name.toLowerCase())!==-1;});
  if(!target||!realMap)return;
  showPage('p3',document.querySelector("button[onclick*='p3']"));
  setTimeout(function(){
    realMap.invalidateSize();
    realMap.setView([target.lat,target.lng],13,{animate:true});
    var marker=realMarkers.find(function(m){return m.stopName===target.name;});
    if(marker)marker.openPopup();
    document.getElementById("route-real-map").scrollIntoView({behavior:"smooth",block:"center"});
  },160);
}

var btt=document.getElementById('btt');
window.addEventListener('scroll',function(){btt.classList.toggle('show',window.scrollY>300);},{passive:true});
buildProgress();
if(location.hash==='#p3'){showPage('p3',document.querySelector("button[onclick*=\"p3\"]"));}
</script>
</body>
</html>

<style>
.ph{display:none!important;}
</style>
