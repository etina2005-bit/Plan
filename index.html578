<!DOCTYPE html>
<html lang="lv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ceļu Plāns 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
/* ── Reset ─────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

/* ── Design tokens ─────────────────────────────── */
:root{
  --bg:#f2f4f0;
  --surface:rgba(255,255,255,0.72);
  --surface2:rgba(255,255,255,0.9);
  --border:rgba(210,220,205,0.6);
  --border2:rgba(180,200,175,0.4);

  --ink:#1a2118;
  --ink2:#3d4d39;
  --muted:#7a8f74;

  --green:#3d8b6e;
  --green-light:#6cb89a;
  --green-pale:#dff0e8;
  --pink:#b5294e;
  --blue:#4a80b5;
  --amber:#b87333;

  --grad-green:linear-gradient(135deg,#3d8b6e 0%,#6cb89a 60%,#d4798a 100%);
  --grad-green-soft:linear-gradient(135deg,rgba(61,139,110,0.08) 0%,rgba(108,184,154,0.14) 60%,rgba(212,121,138,0.08) 100%);
  --grad-pink:linear-gradient(135deg,#b5294e,#d4607c);
  --grad-surface:linear-gradient(160deg,rgba(255,255,255,0.85) 0%,rgba(241,248,244,0.75) 100%);

  --r:12px;--rsm:8px;
  --sh:0 2px 20px rgba(30,50,30,0.08);
  --sh2:0 8px 40px rgba(30,50,30,0.12);
  --font:'DM Sans',sans-serif;
  --serif:'DM Serif Display',serif;
}

/* ── Base ───────────────────────────────────────── */
html{scroll-behavior:smooth;}
body{
  font-family:var(--font);font-weight:400;color:var(--ink);
  min-height:100vh;overflow-x:hidden;
  background:linear-gradient(150deg,#e8ede4 0%,#ddebd6 30%,#e9ede4 60%,#f0e8ec 85%,#ede8ec 100%) fixed;
}
::-webkit-scrollbar{width:4px;}
::-webkit-scrollbar-thumb{background:rgba(61,139,110,0.25);border-radius:10px;}

/* ── Navigation ─────────────────────────────────── */
nav{
  position:fixed;top:0.9rem;left:50%;transform:translateX(-50%);z-index:300;
  display:flex;align-items:center;gap:4px;
  background:rgba(255,255,255,0.9);backdrop-filter:blur(28px) saturate(1.8);
  -webkit-backdrop-filter:blur(28px) saturate(1.8);
  border:2px solid var(--border);border-radius:14px;
  padding:5px;box-shadow:var(--sh),0 1px 3px rgba(61,139,110,0.15);
}
.nt{
  font-family:var(--font);font-size:0.8rem;font-weight:600;letter-spacing:0.01em;
  color:var(--ink2);background:none;border:none;
  padding:0.5rem 1.1rem;border-radius:10px;
  cursor:pointer;transition:all 0.16s ease;white-space:nowrap;
}
.nt:hover{background:rgba(61,139,110,0.09);color:var(--green);}
.nt.active{
  background:var(--grad-green);color:white;
  box-shadow:0 2px 10px rgba(61,139,110,0.3);
  border-radius:10px;
}

/* ── Page transitions ───────────────────────────── */
.page{display:none;padding-top:5rem;padding-bottom:4rem;min-height:100vh;}
.page.active{display:block;animation:pageIn 0.24s ease;}
@keyframes pageIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}

/* ── Layout ─────────────────────────────────────── */
.wrap{max-width:780px;margin:0 auto;padding:0 1.25rem;}
.ph{padding:0.6rem 1.25rem 1.1rem;text-align:center;}
.ph h1{
  font-family:var(--serif);font-size:2rem;font-weight:400;
  color:var(--ink);line-height:1.1;margin-bottom:0.28rem;
}
.ph h1 em{
  font-style:italic;
  background:var(--grad-green);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.ph .sub{font-size:0.72rem;font-weight:500;color:var(--muted);letter-spacing:0.05em;text-transform:uppercase;}

/* ── Card ───────────────────────────────────────── */
.card{
  background:var(--grad-surface);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:2px solid var(--border);border-radius:var(--r);
  box-shadow:var(--sh);
}

/* ── Summary stats strip ────────────────────────── */
.summary-strip{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:0;margin-bottom:1.2rem;
  border-radius:var(--r);overflow:hidden;
  border:2px solid var(--border);
  box-shadow:var(--sh2);
}
.sc{
  position:relative;
  padding:1.9rem 0.5rem 1.7rem;
  text-align:center;
  background:var(--grad-surface);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  transition:background 0.2s;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.sc:not(:last-child){border-right:1px solid var(--border2);}
.sc::before{
  content:"";position:absolute;inset:0;
  background:var(--grad-green-soft);
  opacity:0;transition:opacity 0.2s;
}
.sc:hover::before{opacity:1;}

/* accent bar on top of each stat */
.sc::after{
  content:"";position:absolute;top:0;left:0;right:0;
  height:2px;
  background:var(--grad-green);
  opacity:0.6;
}

.sv{
  font-family:var(--serif);font-size:1.9rem;font-weight:400;
  color:var(--ink);line-height:1;margin-bottom:0.32rem;
  display:block;position:relative;
}
.sl{
  font-size:0.52rem;font-weight:600;letter-spacing:0.09em;
  text-transform:uppercase;color:var(--muted);
  display:block;position:relative;
}

/* special: percent cell gets green tint */
.sc.pct-cell{
  background:linear-gradient(160deg,rgba(61,139,110,0.08) 0%,rgba(108,184,154,0.18) 100%);
}
.sc.pct-cell .sv{
  background:var(--grad-green);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}

/* ── Accordion cards ────────────────────────────── */
.cb{margin-bottom:0.6rem;}
.chd{
  display:flex;align-items:center;gap:0.75rem;
  padding:0.85rem 1rem;cursor:pointer;user-select:none;
  border-radius:var(--r);transition:background 0.15s;
}
.chd:hover{background:rgba(61,139,110,0.04);}
.cbadge{
  font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
  background:var(--grad-green);
  color:white;padding:0.22rem 0.55rem;border-radius:100px;flex-shrink:0;
}
.ci{flex:1;min-width:0;}
.ctitle{font-size:0.88rem;font-weight:600;color:var(--ink);margin-bottom:0.05rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.csub{font-size:0.65rem;font-weight:400;color:var(--muted);}
.cr{display:flex;align-items:center;gap:0.5rem;flex-shrink:0;}
.ccnt{font-size:0.65rem;font-weight:500;color:var(--muted);}
.chev{color:var(--muted);transition:transform 0.22s;flex-shrink:0;}
.cb.open .chev{transform:rotate(180deg);}

/* progress bar */
.pb{height:1.5px;background:rgba(61,139,110,0.1);overflow:hidden;}
.pf{height:100%;background:var(--grad-green);transition:width 0.4s ease;}

.cbody{display:none;overflow:hidden;}
.cb.open .cbody{display:block;animation:slideDown 0.2s ease;}
@keyframes slideDown{from{opacity:0;transform:translateY(-3px)}to{opacity:1;transform:none}}

/* ── Segment rows ───────────────────────────────── */
.seg{
  display:flex;align-items:flex-start;gap:0.75rem;
  padding:0.72rem 1rem;
  border-top:1px solid rgba(61,139,110,0.07);
  cursor:pointer;transition:background 0.13s;
}
.seg:hover{background:rgba(255,255,255,0.5);}
.seg.done{opacity:0.48;}
.schk{
  width:18px;height:18px;border-radius:50%;flex-shrink:0;margin-top:2px;
  border:1.5px solid rgba(61,139,110,0.3);background:rgba(255,255,255,0.6);
  display:flex;align-items:center;justify-content:center;transition:all 0.18s;
}
.seg.done .schk{background:var(--grad-green);border-color:transparent;}
.csv{display:none;}
.seg.done .csv{display:block;}
.stm{font-size:0.63rem;font-weight:500;color:var(--muted);min-width:52px;white-space:nowrap;padding-top:2px;flex-shrink:0;}
.sbdy{flex:1;min-width:0;}
.sttl{font-size:0.83rem;font-weight:500;color:var(--ink);margin-bottom:0.1rem;line-height:1.3;}
.seg.done .sttl{text-decoration:line-through;color:var(--muted);}
.sdsc{font-size:0.7rem;color:var(--muted);line-height:1.5;font-weight:400;}
.sr2{display:flex;flex-direction:column;align-items:flex-end;gap:0.18rem;flex-shrink:0;padding-top:2px;min-width:70px;}
.scst{font-size:0.66rem;font-weight:500;color:var(--ink2);white-space:nowrap;}

/* chips */
.chip{font-size:0.54rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;padding:0.14rem 0.42rem;border-radius:100px;white-space:nowrap;}
.cf{background:rgba(61,139,110,0.1);color:var(--green);border:1px solid rgba(61,139,110,0.22);}
.cp{background:rgba(181,41,78,0.09);color:var(--pink);border:1px solid rgba(181,41,78,0.2);}

.bft{
  display:flex;justify-content:space-between;align-items:center;
  padding:0.6rem 1rem;border-top:1px solid rgba(61,139,110,0.08);
  font-size:0.7rem;color:var(--muted);
}
.bft strong{color:var(--ink2);font-weight:600;}

/* ── Costs overview ─────────────────────────────── */
.cov{
  display:grid;grid-template-columns:repeat(3,1fr);gap:0;
  border:2px solid var(--border);border-radius:var(--r);
  overflow:hidden;box-shadow:var(--sh2);margin-bottom:1.4rem;
}
.cvc{
  background:var(--grad-surface);backdrop-filter:blur(20px);
  padding:1.3rem 0.75rem;text-align:center;
}
.cvc:nth-child(2){
  background:linear-gradient(160deg,rgba(61,139,110,0.08) 0%,rgba(108,184,154,0.2) 100%);
  border-left:2px solid var(--border2);border-right:2px solid var(--border2);
}
.cvv{font-family:var(--serif);font-size:1.6rem;font-weight:400;display:block;color:var(--ink);margin-bottom:0.2rem;}
.cvl{font-size:0.52rem;font-weight:600;color:var(--muted);letter-spacing:0.09em;text-transform:uppercase;}

/* cost rows — vertical layout */
.crow{
  display:flex;flex-direction:column;
  padding:0.8rem 1rem;border-top:1px solid rgba(61,139,110,0.07);
  gap:0.45rem;
}
.crow-top{display:flex;align-items:center;justify-content:space-between;gap:0.5rem;}
.clbl{font-size:0.82rem;color:var(--ink);min-width:0;flex:1;}
.cfxd{font-size:0.7rem;color:var(--muted);white-space:nowrap;flex-shrink:0;}
.crow-bottom{display:flex;align-items:center;justify-content:space-between;gap:0.5rem;padding-top:0.28rem;border-top:1px solid rgba(61,139,110,0.06);}
.crow-val{font-size:0.8rem;font-weight:700;color:var(--ink2);white-space:nowrap;}
.cdif{font-size:0.7rem;font-weight:700;white-space:nowrap;text-align:right;}
.cdif.over{color:#c0392b;}
.cdif.under{color:var(--green);}
.crow-bottom-empty{display:none;}

/* cost summary spent bar */
.cov-spent-bar{
  height:3px;border-radius:100px;margin-top:0.5rem;overflow:hidden;
  background:rgba(61,139,110,0.1);
}
.cov-spent-fill{height:100%;border-radius:100px;background:var(--grad-green);transition:width 0.5s ease;}

/* entry pills in cost rows */
.crow-entries{display:flex;flex-wrap:wrap;align-items:center;gap:0.28rem;}
.entry-pill{
  display:inline-flex;align-items:center;gap:0.2rem;
  font-size:0.67rem;font-weight:600;color:var(--ink2);
  background:rgba(61,139,110,0.09);border:1px solid rgba(61,139,110,0.2);
  border-radius:100px;padding:0.15rem 0.38rem 0.15rem 0.48rem;
  white-space:nowrap;
}
.pill-del{
  font-size:0.65rem;line-height:1;color:var(--muted);background:none;border:none;
  cursor:pointer;padding:0 0.08rem;transition:color 0.13s;font-family:var(--font);
}
.pill-del:hover{color:var(--pink);}
.crow-add{
  font-family:var(--font);font-size:0.85rem;font-weight:700;color:var(--green);
  background:rgba(61,139,110,0.07);border:2px dashed rgba(61,139,110,0.3);
  border-radius:7px;padding:0.08rem 0.4rem;cursor:pointer;
  transition:all 0.14s;white-space:nowrap;flex-shrink:0;line-height:1.5;
}
.crow-add:hover{background:rgba(61,139,110,0.14);border-style:solid;}
/* remove old crow-right since total/diff now go in crow-bottom */
.crow-right{display:none;}
.cinp-cancel{
  font-family:var(--font);font-size:0.62rem;font-weight:600;color:var(--muted);
  background:rgba(255,255,255,0.8);border:2px solid var(--border);border-radius:7px;
  padding:0.26rem 0.4rem;cursor:pointer;white-space:nowrap;flex-shrink:0;
  transition:all 0.14s;
}
.cinp-cancel:hover{color:var(--pink);border-color:rgba(181,41,78,0.4);}

/* shared input */
.cinp-wrap{display:flex;align-items:center;gap:0.35rem;flex-shrink:0;flex-wrap:nowrap;}
.cinp{
  font-family:var(--font);font-size:0.76rem;color:var(--ink);font-weight:500;
  background:rgba(255,255,255,0.95);border:2px solid rgba(61,139,110,0.35);
  border-radius:8px;padding:0.28rem 0.48rem;outline:none;
  transition:border-color 0.15s,box-shadow 0.15s;text-align:right;width:80px;flex-shrink:0;
}
.cinp:focus{border-color:rgba(61,139,110,0.65);box-shadow:0 0 0 3px rgba(61,139,110,0.1);}
.cinp-confirm{
  font-family:var(--font);font-size:0.62rem;font-weight:700;
  background:var(--grad-green);color:white;border:none;border-radius:7px;
  padding:0.26rem 0.5rem;cursor:pointer;white-space:nowrap;flex-shrink:0;
}

/* edit button on row (legacy, keep for compat) */
.crow-edit{
  font-family:var(--font);font-size:0.62rem;font-weight:600;
  color:var(--muted);background:rgba(255,255,255,0.7);
  border:1px solid var(--border);border-radius:6px;
  padding:0.18rem 0.42rem;cursor:pointer;transition:all 0.15s;
  flex-shrink:0;white-space:nowrap;
}
.crow-edit:hover{background:white;color:var(--green);border-color:rgba(61,139,110,0.3);}
.crow-edit.editing{background:var(--grad-green);color:white;border-color:transparent;}

/* ── Map page ───────────────────────────────────── */
.ml{
  display:flex;flex-wrap:wrap;gap:0.85rem;align-items:center;
  padding:0.85rem 1.1rem;margin-bottom:1rem;
  font-size:0.71rem;font-weight:500;color:var(--ink2);
}
.ld{width:8px;height:8px;border-radius:50%;display:inline-block;flex-shrink:0;}
.li{display:flex;align-items:center;gap:0.38rem;}
.mab{
  display:flex;align-items:center;gap:0.5rem;justify-content:center;
  width:100%;padding:0.8rem;margin-bottom:1rem;
  background:var(--grad-green-soft);
  border:1px solid rgba(61,139,110,0.2);border-radius:var(--rsm);
  font-size:0.77rem;font-weight:600;color:var(--green);text-decoration:none;
  cursor:pointer;transition:background 0.18s;font-family:var(--font);
}
.mab:hover{background:linear-gradient(135deg,rgba(61,139,110,0.15),rgba(108,184,154,0.25));}
.slbl{
  font-size:0.55rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  color:var(--muted);margin-bottom:0.55rem;padding:0 0.1rem;
}

/* interactive map */
.realMapWrap{border-radius:var(--r);overflow:hidden;border:1px solid var(--border);box-shadow:var(--sh);background:#e8ede4;margin-bottom:1rem;}
.realMapTop{
  display:flex;gap:0.7rem;align-items:center;justify-content:space-between;flex-wrap:wrap;
  padding:0.8rem 1rem;border-bottom:1px solid var(--border2);
  background:rgba(255,255,255,0.5);
}
.realMapHelp{font-size:0.7rem;color:var(--muted);line-height:1.4;max-width:520px;}
.realMapControls{display:flex;gap:0.35rem;flex-wrap:wrap;}
.realMapControls button{
  font-family:var(--font);font-size:0.72rem;font-weight:700;color:var(--ink2);
  background:rgba(255,255,255,0.85);border:1px solid var(--border);
  border-radius:100px;padding:0.42rem 0.75rem;cursor:pointer;
  transition:background 0.15s;
}
.realMapControls button:hover{background:white;color:var(--green);}
#route-real-map{height:540px;width:100%;background:#e4ece6;z-index:1;}
.leaflet-container{font-family:var(--font);background:#e4ece6;touch-action:pan-x pan-y;}
.leaflet-control-zoom a{
  width:34px!important;height:34px!important;line-height:34px!important;
  font-size:20px!important;border-radius:8px!important;margin-bottom:3px;
  background:rgba(255,255,255,0.94)!important;color:var(--ink)!important;
  border:1px solid rgba(180,200,175,0.5)!important;box-shadow:0 2px 8px rgba(28,45,28,0.12)!important;
}
.leaflet-control-zoom{border:none!important;background:transparent!important;}
.mapPin{position:relative;width:28px;height:28px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:2.5px solid white;box-shadow:0 3px 12px rgba(28,45,28,0.3);}
.mapPin::after{content:"";position:absolute;width:8px;height:8px;border-radius:50%;background:white;left:50%;top:50%;transform:translate(-50%,-50%);}
.popupTitle{font-weight:700;color:var(--ink);font-size:0.92rem;margin-bottom:0.32rem;}
.popupKey{font-size:0.56rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--muted);font-weight:700;margin-top:0.5rem;}
.popupVal{font-size:0.74rem;color:var(--ink2);line-height:1.45;margin-top:0.06rem;}
.leaflet-popup-content-wrapper{border-radius:14px!important;background:rgba(255,255,255,0.97)!important;backdrop-filter:blur(12px);box-shadow:0 6px 28px rgba(28,45,28,0.18)!important;}
.leaflet-popup-content{margin:0.8rem 0.95rem!important;}

/* stop groups */
.stopGroups{margin-bottom:1.5rem;}
.stopGroup{margin-bottom:0.55rem;overflow:hidden;}
.stopGroupHead{
  display:flex;align-items:center;gap:0.7rem;width:100%;
  padding:0.8rem 1rem;
  background:var(--grad-surface);
  border:1px solid var(--border);border-radius:var(--r);
  box-shadow:var(--sh);font-family:var(--font);text-align:left;
  color:var(--ink);cursor:pointer;transition:background 0.15s;
}
.stopGroupHead:hover{background:rgba(255,255,255,0.9);}
.stopGroupHead strong{font-size:0.87rem;font-weight:600;flex:1;}
.stopGroupHead span{font-size:0.64rem;font-weight:500;color:var(--muted);}
.stopGroupBody{display:none;padding-top:0.5rem;}
.stopGroup.open .stopGroupBody{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.5rem;}
.sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:0.55rem;margin-bottom:1.5rem;}
.spc{
  background:var(--grad-surface);backdrop-filter:blur(16px);
  border:1px solid var(--border);border-radius:var(--rsm);
  padding:0.8rem 0.9rem;box-shadow:var(--sh);
  cursor:pointer;border:none;text-align:left;font-family:var(--font);
  transition:box-shadow 0.15s,transform 0.15s;
}
.spc:hover{box-shadow:var(--sh2);transform:translateY(-1px);}
.spd{font-size:0.6rem;font-weight:600;color:var(--muted);margin-bottom:0.24rem;display:flex;align-items:center;gap:0.32rem;text-transform:uppercase;letter-spacing:0.06em;}
.spn{font-size:0.82rem;font-weight:600;color:var(--ink);margin-bottom:0.14rem;}
.spnt{font-size:0.68rem;color:var(--muted);font-weight:400;line-height:1.4;}

/* ── Contacts ─────────────────────────────────────── */
.info-section{margin-bottom:0.7rem;font-family:var(--font);}
.info-header{
  display:flex;align-items:center;gap:0.75rem;
  padding:1rem 1.15rem;
  background:var(--grad-surface);
  backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:2px solid var(--border);border-radius:var(--r);
  box-shadow:var(--sh);
  cursor:pointer;width:100%;font-family:var(--font);
  text-align:left;transition:background 0.15s;
  user-select:none;
}
.info-header:hover{background:rgba(255,255,255,0.92);}
.info-icon{
  width:36px;height:36px;border-radius:9px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  background:var(--grad-green-soft);border:2px solid rgba(61,139,110,0.18);
  font-size:1rem;
}
.info-title{flex:1;font-family:var(--font);}
.info-title strong{display:block;font-size:0.88rem;font-weight:700;color:var(--ink);line-height:1.2;font-family:var(--font);}
.info-title span{display:block;font-size:0.65rem;font-weight:500;color:var(--muted);margin-top:0.1rem;font-family:var(--font);}
.info-chev{color:var(--muted);transition:transform 0.22s;flex-shrink:0;}
.info-section.open .info-chev{transform:rotate(180deg);}
.info-body{
  display:none;
  background:rgba(255,255,255,0.55);
  backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);
  border:2px solid var(--border);border-top:none;
  border-radius:0 0 var(--r) var(--r);
  overflow:hidden;font-family:var(--font);
}
.info-section.open .info-header{border-radius:var(--r) var(--r) 0 0;border-bottom:none;}
.info-section.open .info-body{display:block;animation:slideDown 0.2s ease;}

/* info rows inside body */
.info-row{
  display:flex;align-items:flex-start;gap:0.9rem;
  padding:0.85rem 1.15rem;
  border-bottom:1px solid rgba(61,139,110,0.07);
  font-family:var(--font);
}
.info-row:last-child{border-bottom:none;}
.info-row-icon{
  width:28px;height:28px;border-radius:7px;flex-shrink:0;margin-top:2px;
  display:flex;align-items:center;justify-content:center;
  font-size:0.82rem;
  background:rgba(61,139,110,0.07);border:1px solid rgba(61,139,110,0.14);
}
.info-row-body{flex:1;min-width:0;font-family:var(--font);}
.info-row-label{font-size:0.6rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;color:var(--muted);margin-bottom:0.2rem;font-family:var(--font);}
.info-row-val{font-size:0.83rem;color:var(--ink);line-height:1.5;font-weight:500;font-family:var(--font);}
.info-row-val a{color:var(--green);text-decoration:none;font-weight:600;font-family:var(--font);}
.info-row-val a:hover{text-decoration:underline;}
.info-row-sub{font-size:0.69rem;color:var(--muted);margin-top:0.12rem;line-height:1.45;font-family:var(--font);}
.info-row-sub a{color:var(--green);text-decoration:none;font-weight:600;}
.info-row-right{flex-shrink:0;text-align:right;padding-top:2px;}
.info-badge{
  display:inline-block;font-size:0.59rem;font-weight:700;letter-spacing:0.05em;
  padding:0.2rem 0.5rem;border-radius:6px;white-space:nowrap;font-family:var(--font);
}
.badge-warn{background:rgba(184,115,51,0.12);color:var(--amber);border:1.5px solid rgba(184,115,51,0.25);}
.badge-ok{background:rgba(61,139,110,0.1);color:var(--green);border:1.5px solid rgba(61,139,110,0.22);}
.badge-urgent{background:rgba(181,41,78,0.09);color:var(--pink);border:1.5px solid rgba(181,41,78,0.2);}

/* aria rows — numbered list style */
.aria-row{
  display:flex;align-items:center;gap:0.85rem;
  padding:0.78rem 1.15rem;
  border-bottom:1px solid rgba(61,139,110,0.07);
  font-family:var(--font);
}
.aria-row:last-child{border-bottom:none;}
.aria-num{
  width:26px;height:26px;border-radius:7px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  font-size:0.72rem;font-weight:800;color:white;
  background:var(--grad-green);font-family:var(--font);
}
.aria-body{flex:1;min-width:0;font-family:var(--font);}
.aria-composer{font-size:0.65rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.06em;}
.aria-name{font-size:0.82rem;font-weight:500;color:var(--ink);margin-top:0.07rem;font-style:italic;}
.aria-warn{
  margin:0.5rem 1.15rem 0.75rem;padding:0.6rem 0.85rem;
  background:rgba(181,41,78,0.05);border:1.5px solid rgba(181,41,78,0.18);
  border-radius:8px;font-size:0.72rem;color:var(--muted);font-family:var(--font);
  line-height:1.45;
}

/* emergency — full-row tap targets */
.emg-row{
  display:flex;align-items:center;gap:0.85rem;
  padding:0.8rem 1.15rem;
  border-bottom:1px solid rgba(61,139,110,0.07);
  text-decoration:none;transition:background 0.13s;font-family:var(--font);
}
.emg-row:last-child{border-bottom:none;}
.emg-row:hover{background:rgba(255,255,255,0.6);}
.emg-dot{
  width:38px;height:38px;border-radius:9px;flex-shrink:0;
  background:rgba(181,41,78,0.08);border:2px solid rgba(181,41,78,0.18);
  display:flex;align-items:center;justify-content:center;
  font-size:0.75rem;font-weight:800;color:var(--pink);font-family:var(--font);
}
.emg-dot.long{font-size:0.68rem;}
.emg-desc{flex:1;min-width:0;font-family:var(--font);}
.emg-num-text{font-size:0.9rem;font-weight:700;color:var(--pink);font-family:var(--font);}
.emg-lbl-text{font-size:0.68rem;color:var(--muted);margin-top:0.05rem;font-family:var(--font);}
.emg-arrow{color:rgba(181,41,78,0.3);flex-shrink:0;}

.mn{font-weight:700;letter-spacing:0.02em;font-family:var(--font);}
.ac{color:var(--amber);font-weight:600;}
.okc{color:var(--green);font-weight:600;}

/* info-only segment (no checkbox) */
.seg-info{
  cursor:default;opacity:0.72;
  background:rgba(61,139,110,0.02);
}
.seg-info:hover{background:rgba(61,139,110,0.04);}
.seg-info .sttl{color:var(--ink2);font-style:italic;}
.seg-info-dot{
  width:18px;height:18px;border-radius:50%;flex-shrink:0;margin-top:2px;
  border:1.5px dashed rgba(61,139,110,0.3);
  display:flex;align-items:center;justify-content:center;
  background:transparent;
}
.seg-info-dot::after{
  content:'';width:5px;height:5px;border-radius:50%;
  background:rgba(61,139,110,0.3);display:block;
}
#btt{
  position:fixed;bottom:1.2rem;right:1.4rem;z-index:200;
  width:38px;height:38px;border-radius:50%;
  background:rgba(255,255,255,0.82);backdrop-filter:blur(16px);
  border:1px solid var(--border);box-shadow:var(--sh);
  color:var(--ink2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  opacity:0;transform:translateY(8px);pointer-events:none;
  transition:opacity 0.22s,transform 0.22s;
}
#btt.show{opacity:1;transform:none;pointer-events:all;}
#btt:hover{background:white;color:var(--green);}

/* ── Responsive ─────────────────────────────────── */
@media(max-width:640px){
  nav{top:0.6rem;padding:5px;max-width:calc(100vw - 16px);overflow-x:auto;border-radius:10px;}
  .nt{padding:0.52rem 0.9rem;font-size:0.78rem;border-radius:8px;}
  .wrap{padding:0 0.9rem;}
  .summary-strip{grid-template-columns:repeat(2,1fr);}
  .sc:nth-child(1)::after,.sc:nth-child(2)::after{display:block;}
  .sc:nth-child(1){border-bottom:2px solid var(--border2);}
  .sc:nth-child(2){border-bottom:2px solid var(--border2);}
  .cov{grid-template-columns:repeat(3,1fr);}
  #p4 .wrap>div[style]{grid-template-columns:1fr!important;}
  .stopGroup.open .stopGroupBody{grid-template-columns:1fr 1fr;}
  #route-real-map{height:460px;}
  .sv{font-size:1.6rem!important;}
}
@media(max-width:400px){
  .nt{padding:0.4rem 0.6rem;font-size:0.7rem;}
  .stopGroup.open .stopGroupBody{grid-template-columns:1fr;}
}
</style>

<script>
try{
  if(!localStorage.getItem('cp26-clean-v4')){
    ['cp26c','cp26c2','cp26b2','cp26n2'].forEach(function(k){localStorage.removeItem(k);});
    localStorage.setItem('cp26-clean-v4','1');
  }
}catch(e){}
</script>
</head>
<body>

<nav>
  <button class="nt active" onclick="showPage('p1',this)">Maršruts</button>
  <button class="nt" onclick="showPage('p2',this)">Izmaksas</button>
  <button class="nt" onclick="showPage('p3',this)">Karte</button>
  <button class="nt" onclick="showPage('p4',this)">Kontakti</button>
</nav>

<button id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Uz augšu">
  <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.3">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
  </svg>
</button>

<!-- PAGE 1: Maršruts -->
<div id="p1" class="page active">
  <div class="wrap">

    <!-- Summary strip -->
    <div class="summary-strip">
      <div class="sc">
        <span class="sv">~4 200</span>
        <span class="sl">km kopā</span>
      </div>
      <div class="sc">
        <span class="sv">9</span>
        <span class="sl">Dienas</span>
      </div>
      <div class="sc pct-cell">
        <span class="sv" id="spct">0%</span>
        <span class="sl">Pabeigts</span>
      </div>
      <div class="sc">
        <span class="sv" id="slft">–</span>
        <span class="sl">Pieturas atlicis</span>
      </div>
    </div>

    <div id="dw"></div>
  </div>
</div>

<!-- PAGE 2: Izmaksas -->
<div id="p2" class="page">
  <div class="wrap">
    <div class="cov">
      <div class="cvc"><span class="cvv" id="kb">—</span><span class="cvl">Plānotais</span></div>
      <div class="cvc" style="position:relative;">
        <span class="cvv" id="ka">—</span>
        <span class="cvl">Iztērēts</span>
        <span id="ka-auto" style="display:none;font-size:0.55rem;color:var(--muted);margin-top:0.18rem;"></span>
        <button id="ka-edit-btn" onclick="startSummaryEdit()" title="Rediģēt" style="position:absolute;top:0.6rem;right:0.6rem;font-family:var(--font);font-size:0.75rem;font-weight:600;color:var(--muted);background:rgba(255,255,255,0.7);border:1px solid var(--border);border-radius:6px;padding:0.14rem 0.42rem;cursor:pointer;transition:all 0.15s;" onmouseover="this.style.color='var(--green)'" onmouseout="this.style.color='var(--muted)'">✎</button>
        <div class="cov-spent-bar"><div class="cov-spent-fill" id="spent-bar-fill" style="width:0%"></div></div>
      </div>
      <div class="cvc"><span class="cvv" id="kd">—</span><span class="cvl">Starpība</span></div>
    </div>
    <div id="cw"></div>
  </div>
</div>

<!-- PAGE 3: Karte -->
<div id="p3" class="page">
  <div class="wrap">
    <div class="card ml">
      <div class="li"><div class="ld" style="background:#b5294e;"></div> Naktsmītne</div>
      <div class="li"><div class="ld" style="background:#a07ac4;"></div> Sacensības</div>
      <div class="li"><div class="ld" style="background:#3d8b6e;"></div> Apskate</div>
      <div class="li"><div class="ld" style="background:#4a80b5;"></div> Degviela / Tehniskie</div>
    </div>
    <a class="mab card" href="https://www.google.com/maps/dir/Valmiera,+Latvia/Warsaw,+Poland/M%C3%B6dling,+Austria/Vienna+Musikverein,+Vienna,+Austria/Berlin,+Germany/Valmiera,+Latvia" target="_blank">
      <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
      </svg>
      Atvērt pilnu maršrutu Google Maps
    </a>
    <div class="slbl">Interaktīvā maršruta karte</div>
    <div class="realMapWrap">
      <div class="realMapTop">
        <div class="realMapHelp">Zoomo ar +/−, diviem pirkstiem vai dubultklikšķi. Klikšķini piespraudes — adrese, info un izmaksas.</div>
        <div class="realMapControls">
          <button type="button" onclick="realMapZoomIn()">+</button>
          <button type="button" onclick="realMapZoomOut()">−</button>
          <button type="button" onclick="realMapFit()">Viss maršruts</button>
        </div>
      </div>
      <div id="route-real-map"></div>
    </div>
    <div class="slbl">Pieturas pa dienām</div>
    <div class="stopGroups" id="stops-g"></div>
  </div>
</div>

<!-- PAGE 4: Kontakti -->
<div id="p4" class="page">
  <div class="ph">
    <h1><em>Kontakti & Info</em></h1>
    <p class="sub">Naktsmītnes · Sacensības · Ārkārtas numuri</p>
  </div>
  <div class="wrap">

    <!-- Accommodations -->
    <div class="info-section open">
      <button class="info-header" onclick="this.parentElement.classList.toggle('open')">
        <div class="info-icon">🏨</div>
        <div class="info-title">
          <strong>Naktsmītnes</strong>
          <span>Varšava · Mēdlings · Berlīne</span>
        </div>
        <svg class="info-chev" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="info-body">
        <div class="info-row">
          <div class="info-row-icon">🇵🇱</div>
          <div class="info-row-body">
            <div class="info-row-label">Hotel Arkadia Royal · Varšava</div>
