          </div>
          <div class="info-row-right">
            <span class="info-badge badge-ok">OK</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Competition -->
    <div class="info-section open">
      <button class="info-header" onclick="this.parentElement.classList.toggle('open')">
        <div class="info-icon">🏅</div>
        <div class="info-title">
          <strong>Hedda Urbani Wettbewerb</strong>
          <span>29.–31. maijs · Musikverein, Vīne</span>
        </div>
        <svg class="info-chev" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="info-body">
        <div class="info-row">
          <div class="info-row-icon">✉️</div>
          <div class="info-row-body">
            <div class="info-row-label">Kontakts</div>
            <div class="info-row-val"><a href="mailto:competition@opernfreunde.at">competition@opernfreunde.at</a></div>
          </div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🎹</div>
          <div class="info-row-body">
            <div class="info-row-label">29. maijs · Mēģinājums</div>
            <div class="info-row-val">Penzingerstrasse 7, 1140 Vīne</div>
            <div class="info-row-sub"><a href="tel:+431711550">+43 1 71155</a> · laiks pēc epasta</div>
          </div>
          <div class="info-row-right"><span class="info-badge badge-warn">laiks?</span></div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">⭐</div>
          <div class="info-row-body">
            <div class="info-row-label">30. maijs · 2. Kārta · 10:00–17:00</div>
            <div class="info-row-val">Steinerner Saal · Musikverein</div>
            <div class="info-row-sub"><a href="tel:+4315058190">+43 1 505 8190</a></div>
          </div>
        </div>
        <div class="info-row">
          <div class="info-row-icon">🏆</div>
          <div class="info-row-body">
            <div class="info-row-label">31. maijs · Fināls</div>
            <div class="info-row-val">Glaserner Saal · Musikverein</div>
            <div class="info-row-sub">laiks — pēc ziņas</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Arias -->
    <div class="info-section">
      <button class="info-header" onclick="this.parentElement.classList.toggle('open')">
        <div class="info-icon">🎼</div>
        <div class="info-title">
          <strong>Āriju saraksts</strong>
          <span>5 ārijas · visas partitūras līdzi!</span>
        </div>
        <svg class="info-chev" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </button>
      <div class="info-body">
        <div class="aria-row">
          <div class="aria-num">1</div>
          <div class="aria-body">
            <div class="aria-composer">Puccini · La Bohème</div>
            <div class="aria-name">"Sì, mi chiamano Mimì"</div>
          </div>
        </div>
        <div class="aria-row">
          <div class="aria-num">2</div>
          <div class="aria-body">
            <div class="aria-composer">Bellini · La sonnambula</div>
            <div class="aria-name">"Ah! non credea mirarti"</div>
          </div>
        </div>
        <div class="aria-row">
          <div class="aria-num">3</div>
          <div class="aria-body">
            <div class="aria-composer">Mozart · Così fan tutte</div>
            <div class="aria-name">"Come scoglio immoto resta"</div>
          </div>
        </div>
        <div class="aria-row">
          <div class="aria-num">4</div>
