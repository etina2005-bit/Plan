  {name:"Musikverein — Steinerner Saal",lat:48.2006,lng:16.3726,type:"gold",day:"D4",address:"Musikvereinsplatz 1, 1010 Wien",info:"Hedda Urbani Wettbewerb 2. kārta.",cost:"Transports ~EUR 8"},
  {name:"Musikverein — Glaserner Saal",lat:48.2008,lng:16.373,type:"gold",day:"D5",address:"Musikvereinsplatz 1, 1010 Wien",info:"Fināls.",cost:"Transports ~EUR 8"},
  {name:"Prāga — Kārļa tilts",lat:50.0865,lng:14.4114,type:"green",day:"D6",address:"Karlův most, Praha",info:"1.5h pietura, vecpilsēta.",cost:"~EUR 21"},
  {name:"Drēzdene — Frauenkirche",lat:51.0519,lng:13.7414,type:"green",day:"D6",address:"Frauenkirche, Dresden",info:"45 min pietura pie Elbas.",cost:"~EUR 10"},
